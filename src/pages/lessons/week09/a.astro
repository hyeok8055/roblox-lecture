---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';

// 확인 퀴즈 옵션
const quiz1Options = JSON.stringify(["Handle", "Part", "Tool", "Grip"]);
const quiz2Options = JSON.stringify(["Activated", "Touched", "Equipped", "MouseButton1Click"]);
const quiz3Options = JSON.stringify(["canDamage = false", "canDamage = true", "return", "break"]);
const quiz4Options = JSON.stringify(["StarterPack", "Workspace", "ReplicatedStorage", "ServerStorage"]);

// =========================================
// 드롭다운 퀴즈 데이터 (8개)
// =========================================

// 퀴즈 1: 기본 Tool 구조
const basicToolBlanks = JSON.stringify([
    { id: "b1", correct: "script.Parent", options: ["script.Parent", "game", "workspace", "script"] },
    { id: "b2", correct: "\"Handle\"", options: ["\"Handle\"", "\"Part\"", "\"Tool\"", "\"Grip\""] },
    { id: "b3", correct: "Activated", options: ["Activated", "Touched", "Equipped", "Unequipped"] }
]);
const basicToolTemplate = `-- ========================================
-- ⚔️ Tool 기본 구조
-- ========================================
-- 📦 준비: Tool + Handle(Part) + Script
-- 💡 Tool의 Script에서 tool = script.Parent
-- 💡 Handle = 손에 쥐는 파트 (이름 정확히!)
-- 💡 Activated = 클릭했을 때 이벤트
-- ========================================

-- 💡 Tool 자체를 가리킴!
local tool = [b1]
-- 💡 손잡이 파트 찾기!
local handle = tool:WaitForChild([b2])

-- 💡 클릭하면 실행!
tool.[b3]:Connect(function()
    print("검을 휘둘렀어요! ⚔️")
end)`;
const basicToolFullCode = `-- ⚔️ Tool 기본 구조
-- 📦 Tool → Handle + Script
local tool = script.Parent
local handle = tool:WaitForChild("Handle")

tool.Activated:Connect(function()
    print("검을 휘둘렀어요! ⚔️")
end)`;

// 퀴즈 2: 장착/해제 감지
const equipEventsBlanks = JSON.stringify([
    { id: "b1", correct: "Equipped", options: ["Equipped", "Activated", "Touched", "ChildAdded"] },
    { id: "b2", correct: "Unequipped", options: ["Unequipped", "Equipped", "Activated", "Changed"] },
    { id: "b3", correct: "Activated", options: ["Activated", "Touched", "Equipped", "MouseButton1Click"] }
]);
const equipEventsTemplate = `-- ========================================
-- 👊 장착/해제/클릭 이벤트
-- ========================================
-- 📦 준비: Tool → Handle + Script
-- 💡 Equipped = 도구를 꺼낼 때 (1~9키)
-- 💡 Unequipped = 도구를 집어넣을 때
-- 💡 Activated = 클릭할 때
-- ========================================

local tool = script.Parent

-- 💡 장착할 때!
tool.[b1]:Connect(function()
    print("검을 들었어요! 👊")
end)

-- 💡 해제할 때!
tool.[b2]:Connect(function()
    print("검을 내려놨어요! ✌️")
end)

-- 💡 클릭할 때!
tool.[b3]:Connect(function()
    print("검을 휘둘렀어요! ⚔️")
end)`;
const equipEventsFullCode = `-- 👊 장착/해제/클릭 이벤트
-- 📦 Tool → Handle + Script
local tool = script.Parent

tool.Equipped:Connect(function()
    print("검을 들었어요!")
end)

tool.Unequipped:Connect(function()
    print("검을 내려놨어요!")
end)

tool.Activated:Connect(function()
    print("검을 휘둘렀어요!")
end)`;

// 퀴즈 3: 검으로 적 감지
const touchDetectBlanks = JSON.stringify([
    { id: "b1", correct: "handle", options: ["handle", "tool", "script", "workspace"] },
    { id: "b2", correct: "\"Humanoid\"", options: ["\"Humanoid\"", "\"Character\"", "\"Head\"", "\"HumanoidRootPart\""] },
    { id: "b3", correct: "humanoid", options: ["humanoid", "hit", "handle", "tool"] }
]);
const touchDetectTemplate = `-- ========================================
-- 🔍 검으로 적 감지하기!
-- ========================================
-- 📦 준비: Tool → Handle + Script
-- 💡 handle.Touched = 검(Handle)에 닿았을 때!
-- 💡 hit.Parent = 닿은 것의 모델(캐릭터)
-- 💡 FindFirstChild("Humanoid") = 사람인지 확인
-- ========================================

local tool = script.Parent
local handle = tool:WaitForChild("Handle")

-- 💡 Handle에 닿으면!
[b1].Touched:Connect(function(hit)
    -- 💡 Humanoid가 있는지 확인!
    local humanoid = hit.Parent:FindFirstChild([b2])
    -- 💡 사람이면!
    if [b3] then
        print(hit.Parent.Name .. "에게 닿았어요!")
    end
end)`;
const touchDetectFullCode = `-- 🔍 검으로 적 감지
-- 📦 Tool → Handle + Script
local tool = script.Parent
local handle = tool:WaitForChild("Handle")

handle.Touched:Connect(function(hit)
    local humanoid = hit.Parent:FindFirstChild("Humanoid")
    if humanoid then
        print(hit.Parent.Name .. "에게 닿았어요!")
    end
end)`;

// 퀴즈 4: canDamage 패턴
const canDamageBlanks = JSON.stringify([
    { id: "b1", correct: "false", options: ["false", "true", "nil", "0"] },
    { id: "b2", correct: "true", options: ["true", "false", "nil", "1"] },
    { id: "b3", correct: "false", options: ["false", "true", "nil", "0"] },
    { id: "b4", correct: "canDamage", options: ["canDamage", "not canDamage", "hit", "true"] }
]);
const canDamageTemplate = `-- ========================================
-- ⚡ 클릭할 때만 데미지! (canDamage 패턴)
-- ========================================
-- 📦 준비: Tool → Handle + Script
-- 💡 문제: Handle에 항상 닿아있으면 데미지 무한!
-- 💡 해결: canDamage 변수로 클릭 순간만 활성화!
-- ========================================

local tool = script.Parent
local handle = tool:WaitForChild("Handle")
-- 💡 데미지 가능한지 체크 (처음엔 안됨)
local canDamage = [b1]

tool.Activated:Connect(function()
    -- 💡 클릭하면 켜기!
    canDamage = [b2]
    task.wait(0.5)
    -- 💡 0.5초 후 끄기!
    canDamage = [b3]
end)

handle.Touched:Connect(function(hit)
    -- 💡 켜져있을 때만!
    if [b4] then
        print("데미지!")
    end
end)`;
const canDamageFullCode = `-- ⚡ canDamage 패턴
-- 📦 Tool → Handle + Script
local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local canDamage = false

tool.Activated:Connect(function()
    canDamage = true
    task.wait(0.5)
    canDamage = false
end)

handle.Touched:Connect(function(hit)
    if canDamage then
        print("데미지!")
    end
end)`;

// 퀴즈 5: TakeDamage 적용
const takeDamageBlanks = JSON.stringify([
    { id: "b1", correct: "\"Humanoid\"", options: ["\"Humanoid\"", "\"Head\"", "\"Character\"", "\"HumanoidRootPart\""] },
    { id: "b2", correct: ":TakeDamage(25)", options: [":TakeDamage(25)", ":Destroy()", ".Health = 0", ":Kill()"] },
    { id: "b3", correct: "false", options: ["false", "true", "nil", "0"] }
]);
const takeDamageTemplate = `-- ========================================
-- 💢 TakeDamage로 데미지 주기!
-- ========================================
-- 📦 준비: Tool → Handle + Script
-- 💡 TakeDamage(25) = 체력 -25!
-- 💡 데미지 주고 나서 canDamage = false!
-- 💡 한 번에 한 명에게만 데미지!
-- ========================================

local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local canDamage = false

tool.Activated:Connect(function()
    canDamage = true
    task.wait(0.5)
    canDamage = false
end)

handle.Touched:Connect(function(hit)
    if canDamage then
        -- 💡 Humanoid 찾기!
        local humanoid = hit.Parent:FindFirstChild([b1])
        if humanoid then
            -- 💡 체력 -25!
            humanoid[b2]
            -- 💡 한 번 데미지 후 끄기!
            canDamage = [b3]
        end
    end
end)`;
const takeDamageFullCode = `-- 💢 TakeDamage 데미지
-- 📦 Tool → Handle + Script
local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local canDamage = false

tool.Activated:Connect(function()
    canDamage = true
    task.wait(0.5)
    canDamage = false
end)

handle.Touched:Connect(function(hit)
    if canDamage then
        local humanoid = hit.Parent:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:TakeDamage(25)
            canDamage = false
        end
    end
end)`;

// 퀴즈 6: 자기 자신 제외
const selfExcludeBlanks = JSON.stringify([
    { id: "b1", correct: "tool.Parent", options: ["tool.Parent", "hit.Parent", "handle", "script.Parent"] },
    { id: "b2", correct: "\"Humanoid\"", options: ["\"Humanoid\"", "\"Character\"", "\"Head\"", "\"Human\""] },
    { id: "b3", correct: "false", options: ["false", "true", "nil", "0"] }
]);
const selfExcludeTemplate = `-- ========================================
-- 🚫 자기 자신 공격 방지!
-- ========================================
-- 📦 준비: Tool → Handle + Script
-- 💡 tool.Parent = 이 Tool을 든 캐릭터!
-- 💡 hit.Parent ~= tool.Parent = "나 아닌 누군가"
-- 💡 자기 자신을 공격하지 않으려면 이게 필수!
-- ========================================

local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local canDamage = false

tool.Activated:Connect(function()
    canDamage = true
    task.wait(0.5)
    canDamage = false
end)

handle.Touched:Connect(function(hit)
    -- 💡 나를 제외하고 데미지!
    if canDamage and hit.Parent ~= [b1] then
        local humanoid = hit.Parent:FindFirstChild([b2])
        if humanoid then
            humanoid:TakeDamage(25)
            canDamage = [b3]
        end
    end
end)`;
const selfExcludeFullCode = `-- 🚫 자기 자신 제외
-- 📦 Tool → Handle + Script
local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local canDamage = false

tool.Activated:Connect(function()
    canDamage = true
    task.wait(0.5)
    canDamage = false
end)

handle.Touched:Connect(function(hit)
    if canDamage and hit.Parent ~= tool.Parent then
        local humanoid = hit.Parent:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:TakeDamage(25)
            canDamage = false
        end
    end
end)`;

// 퀴즈 7: 효과음 추가
const soundEffectBlanks = JSON.stringify([
    { id: "b1", correct: "\"Sound\"", options: ["\"Sound\"", "\"Music\"", "\"Part\"", "\"Effect\""] },
    { id: "b2", correct: "handle", options: ["handle", "tool", "workspace", "script"] },
    { id: "b3", correct: ":Play()", options: [":Play()", ":Start()", ":Run()", ":Connect()"] }
]);
const soundEffectTemplate = `-- ========================================
-- 🔊 검 효과음 추가!
-- ========================================
-- 📦 준비: Tool → Handle + Script
-- 💡 Sound를 Handle 안에 넣으면 소리가 나요!
-- 💡 SoundId = rbxassetid://숫자 형식!
-- 💡 Activated 때 :Play()로 재생!
-- ========================================

local tool = script.Parent
local handle = tool:WaitForChild("Handle")

-- 💡 효과음 만들기!
local swingSound = Instance.new([b1])
swingSound.SoundId = "rbxassetid://9120386436"
-- 💡 Handle 안에 넣기!
swingSound.Parent = [b2]

tool.Activated:Connect(function()
    -- 💡 소리 재생!
    swingSound[b3]
    print("쉭! ⚔️")
end)`;
const soundEffectFullCode = `-- 🔊 검 효과음
-- 📦 Tool → Handle + Script
local tool = script.Parent
local handle = tool:WaitForChild("Handle")

local swingSound = Instance.new("Sound")
swingSound.SoundId = "rbxassetid://9120386436"
swingSound.Parent = handle

tool.Activated:Connect(function()
    swingSound:Play()
    print("쉭!")
end)`;

// 퀴즈 8: 완성된 검 스크립트
const finalSwordBlanks = JSON.stringify([
    { id: "b1", correct: "\"Handle\"", options: ["\"Handle\"", "\"Part\"", "\"Script\"", "\"Tool\""] },
    { id: "b2", correct: "true", options: ["true", "false", "1", "nil"] },
    { id: "b3", correct: "tool.Parent", options: ["tool.Parent", "hit.Parent", "handle", "nil"] },
    { id: "b4", correct: ":TakeDamage(25)", options: [":TakeDamage(25)", ":Destroy()", ".Health = 0", ":Kill()"] }
]);
const finalSwordTemplate = `-- ========================================
-- ⚔️ 완성된 검 스크립트!
-- ========================================
-- 📦 준비: Tool → Handle + Script
-- 💡 모든 요소를 합친 완성형!
-- 💡 효과음 + canDamage + 자기 자신 제외
-- ========================================

local tool = script.Parent
-- 💡 손잡이 파트!
local handle = tool:WaitForChild([b1])
local canDamage = false

-- 💡 효과음
local swingSound = Instance.new("Sound")
swingSound.SoundId = "rbxassetid://9120386436"
swingSound.Parent = handle

tool.Activated:Connect(function()
    -- 💡 클릭 = 공격 ON!
    canDamage = [b2]
    swingSound:Play()
    task.wait(0.5)
    canDamage = false
end)

handle.Touched:Connect(function(hit)
    -- 💡 나 제외 + 공격 가능할 때!
    if canDamage and hit.Parent ~= [b3] then
        local humanoid = hit.Parent:FindFirstChild("Humanoid")
        if humanoid then
            -- 💡 데미지 -25!
            humanoid[b4]
            canDamage = false
        end
    end
end)`;
const finalSwordFullCode = `-- ⚔️ 완성된 검 스크립트
-- 📦 Tool → Handle + Script
local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local canDamage = false

local swingSound = Instance.new("Sound")
swingSound.SoundId = "rbxassetid://9120386436"
swingSound.Parent = handle

tool.Activated:Connect(function()
    canDamage = true
    swingSound:Play()
    task.wait(0.5)
    canDamage = false
end)

handle.Touched:Connect(function(hit)
    if canDamage and hit.Parent ~= tool.Parent then
        local humanoid = hit.Parent:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:TakeDamage(25)
            canDamage = false
        end
    end
end)`;
---

<LessonLayout title="Tool 기초: 검 만들기" lessonNumber={9} totalSlides={20}>
    <!-- 슬라이드 1: 인트로 -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">9주차 A</span>
                <h1 class="title-display mb-4">
                    <span class="text-neon-gold">Tool</span>: 검 만들기<br>
                    <span class="text-neon-mint">⚔️ 나만의 무기!</span>
                </h1>
                <p class="text-xl text-ink-light max-w-lg mx-auto mb-8">
                    캐릭터가 들고 휘두를 수 있는<br>
                    진짜 검을 만들어봐요!
                </p>
                <div class="flex gap-3 justify-center flex-wrap">
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">⚔️ Tool</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">✋ Handle</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🎒 StarterPack</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🖱️ Activated</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">💢 TakeDamage</span>
                    </div>
                </div>

                <div class="mt-12 p-6 bg-gradient-to-r from-amber-50 to-red-50 rounded-2xl max-w-md mx-auto">
                    <div class="text-3xl mb-2">🎯</div>
                    <h3 class="font-bold mb-2">오늘의 목표</h3>
                    <ul class="text-left text-sm text-ink-light space-y-1">
                        <li>✓ Tool과 Handle의 구조 이해하기</li>
                        <li>✓ StarterPack→Backpack→Character 여행 이해</li>
                        <li>✓ Activated / Equipped / Unequipped 이벤트</li>
                        <li>✓ canDamage 패턴으로 클릭할 때만 공격</li>
                        <li>✓ 완성된 검 스크립트 작성하기</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 슬라이드 2: Tool이란? (확장) -->
    <section class="slide">
        <div class="max-w-4xl mx-auto px-6 py-12">
            <div class="animate-in">
                <span class="badge badge-lesson mb-4">개념 학습</span>
                <h2 class="title-section mb-6">Tool이란?</h2>
            </div>

            <div class="flex flex-col gap-6">
                <div class="animate-in">
                    <div class="lesson-card">
                        <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
                            <span class="text-2xl">🎮</span>
                            알고 있는 게임에서 다 써봤어요!
                        </h3>
                        <p class="text-ink-light mb-4">
                            로블록스에서 <strong>Tool</strong>은 캐릭터가 손에 들고 사용하는 모든 것이에요.<br>
                            이미 알고 있는 인기 게임들에서 다 나와요!
                        </p>
                        <div class="grid md:grid-cols-4 gap-3 mb-4">
                            <div class="p-3 bg-gradient-to-br from-red-50 to-rose-50 rounded-xl text-center">
                                <div class="text-2xl mb-1">⚔️</div>
                                <div class="font-bold text-sm">Murder Mystery 2</div>
                                <div class="text-xs text-ink-light">칼, 총</div>
                            </div>
                            <div class="p-3 bg-gradient-to-br from-blue-50 to-sky-50 rounded-xl text-center">
                                <div class="text-2xl mb-1">🔫</div>
                                <div class="font-bold text-sm">Arsenal</div>
                                <div class="text-xs text-ink-light">총, 칼</div>
                            </div>
                            <div class="p-3 bg-gradient-to-br from-pink-50 to-fuchsia-50 rounded-xl text-center">
                                <div class="text-2xl mb-1">🐾</div>
                                <div class="font-bold text-sm">Adopt Me!</div>
                                <div class="text-xs text-ink-light">빗, 젖병</div>
                            </div>
                            <div class="p-3 bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl text-center">
                                <div class="text-2xl mb-1">🪛</div>
                                <div class="font-bold text-sm">직접 만들기</div>
                                <div class="text-xs text-ink-light">검, 지팡이, 도구</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="animate-in">
                    <div class="lesson-card">
                        <h3 class="font-bold text-lg mb-4">🔢 키보드 슬롯으로 장착!</h3>
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <div class="flex gap-1 mb-3 flex-wrap">
                                    {["1","2","3","4","5","6","7","8","9"].map((n) => (
                                        <div class="w-9 h-9 bg-gray-800 text-white rounded-lg flex items-center justify-center font-bold text-sm shadow-md">{n}</div>
                                    ))}
                                    <div class="px-3 h-9 bg-red-800 text-white rounded-lg flex items-center justify-center font-bold text-xs shadow-md">⌫</div>
                                </div>
                                <ul class="text-sm text-ink-light space-y-1">
                                    <li>🔢 <strong>1~9키</strong>: 해당 슬롯의 Tool 장착</li>
                                    <li>⌫ <strong>Backspace</strong>: Tool 버리기 (CanBeDropped = true일 때)</li>
                                    <li>🖱️ <strong>마우스 클릭</strong>: Activated 이벤트 발생!</li>
                                </ul>
                            </div>
                            <div class="text-center">
                                <img src="https://prod.docsiteassets.roblox.com/assets/players/in-experience-tools/Tool-Inventory.jpg" alt="Tool 인벤토리" class="rounded-xl w-full" loading="lazy" />
                                <p class="text-xs text-ink-light mt-2">화면 하단 슬롯 = Backpack (인벤토리)</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="animate-in">
                    <div class="text-center">
                        <img src="https://prod.docsiteassets.roblox.com/assets/tutorials/creating-player-tools/title-image.jpg" alt="Tool을 장착한 캐릭터" class="rounded-xl max-h-48 mx-auto" loading="lazy" />
                        <p class="text-xs text-ink-light mt-2">Tool을 장착한 캐릭터 모습</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 슬라이드 3: Tool의 여행 (생명주기) - 신규 -->
    <section class="slide">
        <div class="max-w-4xl mx-auto px-6 py-12">
