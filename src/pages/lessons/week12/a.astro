-- =============================================
-- 메인 게임 루프: 게임 시작 시 자동 실행
-- =============================================
local function gameLoop()
    while true do
        -- [1] 대기 시간 (인터미션)
        print("=== 인터미션 ===")
        RoundInfo:FireAllClients("Intermission", INTERMISSION)
        task.wait(INTERMISSION)

        -- [2] 새 맵 로드
        local currentMap = loadMap()

        -- [3] 모든 플레이어를 타워 시작점으로 텔레포트
        local spawnPoint = currentMap:FindFirstChild("SpawnPoint")
        for _, player in Players:GetPlayers() do
            local character = player.Character
            if character then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = spawnPoint.CFrame + Vector3.new(0, 3, 0)
                end
            end
            -- 이번 라운드 클리어 플래그 초기화
            player:SetAttribute("HasWon", false)
        end

        -- [4] WinPart 연결
        local winPart = currentMap:FindFirstChild("WinPart")
        local winConnection
        if winPart then
            winConnection = winPart.Touched:Connect(function(hit)
                local player = Players:GetPlayerFromCharacter(hit.Parent)
                if player then
                    onPlayerWin(player)
                end
            end)
        end

        -- [5] 타이머 시작 (480초 카운트다운)
        RoundInfo:FireAllClients("RoundStart", currentMap.Name)
        startTimer()

        -- [6] 라운드 종료: WinPart 연결 해제
        if winConnection then
            winConnection:Disconnect()
        end

        print("=== 라운드 종료 ===")
    end
end

-- 게임 시작!
gameLoop()
