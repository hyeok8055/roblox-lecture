local HeightUpdate = ReplicatedStorage:FindFirstChild("HeightUpdate")

-- =============================================
-- 높이 추적: 별도 스레드에서 0.5초마다 실행
-- =============================================
local function trackHeights(currentMap)
    local spawnPoint = currentMap:FindFirstChild("SpawnPoint")
    local winPart = currentMap:FindFirstChild("WinPart")
    if not spawnPoint or not winPart then return end

    local baseY = spawnPoint.Position.Y    -- 시작점 높이
    local topY = winPart.Position.Y        -- 꼭대기 높이
    local totalHeight = topY - baseY       -- 타워 전체 높이

    -- 별도 스레드로 실행 (메인 루프를 막지 않기 위해)
    task.spawn(function()
        while currentMap.Parent ~= nil do  -- 맵이 존재하는 동안
            local heightData = &#123;&#125;

            for _, player in Players:GetPlayers() do
                local character = player.Character
                if character then
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        -- 진행도 계산 (0~1 사이로 제한)
                        local progress = (hrp.Position.Y - baseY) / totalHeight
                        progress = math.clamp(progress, 0, 1)

                        table.insert(heightData, &#123;
                            name = player.Name,
                            progress = progress
                        &#125;)
                    end
                end
            end

            -- 모든 클라이언트에 높이 데이터 전송
            HeightUpdate:FireAllClients(heightData)
            task.wait(0.5)
        end
    end)
end
