---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';
---

<LessonLayout title="Tower of Hell - 게임 시스템 설계" lessonNumber={12} totalSlides={20}>

    <!-- ==================== 슬라이드 1: 인트로 ==================== -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">12주차 A</span>
                <h1 class="title-display mb-4">
                    Tower of Hell<br>
                    <span class="text-neon-mint">게임 시스템 설계</span>
                </h1>
                <p class="text-ink-light text-lg max-w-2xl mx-auto mb-8">
                    실제 인기 게임의 핵심 시스템을 직접 설계하고 구현합니다.<br>
                    리더보드, 타이머, 맵 로테이션, 높이 추적까지 — 진짜 게임을 만듭니다.
                </p>
                <div class="flex flex-wrap justify-center gap-3 mb-8">
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">Leaderstats</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">Timer &amp; Round</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">Map Rotation</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">Height Tracker</span>
                </div>
                <HintBox type="info" title="이번 수업 목표">
                    Tower of Hell 스타일 게임의 <strong>서버 핵심 로직</strong>을 설계합니다.<br>
                    리더보드 점수 시스템, 라운드 타이머, 맵 자동 교체, 플레이어 높이 추적을 구현합니다.
                </HintBox>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 2: 전체 구조도 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 설계</span>
            <h2 class="title-section mb-6">게임 전체 구조</h2>
            <p class="text-ink-light mb-8">Tower of Hell은 여러 시스템이 유기적으로 연결된 게임입니다. 먼저 큰 그림을 이해합시다.</p>

            <div class="arch-diagram">
                <div class="arch-layer server-layer">
                    <div class="arch-label">ServerScriptService (서버)</div>
                    <div class="arch-boxes">
                        <div class="arch-box box-core">
                            <strong>GameManager</strong>
                            <span>라운드 진행, 타이머, 맵 교체</span>
                        </div>
                        <div class="arch-box box-data">
                            <strong>LeaderboardManager</strong>
                            <span>점수, 레벨, 클리어 횟수</span>
                        </div>
                        <div class="arch-box box-data">
                            <strong>HeightTracker</strong>
                            <span>플레이어 높이 실시간 추적</span>
                        </div>
                    </div>
                </div>

                <div class="arch-arrow">
                    <span>RemoteEvent / RemoteFunction</span>
                </div>

                <div class="arch-layer client-layer">
                    <div class="arch-label">StarterPlayerScripts (클라이언트)</div>
                    <div class="arch-boxes">
                        <div class="arch-box box-ui">
                            <strong>TimerUI</strong>
                            <span>상단 카운트다운</span>
                        </div>
                        <div class="arch-box box-ui">
                            <strong>HeightBar</strong>
                            <span>우측 진행도 바</span>
                        </div>
                        <div class="arch-box box-ui">
                            <strong>ShopUI / MusicUI</strong>
                            <span>상점, 음악 토글</span>
                        </div>
                    </div>
                </div>

                <div class="arch-layer storage-layer">
                    <div class="arch-label">ServerStorage</div>
                    <div class="arch-boxes">
                        <div class="arch-box box-map">
                            <strong>Maps 폴더</strong>
                            <span>Tower1, Tower2, Tower3...</span>
                        </div>
                    </div>
                </div>
            </div>

            <HintBox type="tip" title="핵심 원칙">
                <strong>서버가 모든 게임 로직을 관리</strong>합니다. 클라이언트는 UI 표시만 담당합니다.<br>
                이렇게 하면 해킹 방지 + 모든 플레이어에게 동일한 게임 상태를 보장할 수 있습니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 3: 폴더 구조 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-roblox mb-4">프로젝트 세팅</span>
            <h2 class="title-section mb-6">Explorer 폴더 구조</h2>
            <p class="text-ink-light mb-8">먼저 로블록스 스튜디오에서 이 구조를 만들어야 합니다.</p>

            <div class="folder-tree">
                <div class="folder-item root">game</div>
                <div class="folder-item l1 folder">ServerScriptService</div>
                <div class="folder-item l2 script">GameManager <span class="tag-server">Script</span></div>
                <div class="folder-item l1 folder">ServerStorage</div>
                <div class="folder-item l2 folder">Maps</div>
                <div class="folder-item l3 model">Tower1 <span class="tag-model">Model</span></div>
                <div class="folder-item l3 model">Tower2 <span class="tag-model">Model</span></div>
                <div class="folder-item l3 model">Tower3 <span class="tag-model">Model</span></div>
                <div class="folder-item l1 folder">ReplicatedStorage</div>
                <div class="folder-item l2 remote">TimerUpdate <span class="tag-remote">RemoteEvent</span></div>
                <div class="folder-item l2 remote">HeightUpdate <span class="tag-remote">RemoteEvent</span></div>
                <div class="folder-item l2 remote">RoundInfo <span class="tag-remote">RemoteEvent</span></div>
                <div class="folder-item l1 folder">Workspace</div>
                <div class="folder-item l2 folder">Lobby <span class="tag-info">스폰 위치</span></div>
                <div class="folder-item l2 folder">ActiveMap <span class="tag-info">현재 타워가 여기에 배치됨</span></div>
                <div class="folder-item l1 folder">StarterPlayerScripts</div>
                <div class="folder-item l2 script-local">GameUI <span class="tag-local">LocalScript</span></div>
            </div>

            <HintBox type="warning" title="Maps 폴더 규칙">
                각 Tower 모델 안에는 반드시 <strong>SpawnPoint</strong>라는 이름의 파트와
                <strong>WinPart</strong>라는 이름의 파트가 있어야 합니다.<br>
                SpawnPoint = 타워 시작점, WinPart = 꼭대기 클리어 판정 파트입니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 4: 리더보드 시스템 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 1</span>
            <h2 class="title-section mb-6">리더보드 (Leaderstats)</h2>
            <p class="text-ink-light mb-8">
                Tab 키를 누르면 보이는 점수판입니다. Tower of Hell에서는 <strong>Level</strong>과 <strong>Wins</strong>를 추적합니다.
            </p>

            <div class="system-card">
                <div class="system-header">
                    <span class="system-icon">&#x1f3c6;</span>
                    <div>
                        <h3>Leaderstats 설계</h3>
                        <p>플레이어가 접속하면 자동으로 생성되는 점수 폴더</p>
                    </div>
                </div>

                <lua-code-block title="GameManager.lua - Leaderstats 부분" show-line-numbers>
local Players = game:GetService("Players")

-- =============================================
-- 리더보드 생성: 플레이어 접속 시 자동 실행
-- =============================================
local function setupLeaderstats(player)
    -- "leaderstats"라는 이름은 반드시 지켜야 함 (로블록스 규칙)
    local leaderstats = Instance.new("Folder")
    leaderstats.Name = "leaderstats"
    leaderstats.Parent = player

    -- Wins: 타워 꼭대기 도달 횟수
    local wins = Instance.new("IntValue")
    wins.Name = "Wins"
    wins.Value = 0
    wins.Parent = leaderstats

    -- Coins: 게임 재화 (상점에서 사용)
    local coins = Instance.new("IntValue")
    coins.Name = "Coins"
    coins.Value = 0
    coins.Parent = leaderstats

    -- Level: 실제 TOH처럼 XP 기반 레벨 시스템
    -- 레벨업 필요 XP: Lv0→1 = 100, Lv1→2 = 200, Lv2→3 = 300...
    local level = Instance.new("IntValue")
    level.Name = "Level"
    level.Value = 0
    level.Parent = leaderstats
end

Players.PlayerAdded:Connect(setupLeaderstats)
                </lua-code-block>
            </div>

            <HintBox type="info" title="실제 Tower of Hell의 레벨 시스템">
                실제 TOH에서는 <strong>코인 획득 = XP 획득</strong>이고, 레벨업에 필요한 XP가 선형으로 증가합니다.<br>
                Lv0&rarr;1 = 100XP, Lv1&rarr;2 = 200XP, Lv2&rarr;3 = 300XP...<br>
                <code>필요XP = (현재레벨 + 1) * 100</code>
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 5: 리더보드 - 점수 부여 로직 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 1 계속</span>
            <h2 class="title-section mb-6">Win 판정 &amp; 점수 부여</h2>
            <p class="text-ink-light mb-8">
                플레이어가 타워 꼭대기의 <strong>WinPart</strong>에 닿으면 클리어로 판정합니다.
            </p>

            <div class="system-card">
                <lua-code-block title="GameManager.lua - Win 판정 부분" show-line-numbers>
-- =============================================
-- Win 판정: WinPart에 닿으면 클리어
-- =============================================
local function onPlayerWin(player)
    local leaderstats = player:FindFirstChild("leaderstats")
    if not leaderstats then return end

    -- 중복 클리어 방지 (같은 라운드에서 1번만)
    if player:GetAttribute("HasWon") then return end
    player:SetAttribute("HasWon", true)

    -- Wins 증가
    local wins = leaderstats:FindFirstChild("Wins")
    wins.Value += 1

    -- Level 재계산
    local level = leaderstats:FindFirstChild("Level")
    level.Value = math.floor(wins.Value / 5) + 1

    -- 전체 서버에 알림 (클라이언트에서 축하 UI 표시용)
    local RoundInfo = game:GetService("ReplicatedStorage"):FindFirstChild("RoundInfo")
    RoundInfo:FireAllClients("PlayerWon", player.Name, wins.Value)

    print(player.Name .. " 클리어! 총 " .. wins.Value .. "승")
end
                </lua-code-block>
            </div>

            <div class="detail-grid mt-6">
                <div class="detail-item">
                    <div class="detail-label">GetAttribute / SetAttribute</div>
                    <div class="detail-desc">플레이어에 임시 데이터를 저장하는 방법. "HasWon"이라는 플래그를 붙여서 같은 라운드에서 중복 클리어를 방지합니다.</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">FireAllClients</div>
                    <div class="detail-desc">서버 → 모든 클라이언트에 메시지 전송. "○○님이 클리어했습니다!" 같은 알림을 모두에게 보낼 때 사용합니다.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 6: 타이머 시스템 개요 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 2</span>
            <h2 class="title-section mb-6">라운드 타이머</h2>
            <p class="text-ink-light mb-8">
                화면 상단 가운데에 표시되는 카운트다운. 시간이 0이 되면 자동으로 다음 맵으로 넘어갑니다.
            </p>

            <div class="timer-demo">
                <div class="timer-display">8:00</div>
                <div class="timer-label">라운드 남은 시간</div>
            </div>

            <div class="flow-diagram mt-8">
                <div class="flow-step">
                    <div class="flow-num">1</div>
                    <div class="flow-text">
                        <strong>라운드 시작</strong>
                        <span>타이머 = ROUND_TIME (480초)</span>
                    </div>
                </div>
                <div class="flow-arrow">&rarr;</div>
                <div class="flow-step">
                    <div class="flow-num">2</div>
                    <div class="flow-text">
                        <strong>매초 감소</strong>
                        <span>타이머 -= 1, UI 업데이트</span>
                    </div>
                </div>
                <div class="flow-arrow">&rarr;</div>
                <div class="flow-step">
                    <div class="flow-num">3</div>
                    <div class="flow-text">
                        <strong>타이머 = 0</strong>
                        <span>라운드 종료, 맵 교체</span>
                    </div>
                </div>
                <div class="flow-arrow">&rarr;</div>
                <div class="flow-step">
                    <div class="flow-num">4</div>
                    <div class="flow-text">
                        <strong>대기 시간</strong>
                        <span>5초 후 새 라운드 시작</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 7: 타이머 서버 코드 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 2 코드</span>
            <h2 class="title-section mb-6">타이머 서버 코드</h2>

            <div class="system-card">
                <lua-code-block title="GameManager.lua - 타이머 부분" show-line-numbers>
-- =============================================
-- 설정값
-- =============================================
local ROUND_TIME = 480    -- 라운드 시간 (초) — 실제 TOH는 8분!
local INTERMISSION = 5    -- 라운드 사이 대기 시간

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TimerUpdate = ReplicatedStorage:FindFirstChild("TimerUpdate")

-- =============================================
-- 타이머 루프: 매초 클라이언트에 남은 시간 전송
-- =============================================
local function startTimer()
    for remaining = ROUND_TIME, 0, -1 do
        -- 분:초 형식으로 변환
        local minutes = math.floor(remaining / 60)
        local seconds = remaining % 60
        local timeText = string.format("%d:%02d", minutes, seconds)

        -- 모든 클라이언트에 시간 전송
        TimerUpdate:FireAllClients(timeText, remaining)

        task.wait(1)
    end
end
                </lua-code-block>
            </div>

            <div class="detail-grid mt-6">
                <div class="detail-item">
                    <div class="detail-label">for remaining = 120, 0, -1</div>
                    <div class="detail-desc">120부터 0까지 1씩 감소하는 역순 for문. 매 반복마다 task.wait(1)로 1초씩 대기합니다.</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">string.format("%d:%02d")</div>
                    <div class="detail-desc">%d = 숫자, %02d = 2자리(앞에 0 채움). 예: 1:05, 0:30 형태로 표시됩니다.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 8: 타이머 클라이언트 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">클라이언트</span>
            <h2 class="title-section mb-6">타이머 UI (클라이언트)</h2>
            <p class="text-ink-light mb-8">서버에서 보낸 시간을 화면에 표시합니다.</p>

            <div class="system-card">
                <lua-code-block title="GameUI (LocalScript) - 타이머 부분" show-line-numbers>
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- =============================================
-- 타이머 UI 생성
-- =============================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GameHUD"
screenGui.Parent = playerGui

local timerLabel = Instance.new("TextLabel")
timerLabel.Name = "Timer"
timerLabel.Size = UDim2.new(0, 200, 0, 60)
timerLabel.Position = UDim2.new(0.5, -100, 0, 20)  -- 상단 가운데
timerLabel.BackgroundTransparency = 1
timerLabel.TextColor3 = Color3.new(1, 1, 1)
timerLabel.TextSize = 48
timerLabel.Font = Enum.Font.GothamBold
timerLabel.TextStrokeTransparency = 0.3   -- 글자 테두리 (가독성)
timerLabel.Text = "8:00"
timerLabel.Parent = screenGui

-- =============================================
-- 서버에서 시간 받으면 UI 업데이트
-- =============================================
local TimerUpdate = ReplicatedStorage:WaitForChild("TimerUpdate")

TimerUpdate.OnClientEvent:Connect(function(timeText, remaining)
    timerLabel.Text = timeText

    -- 30초 이하면 빨간색으로 경고
    if remaining &lt;= 30 then
        timerLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    else
        timerLabel.TextColor3 = Color3.new(1, 1, 1)
    end
end)
                </lua-code-block>
            </div>

            <HintBox type="tip" title="UDim2 위치 계산">
                <code>UDim2.new(0.5, -100, 0, 20)</code> = 화면 가로 50% 지점에서 왼쪽으로 100px 이동, 위에서 20px.<br>
                이렇게 하면 200px 너비의 라벨이 정확히 화면 가운데에 배치됩니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 9: 맵 로테이션 개요 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 3</span>
            <h2 class="title-section mb-6">맵 로테이션 (자동 교체)</h2>
            <p class="text-ink-light mb-8">
                타이머가 끝나면 현재 타워를 제거하고, 새로운 타워를 랜덤으로 불러옵니다.
            </p>

            <div class="rotation-demo">
                <div class="rotation-step">
                    <div class="rotation-icon">&#x1f3d7;</div>
                    <div class="rotation-label">ServerStorage<br><strong>Maps 폴더</strong></div>
                    <div class="rotation-desc">Tower1, Tower2, Tower3... 원본 보관</div>
                </div>
                <div class="rotation-arrow">&rarr;</div>
                <div class="rotation-step active-step">
                    <div class="rotation-icon">&#x1f3ae;</div>
                    <div class="rotation-label">Workspace<br><strong>ActiveMap</strong></div>
                    <div class="rotation-desc">Clone해서 여기에 배치 = 게임에 등장</div>
                </div>
                <div class="rotation-arrow">&rarr;</div>
                <div class="rotation-step">
                    <div class="rotation-icon">&#x1f5d1;</div>
                    <div class="rotation-label">라운드 종료<br><strong>Destroy</strong></div>
                    <div class="rotation-desc">ActiveMap 비우고 새 타워 Clone</div>
                </div>
            </div>

            <HintBox type="warning" title="Clone vs 원본 이동">
                원본을 직접 Workspace로 옮기면 한 번 쓰고 끝입니다.<br>
                <strong>:Clone()</strong>으로 복사본을 만들어야 매 라운드마다 재사용할 수 있습니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 10: 맵 로테이션 코드 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 3 코드</span>
            <h2 class="title-section mb-6">맵 로테이션 서버 코드</h2>

            <div class="system-card">
                <lua-code-block title="GameManager.lua - 맵 로테이션 부분" show-line-numbers>
local ServerStorage = game:GetService("ServerStorage")
local mapsFolder = ServerStorage:WaitForChild("Maps")
local activeMapFolder = workspace:WaitForChild("ActiveMap")

local lastMapName = nil  -- 같은 맵 연속 방지

-- =============================================
-- 랜덤 맵 선택 (직전 맵 제외)
-- =============================================
local function pickRandomMap()
    local maps = mapsFolder:GetChildren()

    -- 맵이 1개뿐이면 그냥 반환
    if #maps &lt;= 1 then
        return maps[1]
    end

    -- 직전 맵과 다른 맵이 나올 때까지 반복
    local chosen
    repeat
        chosen = maps[math.random(1, #maps)]
    until chosen.Name ~= lastMapName

    lastMapName = chosen.Name
    return chosen
end

-- =============================================
-- 맵 배치: Clone → ActiveMap에 넣기
-- =============================================
local function loadMap()
    -- 기존 맵 제거
    for _, child in activeMapFolder:GetChildren() do
        child:Destroy()
    end

    -- 새 맵 복사 후 배치
    local mapTemplate = pickRandomMap()
    local newMap = mapTemplate:Clone()
    newMap.Parent = activeMapFolder

    print("맵 로드: " .. newMap.Name)
    return newMap
end
