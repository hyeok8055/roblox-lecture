local function trackHeights(currentMap)
    local baseY = spawnPart.Position.Y   -- 타워 바닥 (Y=8)
    local topY = winPart.Position.Y      -- 타워 꼭대기 (Y=885)
    local totalHeight = topY - baseY     -- 877 스터드

    task.spawn(function()  -- 별도 스레드에서 실행
        while currentMap.Parent ~= nil do  -- 맵 삭제되면 자동 종료
            local heightData = &#123;&#125;
            for _, plr in Players:GetPlayers() do
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local progress = (hrp.Position.Y - baseY) / totalHeight
                    progress = math.clamp(progress, 0, 1)
                    table.insert(heightData, &#123;
                        name = plr.Name,
                        progress = progress,
                    &#125;)
                end
            end
            HeightUpdate:FireAllClients(heightData)
            task.wait(0.5)  -- CONFIG.HEIGHT_UPDATE_RATE
        end
    end)
end
            </lua-code-block>

            <HintBox type="tip" title="자동 종료 트릭">
                <code>currentMap.Parent ~= nil</code> — 맵이 Destroy되면 Parent가 nil이 되어 루프가 자동 종료됩니다.
                별도의 종료 신호가 필요 없는 깔끔한 패턴입니다.
