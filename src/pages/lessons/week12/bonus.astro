PurchaseRF.OnServerInvoke = function(player, itemId)
    -- [1] 타입 검증 (해킹 방지)
    if typeof(itemId) ~= "string" then
        return false, "잘못된 요청"
    end

    -- [2] 스팸 방지 (0.5초 쿨다운)
    local lastPurchase = player:GetAttribute("LastPurchaseTime") or 0
    if tick() - lastPurchase &lt; 0.5 then
        return false, "너무 빠릅니다"
    end

    -- [3] 아이템 유효성
    local item = ITEMS[itemId]
    if not item then return false, "존재하지 않는 아이템" end

    -- [4] 코인 잔액 확인
    if coins.Value &lt; item.price then
        return false, "코인 부족"
    end

    -- [5] 코인 차감 → 효과 적용
    coins.Value -= item.price
    item.apply(player.Character)
    return true, item.name .. " 적용!"
end
            </lua-code-block>

