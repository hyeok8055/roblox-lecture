├── stop (Part)        -- 섹션 끝점 (위쪽)
├── center (Part)      -- 중심/피벗 (PrimaryPart)
├── walls (Model)      -- 벽 파트들
├── rotate (NumberValue)  -- 회전값 (0, 90, 180, 270)
├── weight (IntValue)     -- 가중치 (난이도)
├── i (IntValue)          -- 인덱스 번호
├── Model (×3)            -- 장애물 그룹
