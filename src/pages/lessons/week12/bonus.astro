---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';
---

<LessonLayout title="Tower of Hell - 아키텍처 완전 가이드" lessonNumber={12} totalSlides={30}>

    <!-- ==================== 슬라이드 1: 인트로 ==================== -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">보너스 차시</span>
                <h1 class="title-display mb-4">
                    Tower of Hell<br>
                    <span class="text-neon-mint">아키텍처 완전 가이드</span>
                </h1>
                <p class="text-ink-light text-lg max-w-2xl mx-auto mb-8">
                    우리가 만든 게임의 내부 구조를 완전히 해부하고,<br>
                    자유롭게 커스터마이징할 수 있는 실력을 기르자
                </p>
                <div class="flex flex-wrap justify-center gap-3 mb-8">
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">구조 분석</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">시스템 설계</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">커스터마이징</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">고도화</span>
                </div>
                <HintBox type="info" title="이 차시에서 배우는 것">
                    12주차에 만든 Tower of Hell의 <strong>3개 스크립트</strong>가 어떻게 유기적으로 연결되는지,
                    각 시스템의 동작 원리와 확장 방법을 상세히 다룹니다.
                </HintBox>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 2: 프로젝트 파일 구조 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">Part 1 — 전체 구조</span>
            <h2 class="title-section mb-6">프로젝트 파일 구조</h2>
            <p class="text-ink-light mb-6">Rojo 프로젝트의 각 파일이 Studio의 어디에 배치되는지 확인하세요.</p>

            <lua-code-block title="Rojo → Studio 매핑" show-line-numbers>
-- Rojo 파일                          → Studio 위치
-- ──────────────────────────────────────────────────────
-- toh-server/
--   GameManager.server.luau          → ServerScriptService.GameManager
--   ShopHandler.server.luau          → ServerScriptService.ShopHandler
--
-- toh-client/
--   GameUI.client.luau               → StarterPlayer.StarterPlayerScripts.GameUI
--
-- toh-replicatedStorage/
--   TimerUpdate.model.json           → ReplicatedStorage.TOH_Remotes.TimerUpdate
--   HeightUpdate.model.json          → ReplicatedStorage.TOH_Remotes.HeightUpdate
--   RoundInfo.model.json             → ReplicatedStorage.TOH_Remotes.RoundInfo
--   PurchaseItem.model.json          → ReplicatedStorage.TOH_Remotes.PurchaseItem
--
-- build-12주차.project.json          → Workspace (Lobby, ActiveMap, Baseplate)
--                                    → ServerStorage.Maps (빈 폴더)
            </lua-code-block>

            <HintBox type="info" title="핵심 포인트">
                스크립트는 <strong>3개</strong>뿐입니다: GameManager(서버), ShopHandler(서버), GameUI(클라이언트).
                이 3개가 4개의 Remote를 통해 서로 통신합니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 3: Roblox 서비스 구조 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">Part 1 — 전체 구조</span>
            <h2 class="title-section mb-6">Roblox 서비스 구조도</h2>

            <!-- 서비스 구조도 (HTML) -->
            <div class="diagram-box mb-6">
                <div class="diagram-row">
                    <div class="diagram-service">
                        <div class="diagram-label">ServerScriptService</div>
                        <div class="diagram-label-sub">서버 전용</div>
                        <div class="diagram-children">
                            <span class="diagram-node node-server">GameManager<br><small>메인 게임 루프</small></span>
                            <span class="diagram-node node-server">ShopHandler<br><small>상점 시스템</small></span>
                        </div>
                    </div>
                    <div class="diagram-service">
                        <div class="diagram-label">ReplicatedStorage</div>
                        <div class="diagram-label-sub">서버+클라이언트 공유</div>
                        <div class="diagram-children">
                            <span class="diagram-node node-remote">TOH_Remotes</span>
                            <div class="diagram-sub-children">
                                <span class="diagram-chip">TimerUpdate</span>
                                <span class="diagram-chip">HeightUpdate</span>
                                <span class="diagram-chip">RoundInfo</span>
                                <span class="diagram-chip">PurchaseItem</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="diagram-row">
                    <div class="diagram-service">
                        <div class="diagram-label">StarterPlayer</div>
                        <div class="diagram-label-sub">클라이언트 스크립트</div>
                        <div class="diagram-children">
                            <span class="diagram-node node-client">GameUI<br><small>전체 UI + 더블점프</small></span>
                        </div>
                    </div>
                    <div class="diagram-service">
                        <div class="diagram-label">ServerStorage</div>
                        <div class="diagram-label-sub">서버 전용 저장소</div>
                        <div class="diagram-children">
                            <span class="diagram-node" style="background:#3d3654;">Maps 폴더 → RoLive Map</span>
                        </div>
                    </div>
                    <div class="diagram-service">
                        <div class="diagram-label">Workspace</div>
                        <div class="diagram-label-sub">게임 월드</div>
                        <div class="diagram-children" style="flex-direction:row;gap:6px;">
                            <span class="diagram-chip">Lobby</span>
                            <span class="diagram-chip">ActiveMap</span>
                            <span class="diagram-chip">Baseplate</span>
                        </div>
                    </div>
                </div>
            </div>

            <HintBox type="tip" title="색상 구분">
                <strong style="color:#3DFFA2;">초록</strong> = 서버 스크립트,
                <strong style="color:#6BCFFF;">파랑</strong> = 클라이언트 스크립트,
                <strong style="color:#FFD93D;">노랑</strong> = 공유 통신 채널
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 4: 서버-클라이언트 통신 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">Part 1 — 전체 구조</span>
            <h2 class="title-section mb-6">서버-클라이언트 통신 구조</h2>

            <!-- 서버-클라이언트 통신 시퀀스 (HTML) -->
            <div class="diagram-box mb-6">
                <div class="seq-diagram">
                    <div class="seq-participants">
                        <span class="seq-actor node-server">GameManager<br><small>(서버)</small></span>
                        <span class="seq-actor node-server">ShopHandler<br><small>(서버)</small></span>
                        <span class="seq-actor node-client">GameUI<br><small>(클라이언트)</small></span>
                    </div>
                    <div class="seq-messages">
                        <div class="seq-msg">
                            <span class="seq-from">GM</span>
                            <span class="seq-arrow">→</span>
                            <span class="seq-to">GUI</span>
                            <span class="seq-label">TimerUpdate("7:32", 452)</span>
                        </div>
                        <div class="seq-msg">
                            <span class="seq-from">GM</span>
                            <span class="seq-arrow">→</span>
                            <span class="seq-to">GUI</span>
                            <span class="seq-label">HeightUpdate(heightData)</span>
                        </div>
                        <div class="seq-msg">
                            <span class="seq-from">GM</span>
                            <span class="seq-arrow">→</span>
                            <span class="seq-to">GUI</span>
                            <span class="seq-label">RoundInfo("RoundStart", "맵이름")</span>
                        </div>
                        <div class="seq-msg seq-msg-reverse">
                            <span class="seq-from">GUI</span>
                            <span class="seq-arrow">→</span>
                            <span class="seq-to">SH</span>
                            <span class="seq-label">PurchaseItem("speed")</span>
                        </div>
                        <div class="seq-msg seq-msg-reverse">
                            <span class="seq-from">SH</span>
                            <span class="seq-arrow">→</span>
                            <span class="seq-to">GUI</span>
                            <span class="seq-label" style="color:#3DFFA2;">return true, "과속 적용!"</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                <div class="bg-ink-deep rounded-xl p-4">
                    <h4 class="text-neon-mint font-bold mb-2">RemoteEvent (일방통행)</h4>
                    <ul class="text-white text-sm space-y-1">
                        <li>• TimerUpdate — 타이머 텍스트 + 남은 시간</li>
                        <li>• HeightUpdate — 모든 플레이어 높이 데이터</li>
                        <li>• RoundInfo — 라운드 상태 알림</li>
                    </ul>
                </div>
                <div class="bg-ink-deep rounded-xl p-4">
                    <h4 class="text-neon-sky font-bold mb-2">RemoteFunction (양방향)</h4>
                    <ul class="text-white text-sm space-y-1">
                        <li>• PurchaseItem — 클라이언트가 요청, 서버가 처리 후 결과 반환</li>
                        <li>• 반환값: (success: boolean, message: string)</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 5: 게임 루프 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">Part 1 — 전체 구조</span>
            <h2 class="title-section mb-6">게임 루프 플로우</h2>

            <!-- 게임 루프 플로우 (HTML) -->
            <div class="diagram-box mb-6">
                <div class="flow-horizontal">
                    <span class="flow-step" style="background:#FFD93D;color:#1a1625;">Intermission<br><small>8초 대기</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#2d2640;">MapLoad<br><small>맵 Clone</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#2d2640;">Teleport<br><small>스폰 이동</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#3DFFA2;color:#1a1625;">Playing<br><small>480초 타이머</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#2d2640;">RoundEnd<br><small>타이머종료/클리어</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#6BCFFF;color:#1a1625;">Rewards<br><small>보상 지급</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#2d2640;">Lobby<br><small>로비 복귀</small></span>
                    <span class="flow-arrow">↩</span>
                </div>
            </div>

            <lua-code-block title="GameManager — gameLoop() 핵심 흐름">
while true do
    -- [1] 인터미션 (8초 대기)
    -- [2] 맵 로드 (ServerStorage → ActiveMap Clone)
    -- [3] 스폰/클리어 파트 자동 탐색
    -- [4] 모든 플레이어 텔레포트
    -- [5] WinPart Touched 이벤트 연결
    -- [6] 높이 추적 스레드 시작
    -- [7] 타이머 시작 (480초)
    -- [8] 라운드 종료 → 보상 → 로비 → 맵 제거
end
            </lua-code-block>
        </div>
    </section>

    <!-- ==================== 슬라이드 6: CONFIG ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 시스템</span>
            <h2 class="title-section mb-6">CONFIG 설정값 일람</h2>
            <p class="text-ink-light mb-6">이 테이블 하나만 수정하면 게임 밸런스를 조절할 수 있습니다.</p>

            <lua-code-block title="GameManager.server.luau" show-line-numbers>
local CONFIG = &#123;
    ROUND_TIME = 480,         -- 라운드 시간 (초) — 실제 TOH는 8분
    EXTRA_TIME = 120,         -- "추가 시간" 아이템 효과 (2분)
    INTERMISSION = 8,         -- 라운드 사이 대기 시간
    HEIGHT_UPDATE_RATE = 0.5, -- 높이 업데이트 주기 (초)
    WIN_COINS = 50,           -- 타워 클리어 보상 코인
    PARTICIPATE_COINS = 10,   -- 라운드 참여 보상 코인
    HEIGHT_BONUS_COINS = 5,   -- 50% 이상 올라간 보상
    LEVEL_XP_BASE = 100,      -- 레벨업 기본 XP (레벨 × 100)
&#125;
            </lua-code-block>

            <HintBox type="tip" title="밸런스 팁">
                WIN_COINS을 높이면 클리어 동기가 강해지고, PARTICIPATE_COINS를 높이면 참여만으로도 보상감이 있습니다.
                실제 TOH는 섹션당 코인을 줍니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 7: 리더보드 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 시스템</span>
            <h2 class="title-section mb-6">리더보드 시스템</h2>

            <lua-code-block title="setupLeaderstats()" show-line-numbers>
local function setupLeaderstats(player)
    local leaderstats = Instance.new("Folder")
    leaderstats.Name = "leaderstats"  -- 이 이름이어야 자동 리더보드
    leaderstats.Parent = player

    local wins = Instance.new("IntValue")
    wins.Name = "Wins"
    wins.Value = 0
    wins.Parent = leaderstats

    local coins = Instance.new("IntValue")
    coins.Name = "Coins"
    coins.Value = 0
    coins.Parent = leaderstats

    local level = Instance.new("IntValue")
    level.Name = "Level"
    level.Value = 0
    level.Parent = leaderstats
end

Players.PlayerAdded:Connect(setupLeaderstats)
            </lua-code-block>

            <HintBox type="info" title="자동 리더보드">
                Roblox는 <code>leaderstats</code>라는 이름의 Folder를 감지하여 우상단에 자동으로 리더보드를 표시합니다.
                안의 IntValue/StringValue 이름이 컬럼명이 됩니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 8: 코인 & XP ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 시스템</span>
            <h2 class="title-section mb-6">코인 &amp; XP 시스템</h2>

            <lua-code-block title="레벨업 공식" show-line-numbers>
local function giveXP(player, amount)
    playerXP[player.UserId] += amount

    -- 레벨업: 필요 XP = (현재레벨 + 1) × 100
    local requiredXP = (level.Value + 1) * CONFIG.LEVEL_XP_BASE
    while playerXP[player.UserId] >= requiredXP do
        playerXP[player.UserId] -= requiredXP
        level.Value += 1
        requiredXP = (level.Value + 1) * CONFIG.LEVEL_XP_BASE
    end
end

-- 코인 = XP (실제 TOH 방식)
local function giveCoins(player, amount)
    coins.Value += amount
    giveXP(player, amount)  -- 코인만큼 XP도 부여
end
            </lua-code-block>

            <div class="bg-ink-deep rounded-xl p-4 mt-4">
                <h4 class="text-neon-gold font-bold mb-2">레벨업 필요 XP</h4>
                <div class="grid grid-cols-5 gap-2 text-white text-sm text-center">
                    <div>Lv 0→1<br><strong>100</strong></div>
                    <div>Lv 1→2<br><strong>200</strong></div>
                    <div>Lv 2→3<br><strong>300</strong></div>
                    <div>Lv 9→10<br><strong>1,000</strong></div>
                    <div>Lv 79→80<br><strong>8,000</strong></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 9: 맵 로테이션 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 시스템</span>
            <h2 class="title-section mb-6">맵 로테이션 시스템</h2>

            <!-- 맵 로테이션 플로우 (HTML) -->
            <div class="diagram-box mb-6">
                <div class="flow-horizontal">
                    <span class="flow-step" style="background:#2d2640;">ServerStorage<br><small>Maps 폴더</small></span>
                    <span class="flow-arrow-label">GetChildren</span>
                    <span class="flow-step" style="background:#2d2640;">맵 목록</span>
                    <span class="flow-arrow-label">math.random</span>
                    <span class="flow-step" style="background:#FFD93D;color:#1a1625;">랜덤 선택<br><small>연속 방지</small></span>
                    <span class="flow-arrow-label">Clone</span>
                    <span class="flow-step" style="background:#3DFFA2;color:#1a1625;">Workspace<br><small>ActiveMap</small></span>
                    <span class="flow-arrow-label">라운드 종료</span>
                    <span class="flow-step" style="background:#FF6B6B;color:#1a1625;">Destroy</span>
                </div>
            </div>

            <lua-code-block title="pickRandomMap()" show-line-numbers>
local function pickRandomMap()
    local maps = mapsFolder:GetChildren()
    if #maps == 0 then
        warn("Maps 폴더가 비어있습니다!")
        return nil
    end
    if #maps &lt;= 1 then return maps[1] end

    local chosen
    repeat
        chosen = maps[math.random(1, #maps)]
    until chosen.Name ~= lastMapName  -- 같은 맵 연속 방지

    lastMapName = chosen.Name
    return chosen
end
            </lua-code-block>
        </div>
    </section>

    <!-- ==================== 슬라이드 10: 맵 자동 탐색 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 시스템</span>
            <h2 class="title-section mb-6">맵 자동 탐색 시스템</h2>
            <p class="text-ink-light mb-4">어떤 맵이든 스폰/클리어 파트를 자동으로 찾아줍니다.</p>

            <lua-code-block title="탐색 이름 목록">
local SPAWN_NAMES = &#123;"SpawnPoint", "start", "Spawn", "SpawnLocation"&#125;
local WIN_NAMES   = &#123;"FinishGlow", "WinPart", "Win", "End"&#125;
            </lua-code-block>

            <div class="bg-ink-deep rounded-xl p-4 mt-4 mb-4">
                <h4 class="text-neon-mint font-bold mb-2">탐색 우선순위</h4>
                <div class="text-white text-sm space-y-2">
                    <p><strong>스폰 탐색:</strong> 이름 매칭 → Model이면 center Part 우선 → 재귀 탐색</p>
                    <p><strong>클리어 탐색:</strong> 이름 매칭 → Model이면 CanCollide=true Part 우선 → 재귀 탐색</p>
                </div>
            </div>

            <HintBox type="warning" title="중요">
                클리어 파트는 반드시 <code>CanCollide = true</code>여야 <code>Touched</code> 이벤트가 발동합니다.
                RoLive Map의 FinishGlow가 바로 이 역할을 합니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 11: 타이머 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 시스템</span>
            <h2 class="title-section mb-6">타이머 시스템</h2>

            <lua-code-block title="startTimer()" show-line-numbers>
local function startTimer()
    currentRemainingTime = CONFIG.ROUND_TIME  -- 480초

    while currentRemainingTime > 0 do
        -- "추가 시간" 아이템 체크
        if workspace:GetAttribute("ExtraTimeRequested") then
            workspace:SetAttribute("ExtraTimeRequested", nil)
            currentRemainingTime += CONFIG.EXTRA_TIME
            RoundInfo:FireAllClients("Announcement",
                "추가 시간 +" .. CONFIG.EXTRA_TIME .. "초!")
        end

        local minutes = math.floor(currentRemainingTime / 60)
        local seconds = currentRemainingTime % 60
        local timeText = string.format("%d:%02d", minutes, seconds)

        TimerUpdate:FireAllClients(timeText, currentRemainingTime)
        task.wait(1)
        currentRemainingTime -= 1
    end
end
            </lua-code-block>

            <HintBox type="info" title="추가 시간 패턴">
                ShopHandler가 <code>workspace:SetAttribute("ExtraTimeRequested", true)</code>를 설정하면,
                타이머 루프가 이를 감지하여 시간을 추가합니다. 스크립트 간 통신의 간단한 패턴입니다.
