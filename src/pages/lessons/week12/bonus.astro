local function onPlayerWin(player)
    -- 중복 클리어 방지 (같은 라운드에서 1번만)
    if player:GetAttribute("HasWon") then return end
    player:SetAttribute("HasWon", true)

    wins.Value += 1
    giveCoins(player, CONFIG.WIN_COINS)  -- 50코인 + 50XP
    RoundInfo:FireAllClients("PlayerWon", player.Name, wins.Value)
end
