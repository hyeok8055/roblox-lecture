---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';
---

<LessonLayout title="Tower of Hell - 상점 · 음악 · 출시" lessonNumber={12} totalSlides={18}>

    <!-- ==================== 슬라이드 1: 인트로 ==================== -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">12주차 B</span>
                <h1 class="title-display mb-4">
                    상점 · 음악 · 출시<br>
                    <span class="text-neon-mint">게임 완성하기</span>
                </h1>
                <p class="text-ink-light text-lg max-w-2xl mx-auto mb-8">
                    지난 시간에 만든 게임 시스템 위에 <strong>상점 UI</strong>, <strong>음악 토글</strong>을 추가하고,<br>
                    최종적으로 게임을 <strong>출시</strong>하는 방법까지 알아봅니다.
                </p>
                <div class="flex flex-wrap justify-center gap-3 mb-8">
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">Shop System</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">Music Toggle</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">Game Publishing</span>
                </div>
                <HintBox type="info" title="이번 수업 목표">
                    변형 모드 상점 (무적, 과속, 무중력 등), 배경음악 재생/정지 토글,<br>
                    그리고 게임 출시를 위한 썸네일 · 아이콘 · Public 설정을 다룹니다.
                </HintBox>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 2: 상점 시스템 개요 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 5</span>
            <h2 class="title-section mb-6">상점 시스템 설계</h2>
            <p class="text-ink-light mb-8">
                Tower of Hell의 "변형 모드" 상점입니다. 코인으로 효과를 구매하면 일정 시간 동안 적용됩니다.
            </p>

            <div class="shop-preview">
                <div class="shop-header-bar">
                    <div class="shop-tab active">상점</div>
                    <div class="shop-tab">효과</div>
                    <div class="shop-tab">설정</div>
                </div>
                <div class="shop-items-preview">
                    <div class="shop-item-card">
                        <div class="item-icon">&#x1f6e1;</div>
                        <div class="item-name">무적 상태</div>
                        <div class="item-price">500 &#x1fa99;</div>
                    </div>
                    <div class="shop-item-card">
                        <div class="item-icon">&#x27a1;</div>
                        <div class="item-name">과속</div>
                        <div class="item-price">100 &#x1fa99;</div>
                    </div>
                    <div class="shop-item-card">
                        <div class="item-icon">&#x2b06;</div>
                        <div class="item-name">무중력</div>
                        <div class="item-price">130 &#x1fa99;</div>
                    </div>
                </div>
            </div>

            <div class="detail-grid mt-6">
                <div class="detail-item">
                    <div class="detail-label">서버-클라 통신</div>
                    <div class="detail-desc"><strong>RemoteFunction</strong>: 클라이언트가 "이 아이템 사줘" 요청 → 서버가 코인 확인 → 결과 반환. 요청+응답이 한 쌍이므로 RemoteFunction을 씁니다.</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">효과 지속 시간</div>
                    <div class="detail-desc"><strong>task.delay</strong>로 N초 후 효과를 해제합니다. 중복 구매 시 기존 타이머를 취소하고 새로 시작합니다.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 3: 상점 아이템 정의 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 5 코드</span>
            <h2 class="title-section mb-6">아이템 테이블 정의 (서버)</h2>

            <div class="system-card">
                <lua-code-block title="GameManager.lua - 상점 아이템 정의" show-line-numbers>
-- =============================================
-- 상점 아이템 목록
-- =============================================
-- 테이블(딕셔너리) = &#123; 키 = 값 &#125; 형태로 아이템 정보 저장
local ITEMS = &#123;
    invincible = &#123;
        name = "무적 상태",
        price = 500,       -- 실제 TOH와 동일 가격!
        duration = 30,     -- 30초간 유지
        apply = function(character)
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                -- ForceField = 로블록스 기본 무적 효과
                local ff = Instance.new("ForceField")
                ff.Name = "ShopForceField"
                ff.Parent = character
            end
        end,
        remove = function(character)
            local ff = character:FindFirstChild("ShopForceField")
            if ff then ff:Destroy() end
        end
    &#125;,

    speed = &#123;
        name = "과속",
        price = 100,       -- 실제 TOH "High Speed" = 100코인
        duration = 60,     -- 60초간 유지 (실제 TOH는 라운드 끝까지)
        apply = function(character)
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = 32  -- 기본 16의 2배
            end
        end,
        remove = function(character)
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = 16  -- 원래대로
            end
        end
    &#125;,

    gravity = &#123;
        name = "무중력",
        price = 130,       -- 실제 TOH "Low Gravity" = 130코인
        duration = 45,     -- 45초간 유지 (실제 TOH는 라운드 끝까지)
        apply = function(character)
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.UseJumpPower = true
                humanoid.JumpPower = 100  -- 기본 50의 2배
            end
        end,
        remove = function(character)
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.JumpPower = 50  -- 원래대로
            end
        end
    &#125;,
&#125;
                </lua-code-block>
            </div>

            <HintBox type="tip" title="함수도 테이블에 넣을 수 있다!">
                Lua에서는 함수도 값입니다. <code>apply = function(character) ... end</code>처럼 테이블 안에 함수를 넣으면,<br>
                <code>ITEMS.speed.apply(character)</code>로 호출할 수 있습니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 4: 상점 구매 처리 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 5 계속</span>
            <h2 class="title-section mb-6">구매 요청 처리 (서버)</h2>

            <div class="system-card">
                <lua-code-block title="GameManager.lua - 구매 처리" show-line-numbers>
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local PurchaseRF = ReplicatedStorage:WaitForChild("PurchaseItem")

-- 플레이어별 활성 효과 저장
local activeEffects = &#123;&#125;

-- =============================================
-- 구매 요청 처리: 클라이언트 → 서버
-- =============================================
PurchaseRF.OnServerInvoke = function(player, itemId)
    -- 1. 아이템 존재 확인
    local item = ITEMS[itemId]
    if not item then
        return false, "존재하지 않는 아이템"
    end

    -- 2. 코인 확인
    local leaderstats = player:FindFirstChild("leaderstats")
    local coins = leaderstats and leaderstats:FindFirstChild("Coins")
    if not coins or coins.Value &lt; item.price then
        return false, "코인이 부족합니다"
    end

    -- 3. 코인 차감
    coins.Value -= item.price

    -- 4. 기존 같은 효과가 있으면 제거
    if activeEffects[player.UserId] and activeEffects[player.UserId][itemId] then
        local old = activeEffects[player.UserId][itemId]
        task.cancel(old.thread)
        item.remove(player.Character)
    end

    -- 5. 효과 적용
    local character = player.Character
    if character then
        item.apply(character)
    end

    -- 6. 일정 시간 후 자동 해제
    local thread = task.delay(item.duration, function()
        if player.Character then
            item.remove(player.Character)
        end
        if activeEffects[player.UserId] then
            activeEffects[player.UserId][itemId] = nil
        end
    end)

    -- 효과 정보 저장
    if not activeEffects[player.UserId] then
        activeEffects[player.UserId] = &#123;&#125;
    end
    activeEffects[player.UserId][itemId] = &#123; thread = thread &#125;

    return true, item.name .. " 적용! (" .. item.duration .. "초)"
end
                </lua-code-block>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 5: 상점 구매 흐름 해설 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">코드 해설</span>
            <h2 class="title-section mb-6">구매 흐름 단계별 분석</h2>

            <div class="purchase-flow">
                <div class="pf-step">
                    <div class="pf-side client-side">클라이언트</div>
                    <div class="pf-content">
                        <strong>구매 버튼 클릭</strong>
                        <code>PurchaseRF:InvokeServer("speed")</code>
                    </div>
                </div>
                <div class="pf-arrow">&darr;</div>
                <div class="pf-step">
                    <div class="pf-side server-side">서버</div>
                    <div class="pf-content">
                        <strong>아이템 확인</strong>
                        <span>ITEMS["speed"]가 존재하는지 검증</span>
                    </div>
                </div>
                <div class="pf-arrow">&darr;</div>
                <div class="pf-step">
                    <div class="pf-side server-side">서버</div>
                    <div class="pf-content">
                        <strong>코인 확인 &amp; 차감</strong>
                        <span>잔액 &ge; 가격이면 차감, 아니면 실패 반환</span>
                    </div>
                </div>
                <div class="pf-arrow">&darr;</div>
                <div class="pf-step">
                    <div class="pf-side server-side">서버</div>
                    <div class="pf-content">
                        <strong>효과 적용 + 타이머 설정</strong>
                        <span>WalkSpeed 변경, task.delay로 자동 해제 예약</span>
                    </div>
                </div>
                <div class="pf-arrow">&darr;</div>
                <div class="pf-step">
                    <div class="pf-side client-side">클라이언트</div>
                    <div class="pf-content">
                        <strong>결과 수신</strong>
                        <code>local ok, msg = PurchaseRF:InvokeServer("speed")</code>
                    </div>
                </div>
            </div>

            <HintBox type="warning" title="왜 서버에서 처리하나요?">
                클라이언트에서 직접 코인을 차감하면 <strong>해커가 코인을 무한으로 늘릴 수 있습니다</strong>.<br>
                반드시 서버에서 코인 확인 → 차감 → 효과 적용을 해야 안전합니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 6: 상점 UI (클라이언트) ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">클라이언트</span>
            <h2 class="title-section mb-6">상점 UI 코드</h2>
            <p class="text-ink-light mb-8">
                좌하단 "상점" 버튼을 누르면 아이템 목록이 펼쳐지는 UI입니다.
            </p>

            <div class="system-card">
                <lua-code-block title="GameUI (LocalScript) - 상점 UI 부분" show-line-numbers>
local PurchaseRF = ReplicatedStorage:WaitForChild("PurchaseItem")

-- =============================================
-- 상점 토글 버튼 (좌하단)
-- =============================================
local shopButton = Instance.new("TextButton")
shopButton.Name = "ShopToggle"
shopButton.Size = UDim2.new(0, 80, 0, 40)
shopButton.Position = UDim2.new(0, 20, 1, -60)  -- 좌하단
shopButton.BackgroundColor3 = Color3.fromRGB(255, 193, 7)
shopButton.Text = "상점"
shopButton.TextSize = 18
shopButton.Font = Enum.Font.GothamBold
shopButton.TextColor3 = Color3.new(0, 0, 0)
shopButton.Parent = screenGui

-- 모서리 둥글게
Instance.new("UICorner", shopButton).CornerRadius = UDim.new(0, 8)

-- =============================================
-- 상점 패널 (토글로 열고 닫기)
-- =============================================
local shopPanel = Instance.new("Frame")
shopPanel.Name = "ShopPanel"
shopPanel.Size = UDim2.new(0, 300, 0, 400)
shopPanel.Position = UDim2.new(0, 20, 1, -470)
shopPanel.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
shopPanel.BackgroundTransparency = 0.1
shopPanel.Visible = false  -- 처음엔 숨김
shopPanel.Parent = screenGui
Instance.new("UICorner", shopPanel).CornerRadius = UDim.new(0, 12)

local isShopOpen = false
shopButton.MouseButton1Click:Connect(function()
    isShopOpen = not isShopOpen
    shopPanel.Visible = isShopOpen
end)
                </lua-code-block>
            </div>

            <HintBox type="info" title="Instance.new 단축 문법">
                <code>Instance.new("UICorner", shopButton)</code> — 두 번째 인자로 Parent를 바로 지정할 수 있습니다.<br>
                별도로 <code>.Parent = shopButton</code>을 쓰지 않아도 됩니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 7: 상점 아이템 카드 생성 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">클라이언트 계속</span>
            <h2 class="title-section mb-6">아이템 카드 동적 생성</h2>

            <div class="system-card">
                <lua-code-block title="GameUI (LocalScript) - 아이템 카드 부분" show-line-numbers>
-- =============================================
-- 아이템 목록 (클라이언트용 - 가격/이름만)
-- =============================================
local shopItems = &#123;
    &#123; id = "invincible", name = "무적 상태",  price = 500, icon = "🛡️" &#125;,
    &#123; id = "speed",      name = "과속",        price = 100, icon = "➡️" &#125;,
    &#123; id = "gravity",    name = "무중력",      price = 130, icon = "⬆️" &#125;,
&#125;

-- =============================================
-- UIListLayout: 카드를 세로로 자동 정렬
-- =============================================
local listLayout = Instance.new("UIListLayout")
listLayout.Padding = UDim.new(0, 8)
listLayout.SortOrder = Enum.SortOrder.LayoutOrder
listLayout.Parent = shopPanel

-- =============================================
-- 각 아이템별 구매 카드 생성
-- =============================================
for i, item in shopItems do
    local card = Instance.new("TextButton")
    card.Size = UDim2.new(1, -16, 0, 60)
    card.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    card.Text = item.icon .. " " .. item.name .. " - " .. item.price .. " 코인"
    card.TextColor3 = Color3.new(1, 1, 1)
    card.TextSize = 14
    card.Font = Enum.Font.GothamBold
    card.LayoutOrder = i
    card.Parent = shopPanel
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)

    -- 클릭 시 서버에 구매 요청
    card.MouseButton1Click:Connect(function()
        card.Text = "구매 중..."
        local success, message = PurchaseRF:InvokeServer(item.id)

        if success then
            card.Text = "✅ " .. message
        else
            card.Text = "❌ " .. message
        end

        -- 2초 후 원래 텍스트로 복원
        task.delay(2, function()
            card.Text = item.icon .. " " .. item.name .. " - " .. item.price .. " 코인"
        end)
    end)
end
                </lua-code-block>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 8: 코인 획득 방법 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">보충 설명</span>
            <h2 class="title-section mb-6">코인은 어디서 오나?</h2>
            <p class="text-ink-light mb-8">
                상점이 있으려면 재화가 필요합니다. Tower of Hell에서 코인을 얻는 방법을 설계합니다.
            </p>

            <div class="coin-sources">
                <div class="coin-source">
                    <div class="cs-icon">&#x1f3c6;</div>
                    <div class="cs-content">
                        <h4>타워 클리어 보상</h4>
                        <p>꼭대기 도달 시 <strong>+50 코인</strong></p>
                        <code>coins.Value += 50</code>
                    </div>
                </div>
                <div class="coin-source">
                    <div class="cs-icon">&#x23f1;</div>
                    <div class="cs-content">
                        <h4>라운드 참여 보상</h4>
                        <p>라운드 끝까지 생존 시 <strong>+10 코인</strong></p>
                        <code>coins.Value += 10</code>
                    </div>
                </div>
                <div class="coin-source">
                    <div class="cs-icon">&#x1f4b0;</div>
                    <div class="cs-content">
                        <h4>높이 보너스</h4>
                        <p>진행도 50% 이상 시 <strong>+5 코인</strong></p>
                        <code>if progress >= 0.5 then coins.Value += 5 end</code>
                    </div>
                </div>
            </div>

            <HintBox type="tip" title="Leaderstats에 Coins 추가">
                12주차 A에서 만든 <code>setupLeaderstats</code> 함수에 Coins IntValue를 추가하면 됩니다.<br>
                Wins, Level과 같은 방식으로 <code>Instance.new("IntValue")</code>를 하나 더 만드세요.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 9: 음악 시스템 개요 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">시스템 6</span>
            <h2 class="title-section mb-6">배경음악 시스템</h2>
            <p class="text-ink-light mb-8">
                우측 하단의 음악 재생/정지 버튼. 클라이언트 전용이므로 LocalScript만으로 구현합니다.
            </p>

            <div class="music-demo">
                <div class="music-btn playing">
                    <span class="music-icon">&#x266b;</span>
                    <span class="music-label">Interstellar Sky</span>
                    <span class="music-status">&#x25b6; 재생 중</span>
                </div>
            </div>

            <div class="detail-grid mt-6">
                <div class="detail-item">
                    <div class="detail-label">Sound 객체</div>
                    <div class="detail-desc">SoundService 또는 Workspace에 Sound를 넣고, <code>SoundId</code>에 Roblox 오디오 ID를 설정합니다.</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Looped = true</div>
                    <div class="detail-desc">BGM이므로 반복 재생이 필요합니다. Sound의 <code>Looped</code> 속성을 true로 설정합니다.</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">클라이언트 전용</div>
                    <div class="detail-desc">음악 재생/정지는 개인 설정이므로 서버에 보낼 필요 없이 LocalScript에서 처리합니다.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 10: 음악 코드 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">클라이언트</span>
            <h2 class="title-section mb-6">음악 토글 코드</h2>

            <div class="system-card">
                <lua-code-block title="GameUI (LocalScript) - 음악 부분" show-line-numbers>
-- =============================================
-- 배경음악 설정
-- =============================================
local SoundService = game:GetService("SoundService")

local bgm = Instance.new("Sound")
bgm.Name = "BGM"
bgm.SoundId = "rbxassetid://1234567890"  -- 원하는 오디오 ID
bgm.Volume = 0.3
bgm.Looped = true
bgm.Parent = SoundService
bgm:Play()

local isPlaying = true

-- =============================================
-- 음악 토글 버튼 (우하단)
-- =============================================
local musicButton = Instance.new("TextButton")
musicButton.Name = "MusicToggle"
musicButton.Size = UDim2.new(0, 40, 0, 40)
musicButton.Position = UDim2.new(1, -60, 1, -60)  -- 우하단
musicButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
musicButton.BackgroundTransparency = 0.3
musicButton.Text = "♫"
musicButton.TextSize = 22
musicButton.TextColor3 = Color3.new(1, 1, 1)
musicButton.Parent = screenGui
Instance.new("UICorner", musicButton).CornerRadius = UDim.new(0, 20)

-- =============================================
-- 클릭하면 재생/정지 토글
-- =============================================
musicButton.MouseButton1Click:Connect(function()
    isPlaying = not isPlaying

    if isPlaying then
        bgm:Resume()
        musicButton.Text = "♫"
        musicButton.BackgroundTransparency = 0.3
    else
        bgm:Pause()
        musicButton.Text = "🔇"
        musicButton.BackgroundTransparency = 0.6
    end
end)
                </lua-code-block>
            </div>

