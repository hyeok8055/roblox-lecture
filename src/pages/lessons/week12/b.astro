            <h2 class="title-section mb-6">여러 곡 순환 재생</h2>
            <p class="text-ink-light mb-8">
                한 곡만 계속 반복하면 지루합니다. 여러 곡을 자동으로 순환 재생하는 방법입니다.
            </p>

            <div class="system-card">
                <lua-code-block title="GameUI (LocalScript) - 플레이리스트" show-line-numbers>
-- =============================================
-- 플레이리스트: 여러 곡 순환 재생
-- =============================================
local playlist = &#123;
    &#123; id = "rbxassetid://1111111111", name = "Interstellar Sky" &#125;,
    &#123; id = "rbxassetid://2222222222", name = "Neon Lights" &#125;,
    &#123; id = "rbxassetid://3333333333", name = "Tower Rush" &#125;,
&#125;

local currentIndex = 1

local function playNext()
    local track = playlist[currentIndex]
    bgm.SoundId = track.id
    bgm:Play()

    -- 곡 이름 표시 (있다면)
    -- musicLabel.Text = track.name

    -- 곡이 끝나면 다음 곡으로
    bgm.Ended:Wait()

    -- 다음 인덱스 (마지막이면 처음으로)
    currentIndex = currentIndex % #playlist + 1
end

-- 별도 스레드에서 순환 재생
task.spawn(function()
    while true do
        if isPlaying then
            playNext()
        else
            task.wait(0.5)  -- 정지 상태면 대기
        end
    end
end)
                </lua-code-block>
