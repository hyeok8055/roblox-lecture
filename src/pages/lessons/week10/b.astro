                blanks={checkpointBlanks}
                template={checkpointTemplate}
                full-code={checkpointFullCode}
            ></roblox-quiz-example>
        </div>
    </section>

    <!-- 슬라이드 13: 오비 설계 팁 -->
    <section class="slide">
        <div class="max-w-4xl mx-auto px-6 py-12">
            <div class="animate-in">
                <span class="badge badge-lesson mb-4">🗺️ 맵 설계</span>
                <h2 class="title-section mb-6">오비 맵 설계 황금 법칙</h2>
            </div>

            <div class="flex flex-col gap-5 animate-in">
                <div class="grid md:grid-cols-2 gap-4">
                    <div class="lesson-card">
                        <h4 class="font-bold mb-3">📐 난이도 곡선 설계</h4>
                        <div class="space-y-2 text-sm">
                            <div class="flex items-center gap-3 p-2 bg-green-50 rounded-lg">
                                <span class="text-green-600 font-bold">1~2</span>
                                <span class="text-ink-light">넓은 플랫폼, 짧은 거리 (튜토리얼)</span>
                            </div>
                            <div class="flex items-center gap-3 p-2 bg-blue-50 rounded-lg">
                                <span class="text-blue-600 font-bold">3~4</span>
                                <span class="text-ink-light">느린 이동 플랫폼 (보통)</span>
                            </div>
                            <div class="flex items-center gap-3 p-2 bg-yellow-50 rounded-lg">
                                <span class="text-yellow-600 font-bold">5~6</span>
                                <span class="text-ink-light">회전 장애물, 컨베이어 (어려움)</span>
                            </div>
                            <div class="flex items-center gap-3 p-2 bg-red-50 rounded-lg">
                                <span class="text-red-600 font-bold">7~8</span>
                                <span class="text-ink-light">사라지는 함정 + 복합 기믹 (최고 난이도)</span>
                            </div>
                        </div>
                    </div>

                    <div class="lesson-card">
                        <h4 class="font-bold mb-3">🎨 섹션 테마 아이디어</h4>
                        <div class="space-y-2 text-sm">
                            <div class="flex items-center gap-2">
                                <span>🌿</span>
                                <span><strong>초록 구간</strong>: 잔디밭, 기초 점프</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span>⚙️</span>
                                <span><strong>공장 구간</strong>: 컨베이어 벨트, 회전 기어</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span>☁️</span>
                                <span><strong>하늘 구간</strong>: 이동 플랫폼, 좁은 다리</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span>🌋</span>
                                <span><strong>용암 구간</strong>: 사라지는 발판, KillBrick 바닥</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span>🏆</span>
                                <span><strong>최종 구간</strong>: 모든 기믹 복합</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="lesson-card">
                    <h4 class="font-bold mb-3">✅ 좋은 오비 설계 체크리스트</h4>
                    <div class="grid md:grid-cols-2 gap-3 text-sm">
                        <div class="space-y-2">
                            <div class="flex items-center gap-2">
                                <span class="text-neon-mint">✓</span>
                                <span>체크포인트는 어려운 구간 <strong>바로 앞</strong>에 배치</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-neon-mint">✓</span>
                                <span>착지 최소 크기: <strong>4×4 스터드</strong> 이상</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-neon-mint">✓</span>
                                <span>점프 거리: <strong>6~10 스터드</strong> 이내</span>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <div class="flex items-center gap-2">
                                <span class="text-neon-mint">✓</span>
                                <span>이동 방향 힌트: <strong>화살표 파트</strong>로 표시</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-neon-mint">✓</span>
                                <span>색상으로 위험도 구분 (초록→노랑→빨강)</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-neon-mint">✓</span>
                                <span>죽음 바닥(KillBrick) 아래에 배치해서 낙사 방지</span>
                            </div>
                        </div>
                    </div>
                </div>

                <HintBox type="tip" title="Tower of Hell에서 배우기">
                    Tower of Hell은 체크포인트 없이 358개 섹션으로 구성된 유명 오비게임이에요.<br>
                    비결은 <strong>각 섹션이 짧고</strong>, <strong>8분 라운드제</strong>로 긴장감을 유지해요.<br>
                    우리 게임에는 체크포인트를 넣어서 학습 친화적으로 만들어봐요!
                </HintBox>
            </div>
        </div>
    </section>

    <!-- 슬라이드 14: 확인 퀴즈 + 마무리 -->
    <section class="slide">
        <div class="max-w-3xl mx-auto px-6 py-12">
            <div class="animate-in">
                <span class="badge badge-quiz mb-4">확인 퀴즈</span>
                <h2 class="title-section mb-8">오늘 배운 내용 확인!</h2>
            </div>

            <div class="space-y-6">
                <div class="animate-in">
                    <quiz-question
                        question="파트를 부드럽게 왕복 이동시키는 가장 좋은 방법은?"
                        correct="A"
                        options={quiz1Options}
                        correct-explanation="정답! TweenService:Create()로 트윈을 만들고, TweenInfo에서 RepeatCount=-1, Reverses=true로 설정하면 왕복 무한반복 이동 플랫폼이 완성돼요!"
                        wrong-explanation="TweenService:Create()가 정답이에요! RunService.Heartbeat로도 가능하지만 TweenService가 훨씬 간편하고 부드러워요."
                    ></quiz-question>
                </div>

                <div class="animate-in">
                    <quiz-question
                        question="TweenInfo에서 RepeatCount를 몇으로 설정하면 무한반복될까?"
                        correct="A"
                        options={quiz2Options}
                        correct-explanation="정답! RepeatCount = -1이 무한반복이에요. 0은 반복없음, 양수는 그 횟수만큼 반복해요."
                        wrong-explanation="-1이 정답이에요! TweenInfo.new(2, ..., -1, true, 0)처럼 4번째 파라미터를 -1로 설정하면 무한반복돼요."
                    ></quiz-question>
                </div>

                <div class="animate-in">
                    <quiz-question
                        question="앵커된 파트 위의 물체를 밀어내는 속성은?"
                        correct="A"
                        options={quiz3Options}
                        correct-explanation="정답! AssemblyLinearVelocity를 앵커된 파트에 설정하면 그 위의 캐릭터를 해당 방향으로 밀어요. 컨베이어 벨트의 핵심이에요!"
                        wrong-explanation="AssemblyLinearVelocity가 정답이에요! 앵커된 파트에 이 속성을 설정하면 컨베이어 벨트 효과를 낼 수 있어요."
                    ></quiz-question>
                </div>

                <div class="animate-in">
                    <quiz-question
                        question="사라지는 함정에서 서서히 투명해지게 하려면 Transparency를 어떻게 설정할까? (for i = 1, 10 루프 안에서)"
                        correct="A"
                        options={quiz4Options}
                        correct-explanation="정답! i / 10을 사용하면 i=1→0.1, i=5→0.5, i=10→1.0으로 서서히 투명해져요. 10번 반복에 걸쳐 완전히 사라지는 효과예요!"
                        wrong-explanation="i / 10이 정답이에요! for i = 1, 10 루프에서 platform.Transparency = i / 10으로 설정하면 0.1씩 증가해 1.0(완전 투명)이 돼요."
                    ></quiz-question>
                </div>
            </div>

            <div class="animate-in mt-8 text-center">
                <div class="inline-block bg-gradient-to-r from-green-100/50 to-blue-100/50 rounded-2xl p-6">
                    <div class="text-2xl mb-2">🎉</div>
                    <h3 class="font-bold text-lg mb-2">10주차 완료!</h3>
                    <p class="text-ink-light text-sm">
                        사운드 시스템과 고급 오비 기믹까지 완벽하게 배웠어요!<br>
                        다음 시간에는 파티클 & 이펙트로 게임을 화려하게 꾸며요 ✨
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Lit 컴포넌트 로드 -->
    <script>
        import('../../../components/lit/index').catch(console.error);
    </script>
</LessonLayout>
