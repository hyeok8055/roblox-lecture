---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';

// 확인 퀴즈 옵션
const quiz1Options = JSON.stringify(["MouseClick", "Triggered", "Touched", "Activated"]);
const quiz2Options = JSON.stringify(["Workspace.Gravity", "Humanoid.GravityScale", "workspace.FallenPartsDestroyHeight", "Humanoid.JumpPower"]);
const quiz3Options = JSON.stringify(["JumpPower", "WalkSpeed", "Health", "MaxHealth"]);
const quiz4Options = JSON.stringify(["math.random(1, #COLORS)", "#COLORS", "math.random()", "1"]);

// =========================================
// 드롭다운 퀴즈 데이터 (6개)
// =========================================

// 퀴즈 1: ClickDetector 순차 계단 소환
const stairsBlanks = JSON.stringify([
    { id: "b1", correct: "\"ClickDetector\"", options: ["\"ClickDetector\"", "\"Button\"", "\"Trigger\"", "\"ProximityPrompt\""] },
    { id: "b2", correct: "MouseClick", options: ["MouseClick", "Triggered", "Touched", "Activated"] },
    { id: "b3", correct: "0", options: ["0", "1", "0.5", "nil"] },
    { id: "b4", correct: "true", options: ["true", "false", "nil", "0"] }
]);
const stairsTemplate = `-- ========================================
-- 🪜 버튼 누르면 계단이 하나씩 나타남!
-- ========================================
-- 📦 준비:
--   ButtonPart (ClickDetector 추가) > Script
--   Workspace > Stairs(Folder) > Step1, Step2, Step3...
--     (각 Step: Transparency=1, CanCollide=false 로 시작)
-- 💡 ClickDetector = 파트를 클릭 가능하게 만드는 오브젝트
-- 💡 MouseClick = 클릭했을 때 발생하는 이벤트!
-- ========================================

-- 💡 ButtonPart 안에 있는 ClickDetector 찾기
local clickDetector = script.Parent:FindFirstChild([b1])
-- 💡 계단들이 담긴 폴더
local stairsFolder = workspace:FindFirstChild("Stairs")
-- 💡 몇 번째 계단까지 나타났는지 추적
local currentStep = 0

-- 💡 버튼 클릭할 때마다 실행!
clickDetector.[b2]:Connect(function(player)
    currentStep = currentStep + 1

    -- 💡 "Step1", "Step2"... 이름으로 다음 계단 찾기
    local nextStair = stairsFolder:FindFirstChild("Step" .. currentStep)

    if nextStair then
        -- 💡 Transparency 0 = 눈에 보임!
        nextStair.Transparency = [b3]
        -- 💡 CanCollide = 밟을 수 있게!
        nextStair.CanCollide = [b4]
        print(player.Name .. " → " .. currentStep .. "번 계단 소환! 🪜")
    else
        print("모든 계단 소환 완료! 리셋")
        -- 💡 모든 계단 다시 숨기기
        for _, stair in pairs(stairsFolder:GetChildren()) do
            stair.Transparency = 1
            stair.CanCollide = false
        end
        currentStep = 0
    end
end)`;
const stairsFullCode = `-- 🪜 버튼 → 순차 계단 소환
-- 📦 ButtonPart > ClickDetector + Script
-- Workspace > Stairs(Folder) > Step1, Step2, Step3...
local clickDetector = script.Parent:FindFirstChild("ClickDetector")
local stairsFolder = workspace:FindFirstChild("Stairs")
local currentStep = 0

clickDetector.MouseClick:Connect(function(player)
    currentStep = currentStep + 1
    local nextStair = stairsFolder:FindFirstChild("Step" .. currentStep)
    if nextStair then
        nextStair.Transparency = 0
        nextStair.CanCollide = true
        print(player.Name .. " → " .. currentStep .. "번 계단 소환!")
    else
        for _, stair in pairs(stairsFolder:GetChildren()) do
            stair.Transparency = 1
            stair.CanCollide = false
        end
        currentStep = 0
    end
end)`;

// 퀴즈 2: ProximityPrompt 플랫폼 소환
const proximityBlanks = JSON.stringify([
    { id: "b1", correct: "\"ProximityPrompt\"", options: ["\"ProximityPrompt\"", "\"ClickDetector\"", "\"Button\"", "\"Trigger\""] },
    { id: "b2", correct: "Triggered", options: ["Triggered", "MouseClick", "Touched", "Activated"] },
    { id: "b3", correct: "stepIndex + 1", options: ["stepIndex + 1", "stepIndex", "1", "stepIndex - 1"] }
]);
const proximityTemplate = `-- ========================================
-- ✨ ProximityPrompt: [E] 눌러서 발판 소환!
-- ========================================
-- 📦 준비:
--   Part (ActivatorPart) > ProximityPrompt + Script
--   Workspace > Platforms(Folder) > Platform1, Platform2...
-- 💡 ProximityPrompt = 가까이 가면 [E] 안내가 나타남!
-- 💡 ClickDetector보다 더 현대적인 방식!
-- ========================================

-- 💡 ProximityPrompt 찾기
local prompt = script.Parent:FindFirstChild([b1])
local platforms = workspace:FindFirstChild("Platforms")
local stepIndex = 0   -- 💡 몇 번째 발판까지 소환했는지

-- 💡 ProximityPrompt의 속성 설정
prompt.ActionText = "발판 소환"     -- 💡 버튼에 표시되는 텍스트
prompt.MaxActivationDistance = 10   -- 💡 10스터드 안에서만 작동

-- 💡 [E] 키를 눌렀을 때 실행!
prompt.[b2]:Connect(function(player)
    -- 💡 다음 발판 번호로 업데이트
    stepIndex = [b3]

    local platform = platforms:FindFirstChild("Platform" .. stepIndex)
    if platform then
        platform.Transparency = 0
        platform.CanCollide = true
        -- 💡 안내 텍스트 업데이트!
        prompt.ActionText = stepIndex .. "번 발판 소환됨!"
        print(player.Name .. " → Platform" .. stepIndex .. " 소환!")
    else
        prompt.ActionText = "모두 소환 완료!"
        task.wait(1)
        prompt.Enabled = false  -- 💡 프롬프트 비활성화
    end
end)`;
const proximityFullCode = `-- ✨ ProximityPrompt 발판 소환
-- 📦 ActivatorPart > ProximityPrompt + Script
local prompt = script.Parent:FindFirstChild("ProximityPrompt")
local platforms = workspace:FindFirstChild("Platforms")
local stepIndex = 0

prompt.ActionText = "발판 소환"
prompt.MaxActivationDistance = 10

prompt.Triggered:Connect(function(player)
    stepIndex = stepIndex + 1
    local platform = platforms:FindFirstChild("Platform" .. stepIndex)
    if platform then
        platform.Transparency = 0
        platform.CanCollide = true
        prompt.ActionText = stepIndex .. "번 발판 소환됨!"
    else
        prompt.ActionText = "모두 소환 완료!"
        task.wait(1)
        prompt.Enabled = false
    end
end)`;

// 퀴즈 3: 저중력 구역
const gravityBlanks = JSON.stringify([
    { id: "b1", correct: "196.2", options: ["196.2", "100", "9.8", "0"] },
    { id: "b2", correct: "\"Humanoid\"", options: ["\"Humanoid\"", "\"Character\"", "\"Player\"", "\"HumanoidRootPart\""] },
    { id: "b3", correct: "workspace.Gravity", options: ["workspace.Gravity", "game.Gravity", "Humanoid.Gravity", "workspace.FallHeight"] }
]);
const gravityTemplate = `-- ========================================
-- 🌙 저중력 구역 (달나라 존!)
-- ========================================
-- 📦 준비: 큰 투명 Part (Transparency=0.5, CanCollide=false) > Script
-- 💡 Workspace.Gravity = 지구 중력값 (기본: 196.2)
-- 💡 낮추면 달처럼 느리게 떨어지고 높이 점프됨!
-- 💡 CanCollide=false 파트로 구역 경계 만들기
-- ========================================

local zone = script.Parent

-- 💡 기본 중력 저장 (지구 = 196.2)
local NORMAL_GRAVITY = [b1]
-- 💡 달 중력 (30 = 지구의 약 1/6!)
local LOW_GRAVITY    = 30

-- 💡 구역에 있는 캐릭터들을 기억하는 테이블
local inZone = {}

-- 💡 구역에 들어왔을 때
zone.Touched:Connect(function(hit)
    -- 💡 사람인지 확인
    if hit.Parent:FindFirstChild([b2]) and not inZone[hit.Parent] then
        inZone[hit.Parent] = true
        -- 💡 중력을 달나라 수준으로!
        [b3] = LOW_GRAVITY
        print(hit.Parent.Name .. " 저중력 구역 진입! 🌙")
    end
end)

-- 💡 구역을 나갔을 때
zone.TouchEnded:Connect(function(hit)
    if hit.Parent:FindFirstChild("Humanoid") and inZone[hit.Parent] then
        inZone[hit.Parent] = nil
        -- 💡 플레이어가 모두 나가면 중력 복구
        if next(inZone) == nil then
            workspace.Gravity = NORMAL_GRAVITY
            print("중력 복구! 지구로 돌아옴 🌍")
        end
    end
end)`;
const gravityFullCode = `-- 🌙 저중력 구역
-- 📦 큰 투명 Part (CanCollide=false) > Script
local zone = script.Parent
local NORMAL_GRAVITY = 196.2
local LOW_GRAVITY = 30
local inZone = {}

zone.Touched:Connect(function(hit)
    if hit.Parent:FindFirstChild("Humanoid") and not inZone[hit.Parent] then
        inZone[hit.Parent] = true
        workspace.Gravity = LOW_GRAVITY
    end
end)

zone.TouchEnded:Connect(function(hit)
    if hit.Parent:FindFirstChild("Humanoid") and inZone[hit.Parent] then
        inZone[hit.Parent] = nil
        if next(inZone) == nil then
            workspace.Gravity = NORMAL_GRAVITY
        end
    end
end)`;

// 퀴즈 4: 스프링 패드
const springBlanks = JSON.stringify([
    { id: "b1", correct: "\"Humanoid\"", options: ["\"Humanoid\"", "\"Character\"", "\"HumanoidRootPart\"", "\"Player\""] },
    { id: "b2", correct: "JumpPower", options: ["JumpPower", "WalkSpeed", "Health", "JumpHeight"] },
    { id: "b3", correct: "true", options: ["true", "false", "50", "150"] }
]);
const springTemplate = `-- ========================================
-- 🌀 스프링 패드 (엄청 높이 튀어오름!)
-- ========================================
-- 📦 준비: Part (노란색, Anchored ✓) > Script
-- 💡 JumpPower = 점프 높이 (기본값: 50)
-- 💡 humanoid.Jump = true = 강제로 점프 실행!
-- 💡 밟으면 순간적으로 JumpPower를 150으로 높임!
-- ========================================

local springPad = script.Parent
springPad.BrickColor = BrickColor.new("Bright yellow")  -- 💡 노란색
springPad.Material = Enum.Material.Neon                  -- 💡 빛나게!

local debounce = false  -- 💡 중복 방지

springPad.Touched:Connect(function(hit)
    -- 💡 사람인지 확인
    local humanoid = hit.Parent:FindFirstChild([b1])

    if humanoid and not debounce then
        debounce = true

        -- 💡 원래 점프력 저장 (나중에 복구용)
        local originalJump = humanoid.[b2]

        -- 💡 점프력 3배로 UP!
        humanoid.JumpPower = 150
        -- 💡 즉시 점프 실행!
        humanoid.Jump = [b3]

        -- 💡 1.5초 뒤 점프력 원래대로 복구
        task.wait(1.5)
        humanoid.JumpPower = originalJump

        -- 💡 0.5초 쿨타임 후 다시 사용 가능
        task.wait(0.5)
        debounce = false
    end
end)`;
const springFullCode = `-- 🌀 스프링 패드
-- 📦 Part (Anchored=true) > Script
local springPad = script.Parent
springPad.BrickColor = BrickColor.new("Bright yellow")
springPad.Material = Enum.Material.Neon
local debounce = false

springPad.Touched:Connect(function(hit)
    local humanoid = hit.Parent:FindFirstChild("Humanoid")
    if humanoid and not debounce then
        debounce = true
        local originalJump = humanoid.JumpPower
        humanoid.JumpPower = 150
        humanoid.Jump = true
        task.wait(1.5)
        humanoid.JumpPower = originalJump
        task.wait(0.5)
        debounce = false
    end
end)`;

// 퀴즈 5: 색깔 함정
const colorTrapBlanks = JSON.stringify([
    { id: "b1", correct: "humanoid.Health = 0", options: ["humanoid.Health = 0", "humanoid:TakeDamage(100)", "humanoid:Destroy()", "humanoid.Health -= 50"] },
    { id: "b2", correct: "COLORS[safeColorIndex]", options: ["COLORS[safeColorIndex]", "safeColorIndex", "COLORS", "COLORS[1]"] },
    { id: "b3", correct: "math.random(1, #COLORS)", options: ["math.random(1, #COLORS)", "#COLORS", "math.random()", "1"] }
]);
const colorTrapTemplate = `-- ========================================
-- 🎨 색깔 함정 (틀린 색 밟으면 즉사!)
-- ========================================
-- 📦 준비:
--   Workspace > ColorTrap(Folder) > Tile1, Tile2, Tile3, Tile4
--   Script를 ColorTrap 폴더 안에 넣기
-- 💡 3초마다 안전한 색이 바뀜! 잘 보고 밟아요.
-- 💡 safeColorIndex = 현재 안전한 색의 번호
-- ========================================

local colorTrap = script.Parent

-- 💡 사용할 색상 목록
local COLORS = {
    BrickColor.new("Bright red"),
    BrickColor.new("Bright blue"),
    BrickColor.new("Bright yellow"),
    BrickColor.new("Lime green"),
}
local safeColorIndex = 1  -- 💡 처음엔 1번(빨강)이 안전

-- 💡 각 타일에 킬 기능 연결
for _, tile in pairs(colorTrap:GetChildren()) do
    if tile:IsA("BasePart") then
        tile.Touched:Connect(function(hit)
            local humanoid = hit.Parent:FindFirstChild("Humanoid")
            if humanoid then
                -- 💡 안전한 색이 아니면 즉사!
                if tile.BrickColor ~= [b2] then
                    [b1]
                end
            end
        end)
    end
end

-- 💡 3초마다 안전 색 변경 루프
while true do
    task.wait(3)

    -- 💡 새 안전 색 랜덤 선택!
    safeColorIndex = [b3]

    -- 💡 잠깐 회색으로 바꿔서 힌트 제공
    for _, tile in pairs(colorTrap:GetChildren()) do
        if tile:IsA("BasePart") then
            tile.BrickColor = BrickColor.new("Medium stone grey")
        end
    end
    task.wait(0.5)

    -- 💡 색 다시 배정
    local tiles = {}
    for _, t in pairs(colorTrap:GetChildren()) do
        if t:IsA("BasePart") then table.insert(tiles, t) end
    end
    for i, tile in ipairs(tiles) do
        tile.BrickColor = COLORS[((i - 1) % #COLORS) + 1]
    end
end`;
const colorTrapFullCode = `-- 🎨 색깔 함정
-- 📦 ColorTrap(Folder) > Tile1~4 + Script
local colorTrap = script.Parent
local COLORS = {
    BrickColor.new("Bright red"),
    BrickColor.new("Bright blue"),
    BrickColor.new("Bright yellow"),
    BrickColor.new("Lime green"),
}
local safeColorIndex = 1

for _, tile in pairs(colorTrap:GetChildren()) do
    if tile:IsA("BasePart") then
        tile.Touched:Connect(function(hit)
            local humanoid = hit.Parent:FindFirstChild("Humanoid")
            if humanoid and tile.BrickColor ~= COLORS[safeColorIndex] then
                humanoid.Health = 0
            end
        end)
    end
end

while true do
    task.wait(3)
    safeColorIndex = math.random(1, #COLORS)
    for _, tile in pairs(colorTrap:GetChildren()) do
        if tile:IsA("BasePart") then
            tile.BrickColor = BrickColor.new("Medium stone grey")
        end
    end
    task.wait(0.5)
    local tiles = {}
    for _, t in pairs(colorTrap:GetChildren()) do
        if t:IsA("BasePart") then table.insert(tiles, t) end
    end
    for i, tile in ipairs(tiles) do
        tile.BrickColor = COLORS[((i - 1) % #COLORS) + 1]
    end
end`;

// 퀴즈 6: 타이머 챌린지
const timerBlanks = JSON.stringify([
    { id: "b1", correct: "isRunning", options: ["isRunning", "timeLeft", "isFading", "triggered"] },
    { id: "b2", correct: "true", options: ["true", "false", "nil", "0"] },
    { id: "b3", correct: "timeLeft", options: ["timeLeft", "TIME_LIMIT", "0", "isRunning"] }
]);
const timerTemplate = `-- ========================================
-- ⏱️ 타이머 챌린지 (제한시간 내에 도착!)
-- ========================================
-- 📦 준비:
--   StarterPlayerScripts > LocalScript
--   StarterGui > ScreenGui("TimerGui") > TextLabel("TimerLabel")
--   Workspace > TimerStart, TimerEnd (파트)
-- 💡 LocalScript = 이 플레이어에게만 실행됨
-- 💡 isRunning = 타이머 실행 중인지 상태 추적
-- ========================================

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- 💡 GUI 요소 찾기
local timerLabel = player.PlayerGui
    :WaitForChild("TimerGui"):WaitForChild("TimerLabel")

local startPad = workspace:WaitForChild("TimerStart")
local endPad   = workspace:WaitForChild("TimerEnd")

local TIME_LIMIT = 30   -- 💡 30초 제한
local isRunning  = false -- 💡 타이머 실행 중인지 상태

-- 💡 타이머 함수
local function startTimer()
    -- 💡 이미 실행 중이면 무시 (중복 방지)
    if [b1] then return end
    isRunning = [b2]

    local timeLeft = TIME_LIMIT
    timerLabel.Visible = true

    -- 💡 1초마다 카운트다운!
    while timeLeft > 0 and isRunning do
        timerLabel.Text = "⏱️ " .. [b3] .. "초"
        -- 💡 10초 이하면 빨간색으로 강조
        if timeLeft <= 10 then
            timerLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
        task.wait(1)
        timeLeft = timeLeft - 1
    end

    -- 💡 시간 초과시 처음으로!
    if isRunning then
        timerLabel.Text = "💀 시간 초과!"
        task.wait(2)
        character.HumanoidRootPart.CFrame = startPad.CFrame + Vector3.new(0, 3, 0)
    end
    isRunning = false
    timerLabel.Visible = false
    timerLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
end

-- 💡 스타트 패드 밟으면 타이머 시작!
startPad.Touched:Connect(function(hit)
    if hit.Parent == character then
        task.spawn(startTimer)
    end
end)

-- 💡 엔드 패드 밟으면 클리어!
endPad.Touched:Connect(function(hit)
    if hit.Parent == character and isRunning then
        isRunning = false
        timerLabel.Text = "🎉 클리어!"
        timerLabel.TextColor3 = Color3.fromRGB(61, 255, 162)
    end
end)`;
const timerFullCode = `-- ⏱️ 타이머 챌린지
-- 📦 StarterPlayerScripts > LocalScript
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local timerLabel = player.PlayerGui:WaitForChild("TimerGui"):WaitForChild("TimerLabel")
local startPad = workspace:WaitForChild("TimerStart")
local endPad = workspace:WaitForChild("TimerEnd")
local TIME_LIMIT = 30
local isRunning = false

local function startTimer()
    if isRunning then return end
    isRunning = true
    local timeLeft = TIME_LIMIT
    timerLabel.Visible = true
    while timeLeft > 0 and isRunning do
        timerLabel.Text = "⏱️ " .. timeLeft .. "초"
        if timeLeft <= 10 then
            timerLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
        task.wait(1)
        timeLeft = timeLeft - 1
    end
    if isRunning then
        timerLabel.Text = "💀 시간 초과!"
        task.wait(2)
        character.HumanoidRootPart.CFrame = startPad.CFrame + Vector3.new(0, 3, 0)
    end
    isRunning = false
    timerLabel.Visible = false
    timerLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
end

startPad.Touched:Connect(function(hit)
    if hit.Parent == character then task.spawn(startTimer) end
end)
endPad.Touched:Connect(function(hit)
    if hit.Parent == character and isRunning then
        isRunning = false
        timerLabel.Text = "🎉 클리어!"
        timerLabel.TextColor3 = Color3.fromRGB(61, 255, 162)
    end
end)`;
