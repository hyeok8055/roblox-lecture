---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';

// 확인 퀴즈 옵션
const quiz1Options = JSON.stringify(["TweenService:Create()", "RunService.Heartbeat", "Part:MoveTo()", "CFrame.new()"]);
const quiz2Options = JSON.stringify(["-1", "0", "1", "10"]);
const quiz3Options = JSON.stringify(["AssemblyLinearVelocity", "Velocity", "BodyVelocity", "LinearVelocity"]);
const quiz4Options = JSON.stringify(["i / 10", "i", "0.1", "i * 10"]);

// =========================================
// 드롭다운 퀴즈 데이터 (6개)
// =========================================

// 퀴즈 1: 수평 이동 플랫폼
const movePlatformBlanks = JSON.stringify([
    { id: "b1", correct: "\"TweenService\"", options: ["\"TweenService\"", "\"RunService\"", "\"Workspace\"", "\"Players\""] },
    { id: "b2", correct: "Vector3.new(20, 0, 0)", options: ["Vector3.new(20, 0, 0)", "Vector3.new(0, 20, 0)", "Vector3.new(0, 0, 20)", "Vector3.new(20, 20, 0)"] },
    { id: "b3", correct: "-1", options: ["-1", "0", "1", "10"] },
    { id: "b4", correct: "true", options: ["true", "false", "nil", "0"] }
]);
const movePlatformTemplate = `-- ========================================
-- 🚂 수평 왕복 이동 플랫폼
-- ========================================
-- 📦 준비: Part (Anchored ✓) + Script
-- 💡 TweenService = 파트를 부드럽게 움직이는 서비스
-- 💡 TweenInfo = 이동 방식 설정 (시간, 속도, 반복, 왕복)
-- 💡 RepeatCount = -1 이면 무한반복!
-- 💡 Reverses = true 이면 왔다갔다 왕복!
-- ========================================

-- 💡 TweenService 가져오기
local TweenService = game:GetService([b1])
local platform = script.Parent

-- 💡 시작 위치 기억
local startPos = platform.Position
-- 💡 도착 위치 = 오른쪽으로 20스터드
local endPos = startPos + [b2]

-- 💡 이동 방식 설정
local tweenInfo = TweenInfo.new(
    2,                           -- 💡 이동에 걸리는 시간 (초)
    Enum.EasingStyle.Linear,     -- 💡 일정한 속도
    Enum.EasingDirection.InOut,  -- 💡 끝에서 살짝 부드럽게
    [b3],                        -- 💡 -1 = 무한 반복!
    [b4],                        -- 💡 true = 왔다갔다 왕복!
    0.5                          -- 💡 방향 바꿀 때 0.5초 대기
)

-- 💡 트윈 생성: 플랫폼 위치를 endPos로 이동
local tween = TweenService:Create(platform, tweenInfo, {Position = endPos})
tween:Play()`;
const movePlatformFullCode = `-- 🚂 수평 이동 플랫폼
-- 📦 Part (Anchored=true) > Script
local TweenService = game:GetService("TweenService")
local platform = script.Parent
local startPos = platform.Position
local endPos = startPos + Vector3.new(20, 0, 0)

local tweenInfo = TweenInfo.new(
    2,
    Enum.EasingStyle.Linear,
    Enum.EasingDirection.InOut,
    -1,    -- 무한반복
    true,  -- 왕복
    0.5
)

local tween = TweenService:Create(platform, tweenInfo, {Position = endPos})
tween:Play()`;

// 퀴즈 2: 수직 이동 플랫폼
const vertPlatformBlanks = JSON.stringify([
    { id: "b1", correct: "15", options: ["15", "5", "30", "0"] },
    { id: "b2", correct: "Sine", options: ["Sine", "Linear", "Bounce", "Back"] },
    { id: "b3", correct: "Position", options: ["Position", "CFrame", "Size", "Color"] }
]);
const vertPlatformTemplate = `-- ========================================
-- 🛗 위아래 수직 이동 플랫폼
-- ========================================
-- 📦 준비: Part (Anchored ✓) + Script
-- 💡 수직 이동 = Y값만 변경!
-- 💡 EasingStyle.Sine = 가속/감속이 자연스러워서 수직 이동에 딱!
-- 💡 꼭대기에서 1초 대기 후 내려옴 (DelayTime = 1)
-- ========================================

local TweenService = game:GetService("TweenService")
local platform = script.Parent

local startPos = platform.Position
-- 💡 Y값만 늘려서 위로 올라감! (15스터드 위)
local topPos = startPos + Vector3.new(0, [b1], 0)

-- 💡 Sine = 자연스럽게 가속/감속
local tweenInfo = TweenInfo.new(
    3,                            -- 💡 3초 동안 이동 (느릴수록 쉬운 난이도)
    Enum.EasingStyle.[b2],        -- 💡 자연스러운 가속/감속
    Enum.EasingDirection.InOut,
    -1,
    true,
    1   -- 💡 꼭대기에서 1초 대기 후 내려옴
)

-- 💡 Position 속성을 topPos로 이동
local tween = TweenService:Create(platform, tweenInfo, {[b3] = topPos})
tween:Play()`;
const vertPlatformFullCode = `-- 🛗 수직 이동 플랫폼
-- 📦 Part (Anchored=true) > Script
local TweenService = game:GetService("TweenService")
local platform = script.Parent
local startPos = platform.Position
local topPos = startPos + Vector3.new(0, 15, 0)

local tweenInfo = TweenInfo.new(
    3,
    Enum.EasingStyle.Sine,
    Enum.EasingDirection.InOut,
    -1,
    true,
    1
)

local tween = TweenService:Create(platform, tweenInfo, {Position = topPos})
tween:Play()`;

// 퀴즈 3: 회전 장애물
const spinnerBlanks = JSON.stringify([
    { id: "b1", correct: "\"RunService\"", options: ["\"RunService\"", "\"TweenService\"", "\"Workspace\"", "\"Players\""] },
    { id: "b2", correct: "Heartbeat", options: ["Heartbeat", "Stepped", "RenderStepped", "Connect"] },
    { id: "b3", correct: "ROTATION_SPEED * deltaTime", options: ["ROTATION_SPEED * deltaTime", "deltaTime", "ROTATION_SPEED", "90"] }
]);
const spinnerTemplate = `-- ========================================
-- 🌀 회전하는 장애물 (스피너)
-- ========================================
-- 📦 준비: Part (Anchored ✓, 길쭉한 막대) + Script
-- 💡 RunService = 매 프레임마다 뭔가를 실행하는 서비스
-- 💡 deltaTime = 지난 프레임과 현재 사이의 시간(초)
--    → 이걸 곱해야 프레임 속도와 상관없이 일정하게 회전!
-- 💡 math.rad() = 도(°)를 라디안으로 변환 (Lua 필수!)
-- ========================================

local RunService = game:GetService([b1])
local spinner = script.Parent

-- 💡 초당 회전 각도 (90 = 초당 90도 = 4초에 한 바퀴)
local ROTATION_SPEED = 90

-- 💡 Heartbeat = 매 프레임마다 실행됨
RunService.[b2]:Connect(function(deltaTime)
    -- 💡 CFrame을 Y축으로 회전시키기!
    spinner.CFrame = spinner.CFrame * CFrame.Angles(
        0,                                    -- 💡 X축: 회전 없음
        math.rad([b3]),   -- 💡 Y축: 회전!
        0                                     -- 💡 Z축: 회전 없음
    )
end)`;
const spinnerFullCode = `-- 🌀 회전 장애물
-- 📦 Part (Anchored=true) > Script
local RunService = game:GetService("RunService")
local spinner = script.Parent
local ROTATION_SPEED = 90

RunService.Heartbeat:Connect(function(deltaTime)
    spinner.CFrame = spinner.CFrame * CFrame.Angles(
        0,
        math.rad(ROTATION_SPEED * deltaTime),
        0
    )
end)`;

// 퀴즈 4: 컨베이어 벨트
const conveyorBlanks = JSON.stringify([
    { id: "b1", correct: "AssemblyLinearVelocity", options: ["AssemblyLinearVelocity", "Velocity", "BodyVelocity", "LinearVelocity"] },
    { id: "b2", correct: "LookVector", options: ["LookVector", "RightVector", "UpVector", "Position"] },
    { id: "b3", correct: "SPEED", options: ["SPEED", "1", "0", "-SPEED"] }
]);
const conveyorTemplate = `-- ========================================
-- 🏭 컨베이어 벨트
-- ========================================
-- 📦 준비: Part (Anchored ✓, 납작한 판) + Script
-- 💡 AssemblyLinearVelocity = 파트 위의 물체를 미는 힘!
-- 💡 CFrame.LookVector = 파트가 바라보는 앞방향 벡터
--    → 파트를 원하는 방향으로 회전시켜 놓으면 그 방향으로 밀어냄
-- ========================================

local conveyor = script.Parent

-- 💡 밀어내는 속도 (숫자가 클수록 빠름)
local SPEED = 20

-- 💡 파트 앞방향으로 초당 SPEED 스터드만큼 밀어냄!
-- 💡 한 번만 설정하면 계속 작동해요 (루프 불필요!)
conveyor.[b1] = conveyor.CFrame.[b2] * [b3]

print("🏭 컨베이어 벨트 활성화! 속도:", SPEED)`;
const conveyorFullCode = `-- 🏭 컨베이어 벨트
-- 📦 Part (Anchored=true) > Script
local conveyor = script.Parent
local SPEED = 20

conveyor.AssemblyLinearVelocity = conveyor.CFrame.LookVector * SPEED`;

// 퀴즈 5: 사라지는 함정
const fadingTrapBlanks = JSON.stringify([
    { id: "b1", correct: "i / 10", options: ["i / 10", "i", "0.1", "i * 10"] },
    { id: "b2", correct: "false", options: ["false", "true", "nil", "0"] },
    { id: "b3", correct: "true", options: ["true", "false", "nil", "0"] }
]);
const fadingTrapTemplate = `-- ========================================
-- 💨 밟으면 사라지는 함정 플랫폼
-- ========================================
-- 📦 준비: Part (Anchored ✓, 노란색) + Script
-- 💡 isTouched = debounce (동시에 여러 번 실행 방지)
-- 💡 for i = 1, 10 → 10번 반복하면서 0.1씩 투명해짐!
-- 💡 CanCollide = false → 이제 발이 빠져 떨어짐!
-- ========================================

local platform = script.Parent
local isTouched = false   -- 💡 중복 방지 플래그

local function fade()
    if isTouched then return end   -- 💡 이미 진행 중이면 무시
    isTouched = true

    -- 💡 1초에 걸쳐 서서히 투명해짐
    for i = 1, 10 do
        -- 💡 i=1이면 0.1, i=5면 0.5, i=10이면 1.0 (완전 투명)
        platform.Transparency = [b1]
        task.wait(0.1)   -- 💡 0.1초마다 한 단계씩
    end

    -- 💡 투명해지면 이제 통과됨 (떨어짐!)
    platform.CanCollide = [b2]

    -- 💡 3초 후 다시 복구
    task.wait(3)
    platform.Transparency = 0   -- 💡 다시 보임
    platform.CanCollide = [b3]  -- 💡 다시 밟을 수 있음
    isTouched = false           -- 💡 잠금 해제
end

platform.Touched:Connect(fade)`;
const fadingTrapFullCode = `-- 💨 사라지는 함정
-- 📦 Part (Anchored=true) > Script
local platform = script.Parent
local isTouched = false

local function fade()
    if isTouched then return end
    isTouched = true

    for i = 1, 10 do
        platform.Transparency = i / 10
        task.wait(0.1)
    end

    platform.CanCollide = false
    task.wait(3)
    platform.Transparency = 0
    platform.CanCollide = true
    isTouched = false
end

platform.Touched:Connect(fade)`;

// 퀴즈 6: 고급 체크포인트 시스템
const checkpointBlanks = JSON.stringify([
    { id: "b1", correct: "\"Folder\"", options: ["\"Folder\"", "\"IntValue\"", "\"StringValue\"", "\"Frame\""] },
    { id: "b2", correct: "stage.Value", options: ["stage.Value", "checkpointNum", "1", "stage"] },
    { id: "b3", correct: "stage.Value", options: ["stage.Value", "checkpointNum", "0", "1"] }
]);
const checkpointTemplate = `-- ========================================
-- 🏁 고급 체크포인트 시스템 (Leaderstats 연동)
-- ========================================
-- 📦 준비:
--   ServerScriptService > Script (이 코드)
--   Workspace > Checkpoints (Folder)
--     > Checkpoint1, Checkpoint2, Checkpoint3 ... (Part들)
-- 💡 Stage = 현재 도달한 체크포인트 번호
-- 💡 죽으면 마지막 체크포인트로 자동 텔레포트!
-- ========================================

local Players = game:GetService("Players")
local checkpointsFolder = workspace:WaitForChild("Checkpoints")

Players.PlayerAdded:Connect(function(player)
    -- 💡 Leaderstats 폴더 생성
    local leaderstats = Instance.new([b1])
    leaderstats.Name = "leaderstats"
    leaderstats.Parent = player

    -- 💡 Stage 값 (0 = 아직 체크포인트 없음)
    local stage = Instance.new("IntValue")
    stage.Name = "Stage"
    stage.Value = 0
    stage.Parent = leaderstats

    -- 💡 죽고 다시 스폰될 때마다 실행
    player.CharacterAdded:Connect(function(character)
        local rootPart = character:WaitForChild("HumanoidRootPart")
        if stage.Value > 0 then
            -- 💡 마지막 체크포인트 찾기 (번호로 검색)
            local checkpoint = checkpointsFolder:FindFirstChild("Checkpoint" .. [b2])
            if checkpoint then
                task.wait(0.1)
                rootPart.CFrame = checkpoint.CFrame + Vector3.new(0, 2, 0)
            end
        end
    end)
end)

-- 💡 각 체크포인트에 Touched 이벤트 연결
for _, checkpoint in pairs(checkpointsFolder:GetChildren()) do
    local checkpointNum = tonumber(checkpoint.Name:match("%d+"))
    checkpoint.Touched:Connect(function(hit)
        local humanoid = hit.Parent:FindFirstChildWhichIsA("Humanoid")
        if not humanoid then return end
        local player = Players:GetPlayerFromCharacter(hit.Parent)
        if not player then return end
        local stage = player.leaderstats.Stage
        -- 💡 더 높은 체크포인트에 도달했을 때만 저장!
        if checkpointNum > [b3] then
            stage.Value = checkpointNum
        end
    end)
end`;
const checkpointFullCode = `-- 🏁 체크포인트 시스템
-- 📦 ServerScriptService > Script
local Players = game:GetService("Players")
local checkpointsFolder = workspace:WaitForChild("Checkpoints")

Players.PlayerAdded:Connect(function(player)
    local leaderstats = Instance.new("Folder")
    leaderstats.Name = "leaderstats"
    leaderstats.Parent = player

    local stage = Instance.new("IntValue")
    stage.Name = "Stage"
    stage.Value = 0
    stage.Parent = leaderstats

    player.CharacterAdded:Connect(function(character)
        local rootPart = character:WaitForChild("HumanoidRootPart")
        if stage.Value > 0 then
            local checkpoint = checkpointsFolder:FindFirstChild("Checkpoint" .. stage.Value)
            if checkpoint then
                task.wait(0.1)
                rootPart.CFrame = checkpoint.CFrame + Vector3.new(0, 2, 0)
            end
        end
    end)
end)

for _, checkpoint in pairs(checkpointsFolder:GetChildren()) do
    local checkpointNum = tonumber(checkpoint.Name:match("%d+"))
    checkpoint.Touched:Connect(function(hit)
        local humanoid = hit.Parent:FindFirstChildWhichIsA("Humanoid")
        if not humanoid then return end
        local player = Players:GetPlayerFromCharacter(hit.Parent)
        if not player then return end
        local stage = player.leaderstats.Stage
        if checkpointNum > stage.Value then
            stage.Value = checkpointNum
        end
    end)
end`;
---

<LessonLayout title="오비 맵 고급 설계: 5가지 기믹" lessonNumber={10} totalSlides={14}>
    <!-- 슬라이드 1: 인트로 -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">10주차 B</span>
                <h1 class="title-display mb-4">
                    오비 맵 고급 설계:<br>
                    <span class="text-neon-mint">🏃 5가지 기믹!</span>
                </h1>
                <p class="text-xl text-ink-light max-w-lg mx-auto mb-8">
                    이동 플랫폼, 회전 장애물, 컨베이어 벨트,<br>
                    사라지는 함정, 고급 체크포인트까지!
                </p>
                <div class="flex gap-3 justify-center flex-wrap">
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🚂 TweenService 이동</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🌀 RunService 회전</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🏭 컨베이어 벨트</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">💨 사라지는 함정</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🏁 고급 체크포인트</span>
                    </div>
                </div>

                <div class="mt-12 p-6 bg-gradient-to-r from-green-50 to-blue-50 rounded-2xl max-w-md mx-auto">
                    <div class="text-3xl mb-2">🎯</div>
                    <h3 class="font-bold mb-2">오늘의 목표</h3>
                    <ul class="text-left text-sm text-ink-light space-y-1">
                        <li>✓ TweenService로 수평/수직 이동 플랫폼 만들기</li>
                        <li>✓ RunService.Heartbeat로 회전 장애물 만들기</li>
                        <li>✓ AssemblyLinearVelocity로 컨베이어 벨트</li>
                        <li>✓ 서서히 사라지는 함정 플랫폼</li>
                        <li>✓ Leaderstats 연동 고급 체크포인트 시스템</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 슬라이드 2: TweenService 개념 -->
    <section class="slide">
        <div class="max-w-4xl mx-auto px-6 py-12">
            <div class="animate-in">
                <span class="badge badge-lesson mb-4">개념 학습</span>
                <h2 class="title-section mb-6">🚂 TweenService: 부드러운 이동!</h2>
            </div>

            <div class="flex flex-col gap-5 animate-in">
                <div class="lesson-card">
                    <h3 class="font-bold text-lg mb-4">TweenService란?</h3>
                    <p class="text-sm text-ink-light mb-4">파트의 위치(Position), 색상(Color), 투명도 등을 <strong>부드럽게 변화</strong>시켜주는 서비스예요. while true do로 직접 이동시키는 것보다 훨씬 부드럽고 효율적이에요!</p>

                    <div class="bg-ink-pale rounded-xl p-4 font-mono text-sm mb-4">
                        <div class="text-ink-light text-xs mb-2">-- TweenService 사용 기본 구조</div>
                        <div>local ts = game:GetService(<span class="text-neon-gold">"TweenService"</span>)</div>
                        <div>local info = TweenInfo.new(시간, EasingStyle, ...)</div>
                        <div>local tween = ts:Create(파트, info, &#123;속성 = 목표값&#125;)</div>
                        <div>tween:<span class="text-neon-mint">Play()</span></div>
                    </div>
                </div>

                <div class="lesson-card">
                    <h4 class="font-bold mb-4">TweenInfo 파라미터 설명</h4>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm border-collapse">
                            <thead>
                                <tr class="bg-ink-pale">
                                    <th class="text-left p-3 font-bold">순서</th>
                                    <th class="text-left p-3 font-bold">이름</th>
                                    <th class="text-left p-3 font-bold">예시값</th>
                                    <th class="text-left p-3 font-bold">설명</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-b border-gray-100">
                                    <td class="p-3 font-bold text-neon-gold">1번째</td>
                                    <td class="p-3 font-mono text-sm">Time</td>
                                    <td class="p-3 font-mono">2</td>
                                    <td class="p-3">이동 시간(초). 클수록 느리게 이동</td>
                                </tr>
                                <tr class="border-b border-gray-100 bg-gray-50">
                                    <td class="p-3 font-bold text-neon-gold">2번째</td>
                                    <td class="p-3 font-mono text-sm">EasingStyle</td>
                                    <td class="p-3 font-mono">Linear</td>
                                    <td class="p-3">속도 곡선 (Linear=일정, Sine=자연스러운, Bounce=통통)</td>
                                </tr>
                                <tr class="border-b border-gray-100">
                                    <td class="p-3 font-bold text-neon-gold">3번째</td>
