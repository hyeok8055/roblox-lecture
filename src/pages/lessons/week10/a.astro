---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';

// 확인 퀴즈 옵션
const quiz1Options = JSON.stringify(["TweenService", "SoundService", "RunService", "Players"]);
const quiz2Options = JSON.stringify(["Touched", "TouchEnded", "MouseClick", "Triggered"]);
const quiz3Options = JSON.stringify(["RollOffMaxDistance", "Volume", "PlaybackSpeed", "TimePosition"]);
const quiz4Options = JSON.stringify(["speed / 14", "speed * 2", "speed / 2", "speed + 1"]);

// =========================================
// 드롭다운 퀴즈 데이터 (5개)
// =========================================

// 퀴즈 1: TweenService 볼륨 페이드인/페이드아웃
const fadeBlanks = JSON.stringify([
    { id: "b1", correct: "\"TweenService\"", options: ["\"TweenService\"", "\"SoundService\"", "\"RunService\"", "\"Players\""] },
    { id: "b2", correct: "TweenInfo.new(duration)", options: ["TweenInfo.new(duration)", "Info.new(2)", "TweenInfo(2)", "TweenInfo.new()"] },
    { id: "b3", correct: "{Volume = targetVolume}", options: ["{Volume = targetVolume}", "{volume = target}", "{Sound.Volume = 1}", "Volume = targetVolume"] },
    { id: "b4", correct: "tween:Play()", options: ["tween:Play()", "tween:Start()", "tween:Run()", "tween:Begin()"] }
]);
const fadeTemplate = `-- ========================================
-- 🎵 부드럽게 볼륨 올리면서 BGM 시작 (페이드인)
-- ========================================
-- 📦 준비: SoundService > Sound("BGM") + LocalScript
-- 💡 TweenService = 숫자를 부드럽게 변화시켜주는 서비스
-- 💡 Volume을 0→목표값으로 서서히 올려 자연스럽게 들리게!
-- ========================================

-- 💡 두 서비스 모두 가져오기
local TweenService = game:GetService([b1])
local SoundService = game:GetService("SoundService")

-- 💡 SoundService 안의 BGM 사운드
local bgm = SoundService:WaitForChild("BGM")

-- 💡 페이드인 함수: 볼륨을 0부터 서서히 올리기
local function fadeIn(sound, targetVolume, duration)
    sound.Volume = 0  -- 💡 처음엔 소리 0
    sound:Play()       -- 💡 재생 시작 (들리지 않음)

    -- 💡 TweenInfo: 몇 초 동안 변화할지 설정
    local tweenInfo = [b2]

    -- 💡 Volume을 targetVolume까지 부드럽게 올리기
    local tween = TweenService:Create(sound, tweenInfo, [b3])
    [b4]  -- 💡 Tween 시작!
end

-- 💡 2초 동안 부드럽게 볼륨 0.5까지 올리기
fadeIn(bgm, 0.5, 2)
print("🎵 BGM 페이드인 시작!")`;
const fadeFullCode = `-- 🎵 TweenService 볼륨 페이드인/아웃
-- 📦 SoundService > Sound("BGM") + LocalScript
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")
local bgm = SoundService:WaitForChild("BGM")

local function fadeIn(sound, targetVolume, duration)
    sound.Volume = 0
    sound:Play()
    local tween = TweenService:Create(sound, TweenInfo.new(duration), {Volume = targetVolume})
    tween:Play()
end

local function fadeOut(sound, duration)
    local tween = TweenService:Create(sound, TweenInfo.new(duration), {Volume = 0})
    tween:Play()
    tween.Completed:Wait()
    sound:Stop()
end

fadeIn(bgm, 0.5, 2)`;

// 퀴즈 2: 존(Zone) 기반 BGM 자동 전환
const zoneBlanks = JSON.stringify([
    { id: "b1", correct: "\"currentBGM\"", options: ["\"currentBGM\"", "\"bgm\"", "\"music\"", "\"sound\""] },
    { id: "b2", correct: "currentBGM ~= newBGM", options: ["currentBGM ~= newBGM", "currentBGM == newBGM", "currentBGM = newBGM", "newBGM ~= nil"] },
    { id: "b3", correct: "currentBGM:Stop()", options: ["currentBGM:Stop()", "currentBGM:Pause()", "currentBGM = nil", "currentBGM:Destroy()"] },
    { id: "b4", correct: "Touched", options: ["Touched", "TouchEnded", "MouseClick", "Triggered"] }
]);
const zoneTemplate = `-- ========================================
-- 🗺️ 구역마다 다른 배경음악 자동 재생!
-- ========================================
-- 📦 준비:
--   SoundService > ForestBGM, CaveBGM (각각 SoundId 설정)
--   Workspace > ForestZone (Part, Anchored, CanCollide=false, Transparency=0.8)
--   Workspace > CaveZone  (Part, Anchored, CanCollide=false, Transparency=0.8)
--   ServerScript 또는 LocalScript
-- 💡 투명한 파트를 밟으면 BGM이 바뀜!
-- ========================================

local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")

-- 💡 현재 재생 중인 BGM을 추적 (처음엔 없음)
local [b1] = nil

-- 💡 BGM 부드럽게 전환 함수
local function switchBGM(newBGM)
    -- 💡 지금이랑 다른 BGM일 때만 전환!
    if [b2] then
        if currentBGM then
            -- 💡 현재 음악 0.5초에 걸쳐 꺼주기
            [b3]
        end
        -- 💡 새 BGM 0.5초에 걸쳐 켜주기
        newBGM.Volume = 0
        newBGM:Play()
        TweenService:Create(newBGM, TweenInfo.new(0.5), {Volume = 0.5}):Play()
        currentBGM = newBGM
    end
end

-- 💡 숲 구역 파트를 밟으면 숲 BGM 재생!
local forestZone = workspace:WaitForChild("ForestZone")
local forestBGM = SoundService:WaitForChild("ForestBGM")

forestZone.[b4]:Connect(function(hit)
    local player = game.Players:GetPlayerFromCharacter(hit.Parent)
    if player then
        switchBGM(forestBGM)
    end
end)`;
const zoneFullCode = `-- 🗺️ 존 기반 BGM 전환 시스템
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")
local currentBGM = nil

local function switchBGM(newBGM)
    if currentBGM ~= newBGM then
        if currentBGM then
            TweenService:Create(currentBGM, TweenInfo.new(0.5), {Volume = 0}):Play()
            task.delay(0.5, function() currentBGM:Stop() end)
        end
        newBGM.Volume = 0
        newBGM:Play()
        TweenService:Create(newBGM, TweenInfo.new(0.5), {Volume = 0.5}):Play()
        currentBGM = newBGM
    end
end

local forestZone = workspace:WaitForChild("ForestZone")
local forestBGM = SoundService:WaitForChild("ForestBGM")
forestZone.Touched:Connect(function(hit)
    if game.Players:GetPlayerFromCharacter(hit.Parent) then
        switchBGM(forestBGM)
    end
end)`;

// 퀴즈 3: 3D 공간 사운드 (RollOffMaxDistance)
const spatialBlanks = JSON.stringify([
    { id: "b1", correct: "Instance.new(\"Sound\")", options: ["Instance.new(\"Sound\")", "Instance.new(\"Audio\")", "game:GetService(\"Sound\")", "Sound.new()"] },
    { id: "b2", correct: "waterfall", options: ["waterfall", "workspace", "SoundService", "game"] },
    { id: "b3", correct: "RollOffMaxDistance", options: ["RollOffMaxDistance", "Volume", "MaxDistance", "PlaybackDistance"] },
    { id: "b4", correct: "sound:Play()", options: ["sound:Play()", "sound:Start()", "sound.Looped = true", "sound:Resume()"] }
]);
const spatialTemplate = `-- ========================================
-- 🌊 가까이 가면 들리는 3D 공간 사운드!
-- ========================================
-- 📦 준비: Workspace > Waterfall (Part, Anchored) + Script
-- 💡 파트에 Sound를 붙이면 3D 위치 기반으로 들림!
-- 💡 가까울수록 크게, 멀어질수록 작게 들림
-- ========================================

-- 💡 스크립트가 붙어있는 폭포 파트
local waterfall = script.Parent

-- 💡 파트 안에 Sound를 동적으로 생성!
local sound = [b1]

-- 💡 사운드를 폭포 파트의 자식으로 설정 (3D 위치 고정)
sound.Parent = [b2]

-- 💡 사운드 에셋 ID (로블록스 오디오 에셋)
sound.SoundId = "rbxassetid://136523485"

-- 💡 멀어질수록 소리 줄어드는 최대 거리 (스터드 단위)
sound.[b3] = 60   -- 💡 60스터드 밖에선 안 들림

-- 💡 가장 가까운 거리에서의 최대 볼륨 거리
sound.RollOffMinDistance = 5

-- 💡 반복 재생 + 시작!
sound.Looped = true
[b4]
print("🌊 폭포 소리 시작! 가까이 다가가보세요~")`;
const spatialFullCode = `-- 🌊 3D 공간 사운드 (파트에 붙이기)
-- 📦 Workspace > Waterfall (Part) + Script
local waterfall = script.Parent
local sound = Instance.new("Sound")
sound.Parent = waterfall
sound.SoundId = "rbxassetid://136523485"
sound.RollOffMaxDistance = 60  -- 60스터드 밖에선 안 들림
sound.RollOffMinDistance = 5
sound.Looped = true
sound:Play()`;

// 퀴즈 4: 발소리 속도 동기화 (Humanoid.Running)
const footstepBlanks = JSON.stringify([
    { id: "b1", correct: "\"Humanoid\"", options: ["\"Humanoid\"", "\"HumanoidRootPart\"", "\"Character\"", "\"Player\""] },
    { id: "b2", correct: "humanoid.Running", options: ["humanoid.Running", "humanoid.Touched", "humanoid.Walking", "character.Running"] },
    { id: "b3", correct: "speed / 14", options: ["speed / 14", "speed * 2", "speed / 2", "speed + 1"] },
    { id: "b4", correct: "0", options: ["0", "1", "nil", "false"] }
]);
const footstepTemplate = `-- ========================================
-- 👟 달릴수록 빨라지는 발소리!
-- ========================================
-- 📦 준비:
--   StarterCharacterScripts > LocalScript
--   HumanoidRootPart 안에 Sound("Footstep") 추가
--   Sound에 발소리 에셋ID 설정, Looped = true
-- 💡 Humanoid.Running = 이동 속도가 바뀔 때마다 발동!
-- 💡 PlaybackSpeed = 사운드 재생 속도 (1 = 정상, 2 = 2배 빠름)
-- ========================================

-- 💡 캐릭터가 스폰될 때 실행 (LocalScript는 캐릭터 안에서 시작)
local character = script.Parent
local humanoid = character:WaitForChild([b1])

-- 💡 캐릭터의 몸 중심 파트에서 발소리 찾기
local rootPart = character:WaitForChild("HumanoidRootPart")
local footstep = rootPart:WaitForChild("Footstep")

-- 💡 Humanoid.Running: 이동 속도(speed)를 계속 알려줌!
[b2]:Connect(function(speed)
    if speed > 0 then
        -- 💡 속도에 비례해서 발소리 속도 설정 (16 / 14 ≈ 1.14배)
        footstep.PlaybackSpeed = [b3]
        if not footstep.IsPlaying then
            footstep:Play()
        end
    else
        -- 💡 멈추면 발소리 속도를 0으로 (정지)
        footstep.PlaybackSpeed = [b4]
        footstep:Stop()
    end
end)`;
const footstepFullCode = `-- 👟 발소리 속도 동기화 (StarterCharacterScripts > LocalScript)
-- 📦 HumanoidRootPart > Sound("Footstep", Looped=true)
local character = script.Parent
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local footstep = rootPart:WaitForChild("Footstep")

humanoid.Running:Connect(function(speed)
    if speed > 0 then
        footstep.PlaybackSpeed = speed / 14
        if not footstep.IsPlaying then footstep:Play() end
    else
        footstep.PlaybackSpeed = 0
        footstep:Stop()
    end
end)`;

// 퀴즈 5: 승리 효과음 피치 업 (PlaybackSpeed TweenService)
const pitchBlanks = JSON.stringify([
    { id: "b1", correct: "winSound:Play()", options: ["winSound:Play()", "winSound:Start()", "winSound:Resume()", "winSound:Begin()"] },
    { id: "b2", correct: "TweenInfo.new(2, Enum.EasingStyle.Quad)", options: ["TweenInfo.new(2, Enum.EasingStyle.Quad)", "TweenInfo.new(2)", "TweenInfo.new(2, Linear)", "Info.new(2, Quad)"] },
    { id: "b3", correct: "{PlaybackSpeed = 2.0}", options: ["{PlaybackSpeed = 2.0}", "{Speed = 2.0}", "{Pitch = 2.0}", "{Volume = 2.0}"] },
    { id: "b4", correct: "pitchTween:Play()", options: ["pitchTween:Play()", "pitchTween:Start()", "pitchTween:Run()", "pitchTween:Begin()"] }
]);
const pitchTemplate = `-- ========================================
-- 🏆 승리 시 피치가 점점 올라가는 효과음!
-- ========================================
-- 📦 준비: SoundService > WinSound (승리 효과음 에셋ID)
--         ServerScriptService > Script
-- 💡 PlaybackSpeed = 1.0(기본) → 2.0(2배 높은 음)
-- 💡 TweenService로 부드럽게 피치 올리기
-- ========================================

local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")

-- 💡 승리 효과음 가져오기
local winSound = SoundService:WaitForChild("WinSound")

-- 💡 플레이어가 골인 파트에 닿으면!
local goalPart = workspace:WaitForChild("GoalPart")
goalPart.Touched:Connect(function(hit)
    if game.Players:GetPlayerFromCharacter(hit.Parent) then
        -- 💡 피치를 0.8에서 시작 (약간 낮게)
        winSound.PlaybackSpeed = 0.8
        -- 💡 승리 효과음 재생!
        [b1]

        -- 💡 Quad 이징: 처음엔 천천히, 나중엔 빠르게
        local tweenInfo = [b2]

        -- 💡 PlaybackSpeed를 2.0까지 올려서 피치 업 효과!
        local pitchTween = TweenService:Create(winSound, tweenInfo, [b3])
        -- 💡 Tween 시작!
        [b4]

        print("🏆 승리! 피치 업 효과 재생!")
    end
end)`;
const pitchFullCode = `-- 🏆 승리 사운드 피치 업 효과
-- 📦 SoundService > WinSound + Script (ServerScriptService)
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")
local winSound = SoundService:WaitForChild("WinSound")
local goalPart = workspace:WaitForChild("GoalPart")

goalPart.Touched:Connect(function(hit)
    if game.Players:GetPlayerFromCharacter(hit.Parent) then
        winSound.PlaybackSpeed = 0.8
        winSound:Play()
        local pitchTween = TweenService:Create(
            winSound,
            TweenInfo.new(2, Enum.EasingStyle.Quad),
            {PlaybackSpeed = 2.0}
        )
        pitchTween:Play()
    end
end)`;

// 퀴즈 5: RemoteFunction 구매 요청
const shopBlanks = JSON.stringify([
    { id: "b1", correct: "\"PurchaseItem\"", options: ["\"PurchaseItem\"", "\"BuyItem\"", "\"ShopEvent\"", "\"Purchase\""] },
    { id: "b2", correct: "purchaseRF:InvokeServer(item.id)", options: ["purchaseRF:InvokeServer(item.id)", "purchaseRF:FireServer(item.id)", "purchaseRF:Send(item.id)", "purchaseRF:Call(item.id)"] },
    { id: "b3", correct: "success", options: ["success", "result", "ok", "status"] },
    { id: "b4", correct: "msg", options: ["msg", "message", "text", "info"] }
]);
const shopTemplate = `-- ========================================
-- 🏪 상점 구매 버튼 (LocalScript)
-- ========================================
-- 💡 RemoteFunction = 클라이언트→서버 요청 후 결과 받기
-- 💡 InvokeServer = 서버에 물어보고 답장 기다리기
-- ========================================

-- 💡 서버에서 만들어놓은 RemoteFunction 가져오기
local purchaseRF = ReplicatedStorage:WaitForChild([b1])

-- 💡 구매 버튼 클릭!
buyBtn.MouseButton1Click:Connect(function()
    buyBtn.Text = "..."   -- 💡 처리 중 표시
    buyBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)

    -- 💡 서버에 구매 요청! 결과가 올 때까지 기다림
    local [b3], [b4] = [b2]

    -- 💡 성공/실패 메시지 표시
    if success then
        resultLabel.Text = "✓ " .. msg
    else
        resultLabel.Text = "✗ " .. msg
    end

    task.wait(0.5)
    buyBtn.Text = "구매"   -- 💡 버튼 복원
end)`;
const shopFullCode = `local purchaseRF = ReplicatedStorage:WaitForChild("PurchaseItem")

buyBtn.MouseButton1Click:Connect(function()
    buyBtn.Text = "..."
    buyBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    local success, msg = purchaseRF:InvokeServer(item.id)
    if success then
        resultLabel.Text = "✓ " .. msg
    else
        resultLabel.Text = "✗ " .. msg
    end
    task.wait(0.5)
    buyBtn.Text = "구매"
    buyBtn.BackgroundColor3 = Color3.fromRGB(40, 90, 200)
end)`;

// 퀴즈 6: 스택 효과 시스템
const stackBlanks = JSON.stringify([
    { id: "b1", correct: "task.cancel(effect.thread)", options: ["task.cancel(effect.thread)", "effect.thread:Stop()", "thread.cancel()", "task.stop(effect.thread)"] },
    { id: "b2", correct: "effect.stacks + 1", options: ["effect.stacks + 1", "effect.stacks", "stacks + 1", "effect.stacks * 2"] },
    { id: "b3", correct: "16 * (1 + effect.stacks)", options: ["16 * (1 + effect.stacks)", "16 + effect.stacks", "16 * effect.stacks", "16 + (effect.stacks * 16)"] },
    { id: "b4", correct: "task.delay(300, function()", options: ["task.delay(300, function()", "task.wait(300)", "wait(300)", "task.spawn(300, function()"] }
]);
const stackTemplate = `-- ========================================
-- 🔥 스택 효과 시스템 (5분 중첩)
-- ========================================
-- 💡 stacks = 쌓인 횟수 (구매마다 +1)
-- 💡 thread = 5분 타이머 (새 구매 시 리셋!)
-- ========================================

local effect = getEffect(player, itemId)

-- 💡 기존 타이머가 있으면 취소해서 리셋!
if effect.thread then
    [b1]   -- 기존 타이머 취소
    effect.thread = nil
end

-- 💡 스택 1 추가
effect.stacks = [b2]

-- 💡 스택 수 × 기본값으로 능력치 설정
-- 예) 2중첩 → WalkSpeed = 16 × (1 + 2) = 48
humanoid.WalkSpeed = [b3]

-- 💡 5분(300초) 후 효과 초기화 타이머
effect.thread = [b4]
    effect.stacks = 0        -- 스택 리셋
    humanoid.WalkSpeed = 16  -- 원래 속도로
end)`;
const stackFullCode = `local effect = getEffect(player, itemId)
if effect.thread then
    task.cancel(effect.thread)
    effect.thread = nil
end
effect.stacks = effect.stacks + 1
humanoid.WalkSpeed = 16 * (1 + effect.stacks)
effect.thread = task.delay(300, function()
    effect.stacks = 0
    humanoid.WalkSpeed = 16
end)`;

const shopQuiz5Options = JSON.stringify(["RemoteFunction", "RemoteEvent", "BindableFunction", "BindableEvent"]);
const shopQuiz6Options = JSON.stringify(["task.cancel()", "task.stop()", "task.kill()", "task.clear()"]);
