    <!-- 슬라이드 2: TweenService 볼륨 페이드 개념 -->
    <section class="slide">
        <div class="max-w-4xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">개념 1</span>
            <h2 class="title-section mb-6">🎵 TweenService로 볼륨 페이드</h2>

            <div class="grid grid-cols-2 gap-6 mb-6">
                <div>
                    <p class="text-gray-300 mb-4">
                        게임에서 BGM이 갑자기 <strong class="text-neon-coral">뚝!</strong> 켜지거나 꺼지면 어색하다.
                        프로 게임들은 <strong class="text-neon-mint">TweenService</strong>를 이용해 볼륨을 <em>서서히</em> 올리거나 내린다.
                    </p>
