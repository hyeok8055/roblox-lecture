---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';

// 확인 퀴즈 옵션
const quiz1Options = JSON.stringify(["SoundService", "Workspace", "StarterGui", "ReplicatedStorage"]);
const quiz2Options = JSON.stringify([":Play()", ":Stop()", ":Pause()", ":Resume()"]);
const quiz3Options = JSON.stringify(["Ended", "Played", "Stopped", "DidLoop"]);
const quiz4Options = JSON.stringify(["#musicList", "3", "musicList", "math.max()"]);

// =========================================
// 드롭다운 퀴즈 데이터 (5개)
// =========================================

// 퀴즈 1: BGM 기본 설정
const bgmSetupBlanks = JSON.stringify([
    { id: "b1", correct: "\"SoundService\"", options: ["\"SoundService\"", "\"Workspace\"", "\"Players\"", "\"ServerScriptService\""] },
    { id: "b2", correct: "\"BGM\"", options: ["\"BGM\"", "\"Sound\"", "\"Music\"", "\"Audio\""] },
    { id: "b3", correct: "true", options: ["true", "false", "0", "nil"] }
]);
const bgmSetupTemplate = `-- ========================================
-- 🎵 배경음악(BGM) 루프 재생 설정
-- ========================================
-- 📦 준비: SoundService 안에 Sound 오브젝트 추가 후 이름 "BGM"으로 변경
-- 💡 SoundService = 어디서든 동일한 음량으로 들리는 특수 서비스
-- 💡 Looped = 끝나면 자동으로 처음부터 반복할지 여부
-- ========================================

-- 💡 SoundService 서비스 가져오기
local SoundService = game:GetService([b1])

-- 💡 SoundService 안에 미리 만들어둔 BGM 사운드 찾기
local bgm = SoundService:WaitForChild([b2])

-- 💡 true = 끝나면 자동으로 다시 처음부터 재생!
bgm.Looped = [b3]

-- 💡 재생 시작!
bgm:Play()
print("🎵 배경음악 시작!")`;
const bgmSetupFullCode = `-- 🎵 BGM 루프 재생
-- 📦 SoundService > Sound("BGM") + LocalScript
local SoundService = game:GetService("SoundService")
local bgm = SoundService:WaitForChild("BGM")
bgm.Looped = true
bgm:Play()`;

// 퀴즈 2: BGM 볼륨 조절 (LocalScript)
const bgmVolumeBlanks = JSON.stringify([
    { id: "b1", correct: "\"SoundService\"", options: ["\"SoundService\"", "\"Workspace\"", "\"Players\"", "\"game\""] },
    { id: "b2", correct: "0.25", options: ["0.25", "1", "5", "10"] },
    { id: "b3", correct: ":Play()", options: [":Play()", ":Stop()", ":Pause()", ":Resume()"] }
]);
const bgmVolumeTemplate = `-- ========================================
-- 🎛️ BGM 볼륨 조절 (LocalScript)
-- ========================================
-- 📦 준비: StarterPlayerScripts > LocalScript
-- 💡 LocalScript = 각 플레이어의 컴퓨터에서만 실행됨
-- 💡 Volume = 음량 (0 ~ 10, 배경음은 0.25가 딱 좋음!)
-- 💡 너무 크면 효과음이 안 들리고 집중도 방해됨
-- ========================================

-- 💡 SoundService 가져오기
local SoundService = game:GetService([b1])
local bgm = SoundService:WaitForChild("BGM")

-- 💡 볼륨 설정! (배경음악은 낮게 = 0.25 추천)
bgm.Volume = [b2]
bgm.Looped = true

-- 💡 재생!
bgm[b3]
print("🎵 배경음악 재생 중! 볼륨:", bgm.Volume)`;
const bgmVolumeFullCode = `-- 🎛️ BGM 볼륨 조절
-- 📦 StarterPlayerScripts > LocalScript
local SoundService = game:GetService("SoundService")
local bgm = SoundService:WaitForChild("BGM")
bgm.Volume = 0.25
bgm.Looped = true
bgm:Play()`;

// 퀴즈 3: 코인 효과음
const coinSoundBlanks = JSON.stringify([
    { id: "b1", correct: "\"CoinSound\"", options: ["\"CoinSound\"", "\"Sound\"", "\"Effect\"", "\"Audio\""] },
    { id: "b2", correct: "\"Humanoid\"", options: ["\"Humanoid\"", "\"Character\"", "\"Part\"", "\"Player\""] },
    { id: "b3", correct: ":Play()", options: [":Play()", ":Stop()", ":Pause()", ":Resume()"] }
]);
const coinSoundTemplate = `-- ========================================
-- 🪙 코인 먹으면 효과음 재생!
-- ========================================
-- 📦 준비: 코인 Part > Script + Sound("CoinSound")
-- 💡 코인 파트 안에 Sound 오브젝트를 미리 넣어두세요
-- 💡 SoundId 예시: rbxassetid://4590662766 (코인 짤랑)
-- 💡 sound.Ended:Wait() = 소리가 끝날 때까지 기다림
-- ========================================

local coin = script.Parent
-- 💡 코인 안에 있는 CoinSound 찾기
local sound = coin:WaitForChild([b1])
local collected = false  -- 💡 중복 실행 방지

coin.Touched:Connect(function(hit)
    -- 💡 이미 먹었으면 무시
    if collected then return end

    -- 💡 사람인지 확인 (Humanoid가 있는지)
    local humanoid = hit.Parent:FindFirstChild([b2])
    if humanoid then
        collected = true

        -- 💡 효과음 재생!
        sound[b3]

        -- 💡 코인 일단 숨기기 (소리는 계속 들려야 하니까)
        coin.Transparency = 1
        coin.CanCollide = false

        -- 💡 소리가 끝나면 코인 제거!
        sound.Ended:Wait()
        coin:Destroy()
    end
end)`;
const coinSoundFullCode = `-- 🪙 코인 효과음
-- 📦 코인 Part > Script + Sound("CoinSound")
local coin = script.Parent
local sound = coin:WaitForChild("CoinSound")
local collected = false

coin.Touched:Connect(function(hit)
    if collected then return end
    local humanoid = hit.Parent:FindFirstChild("Humanoid")
    if humanoid then
        collected = true
        sound:Play()
        coin.Transparency = 1
        coin.CanCollide = false
        sound.Ended:Wait()
        coin:Destroy()
    end
end)`;

// 퀴즈 4: 랜덤 BGM 재생
const randomBgmBlanks = JSON.stringify([
    { id: "b1", correct: "#musicList", options: ["#musicList", "3", "musicList", "10"] },
    { id: "b2", correct: "musicList[randomIndex]", options: ["musicList[randomIndex]", "musicList", "randomIndex", "musicList[1]"] },
    { id: "b3", correct: "Ended", options: ["Ended", "Played", "Stopped", "DidLoop"] }
]);
const randomBgmTemplate = `-- ========================================
-- 🎲 여러 BGM 중 랜덤으로 재생하기
-- ========================================
-- 📦 준비: StarterPlayerScripts > LocalScript
-- 💡 musicList = 여러 BGM ID를 담은 표(table)
-- 💡 #musicList = 표 안에 있는 항목 개수 (자동으로 셈!)
-- 💡 bgm.Ended = 곡이 끝났을 때 발생하는 이벤트
-- ========================================

local SoundService = game:GetService("SoundService")

-- 💡 배경음악 에셋 ID 목록 (원하는 ID로 바꿔보세요!)
local musicList = {
    "rbxassetid://1843463175",   -- 💡 첫 번째 곡
    "rbxassetid://1837849285",   -- 💡 두 번째 곡
    "rbxassetid://1848183670",   -- 💡 세 번째 곡
}

-- 💡 Sound 오브젝트 만들기
local bgm = Instance.new("Sound")
bgm.Parent = SoundService
bgm.Volume = 0.25

-- 💡 랜덤 곡 재생 함수
local function playRandomMusic()
    -- 💡 1 ~ musicList 개수 중 랜덤 숫자 선택!
    local randomIndex = math.random(1, [b1])
    -- 💡 그 번호에 해당하는 음악 ID 설정
    bgm.SoundId = [b2]
    bgm:Play()
    print("🎵 " .. randomIndex .. "번 곡 재생!")
end

-- 💡 처음 재생
playRandomMusic()

-- 💡 곡이 끝나면 자동으로 다음 랜덤 곡!
bgm.[b3]:Connect(function()
    playRandomMusic()
end)`;
const randomBgmFullCode = `-- 🎲 랜덤 BGM 재생
-- 📦 StarterPlayerScripts > LocalScript
local SoundService = game:GetService("SoundService")
local musicList = {
    "rbxassetid://1843463175",
    "rbxassetid://1837849285",
    "rbxassetid://1848183670",
}
local bgm = Instance.new("Sound")
bgm.Parent = SoundService
bgm.Volume = 0.25

local function playRandomMusic()
    local randomIndex = math.random(1, #musicList)
    bgm.SoundId = musicList[randomIndex]
    bgm:Play()
end

playRandomMusic()
bgm.Ended:Connect(function()
    playRandomMusic()
end)`;

// 퀴즈 5: SoundGroup 분리 관리
const soundGroupBlanks = JSON.stringify([
    { id: "b1", correct: "\"SoundGroup\"", options: ["\"SoundGroup\"", "\"Folder\"", "\"Sound\"", "\"AudioGroup\""] },
    { id: "b2", correct: "SoundService", options: ["SoundService", "workspace", "game", "script"] },
    { id: "b3", correct: "sfxGroup", options: ["sfxGroup", "bgmGroup", "SoundService", "sound"] }
]);
const soundGroupTemplate = `-- ========================================
-- 🎛️ SoundGroup으로 BGM / 효과음 분리 관리
-- ========================================
-- 📦 준비: ServerScriptService > Script
-- 💡 SoundGroup = 소리들을 그룹으로 묶어서 한번에 음량 조절!
-- 💡 bgmGroup.Volume = 0.3 → BGM 전체 30% 볼륨
-- 💡 sfxGroup.Volume = 0.7 → 효과음 전체 70% 볼륨
-- ========================================

local SoundService = game:GetService("SoundService")

-- 💡 BGM 그룹 만들기!
local bgmGroup = Instance.new([b1])
bgmGroup.Name = "BGM_Group"
bgmGroup.Volume = 0.3
bgmGroup.Parent = [b2]

-- 💡 효과음(SFX) 그룹 만들기!
local sfxGroup = Instance.new("SoundGroup")
sfxGroup.Name = "SFX_Group"
sfxGroup.Volume = 0.7
sfxGroup.Parent = SoundService

-- 💡 코인 효과음을 SFX 그룹에 연결하기
local coinSfx = Instance.new("Sound")
coinSfx.SoundId = "rbxassetid://4590662766"
-- 💡 SoundGroup 속성에 그룹을 지정! (Parent가 아니라 SoundGroup 속성으로!)
coinSfx.SoundGroup = [b3]
coinSfx.Parent = SoundService

print("🎛️ BGM 그룹 볼륨:", bgmGroup.Volume)
print("🔊 SFX 그룹 볼륨:", sfxGroup.Volume)`;
const soundGroupFullCode = `-- 🎛️ SoundGroup 분리 관리
-- 📦 ServerScriptService > Script
local SoundService = game:GetService("SoundService")

local bgmGroup = Instance.new("SoundGroup")
bgmGroup.Name = "BGM_Group"
bgmGroup.Volume = 0.3
bgmGroup.Parent = SoundService

local sfxGroup = Instance.new("SoundGroup")
sfxGroup.Name = "SFX_Group"
sfxGroup.Volume = 0.7
sfxGroup.Parent = SoundService

local coinSfx = Instance.new("Sound")
coinSfx.SoundId = "rbxassetid://4590662766"
coinSfx.SoundGroup = sfxGroup
coinSfx.Parent = SoundService`;
---

<LessonLayout title="사운드 시스템: 배경음 & 효과음" lessonNumber={10} totalSlides={15}>
    <!-- 슬라이드 1: 인트로 -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">10주차 A</span>
                <h1 class="title-display mb-4">
                    사운드 시스템:<br>
                    <span class="text-neon-mint">🎵 배경음 & 효과음!</span>
                </h1>
                <p class="text-xl text-ink-light max-w-lg mx-auto mb-8">
                    배경음악(BGM)을 삽입하고<br>
                    코인 효과음, 랜덤 음악 시스템을 만들어요!
                </p>
                <div class="flex gap-3 justify-center flex-wrap">
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🎵 Sound 클래스</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🔊 SoundService</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🔁 Looped BGM</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🎲 랜덤 음악</span>
                    </div>
                    <div class="px-4 py-2 bg-ink-pale rounded-full text-sm">
                        <span class="font-bold">🎛️ SoundGroup</span>
                    </div>
                </div>

                <div class="mt-12 p-6 bg-gradient-to-r from-purple-50 to-blue-50 rounded-2xl max-w-md mx-auto">
                    <div class="text-3xl mb-2">🎯</div>
                    <h3 class="font-bold mb-2">오늘의 목표</h3>
                    <ul class="text-left text-sm text-ink-light space-y-1">
                        <li>✓ Sound 클래스 속성 이해 (SoundId, Volume, Looped)</li>
                        <li>✓ SoundService에 BGM 삽입해서 루프 재생</li>
                        <li>✓ 코인 파트에 효과음 연결</li>
                        <li>✓ 여러 BGM 중 랜덤 재생하기</li>
                        <li>✓ SoundGroup으로 BGM/효과음 분리 관리</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 슬라이드 2: Sound 클래스 속성 -->
    <section class="slide">
        <div class="max-w-4xl mx-auto px-6 py-12">
            <div class="animate-in">
                <span class="badge badge-lesson mb-4">개념 학습</span>
                <h2 class="title-section mb-6">🎵 Sound 오브젝트란?</h2>
            </div>

            <div class="flex flex-col gap-6">
                <div class="animate-in">
                    <div class="lesson-card">
                        <h3 class="font-bold text-lg mb-4">핵심 속성 4가지</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm border-collapse">
                                <thead>
                                    <tr class="bg-ink-pale">
                                        <th class="text-left p-3 rounded-tl-lg font-bold">속성명</th>
                                        <th class="text-left p-3 font-bold">기본값</th>
                                        <th class="text-left p-3 rounded-tr-lg font-bold">설명</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-b border-gray-100">
                                        <td class="p-3 font-mono text-neon-sky font-bold">SoundId</td>
                                        <td class="p-3 text-ink-light">""</td>
                                        <td class="p-3">재생할 음악 에셋 ID<br><span class="text-xs text-ink-light">rbxassetid://숫자 형식</span></td>
                                    </tr>
                                    <tr class="border-b border-gray-100 bg-gray-50">
                                        <td class="p-3 font-mono text-neon-sky font-bold">Volume</td>
                                        <td class="p-3 text-ink-light">0.5</td>
                                        <td class="p-3">음량 (0 ~ 10)<br><span class="text-xs text-ink-light">BGM은 0.25, 효과음은 0.7 권장</span></td>
                                    </tr>
                                    <tr class="border-b border-gray-100">
                                        <td class="p-3 font-mono text-neon-sky font-bold">Looped</td>
                                        <td class="p-3 text-ink-light">false</td>
                                        <td class="p-3">반복 재생 여부<br><span class="text-xs text-ink-light">BGM은 true로 설정!</span></td>
                                    </tr>
                                    <tr class="border-b border-gray-100 bg-gray-50">
                                        <td class="p-3 font-mono text-neon-sky font-bold">PlaybackSpeed</td>
                                        <td class="p-3 text-ink-light">1.0</td>
                                        <td class="p-3">재생 속도 (높으면 음조도 올라감)<br><span class="text-xs text-ink-light">2.0 = 2배 빠르고 고음, 0.5 = 느리고 저음</span></td>
                                    </tr>
                                    <tr>
                                        <td class="p-3 font-mono text-neon-sky font-bold">IsPlaying</td>
                                        <td class="p-3 text-ink-light">false (읽기전용)</td>
                                        <td class="p-3">현재 재생 중인지 확인용<br><span class="text-xs text-ink-light">if sound.IsPlaying then ... end</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="animate-in grid md:grid-cols-3 gap-4">
                    <div class="lesson-card text-center">
                        <div class="text-3xl mb-2">▶️</div>
                        <div class="font-bold font-mono text-sm mb-1">sound:Play()</div>
                        <p class="text-xs text-ink-light">재생 시작</p>
                    </div>
                    <div class="lesson-card text-center">
                        <div class="text-3xl mb-2">⏸️</div>
                        <div class="font-bold font-mono text-sm mb-1">sound:Pause()</div>
                        <p class="text-xs text-ink-light">일시정지</p>
                    </div>
                    <div class="lesson-card text-center">
                        <div class="text-3xl mb-2">⏹️</div>
                        <div class="font-bold font-mono text-sm mb-1">sound:Stop()</div>
                        <p class="text-xs text-ink-light">정지 + 처음으로</p>
                    </div>
                </div>

                <HintBox type="info" title="Sound 이벤트">
                    <code>sound.Ended</code> → 곡이 끝났을 때 발생<br>
                    <code>sound.DidLoop</code> → 루프가 한 번 완료될 때마다 발생<br>
                    <code>sound.Played</code> → Play() 호출 시 발생
                </HintBox>
            </div>
        </div>
    </section>

    <!-- 슬라이드 3: 배치 위치 차이 -->
    <section class="slide">
        <div class="max-w-4xl mx-auto px-6 py-12">
            <div class="animate-in">
                <span class="badge badge-lesson mb-4">핵심 개념</span>
                <h2 class="title-section mb-6">🗺️ Sound를 어디에 넣어야 할까?</h2>
            </div>

            <div class="flex flex-col gap-5 animate-in">
                <div class="grid md:grid-cols-3 gap-4">
                    <div class="lesson-card border-2 border-neon-mint">
                        <div class="text-center mb-3">
                            <div class="text-3xl mb-1">🔊</div>
                            <div class="font-bold text-neon-mint">SoundService</div>
                        </div>
                        <p class="text-sm text-ink-light mb-3">어디서나 <strong>같은 음량</strong>으로 들림</p>
                        <div class="bg-green-50 rounded-lg p-3 text-xs">
                            ✅ 배경음악(BGM)<br>
                            ✅ UI 클릭음<br>
                            ✅ 전역 이펙트음
                        </div>
                    </div>
                    <div class="lesson-card border-2 border-neon-sky">
                        <div class="text-center mb-3">
                            <div class="text-3xl mb-1">🌍</div>
                            <div class="font-bold text-neon-sky">Workspace</div>
                        </div>
                        <p class="text-sm text-ink-light mb-3">플레이어와 <strong>거리에 따라</strong> 음량 변화</p>
                        <div class="bg-blue-50 rounded-lg p-3 text-xs">
                            ✅ 폭포 소리<br>
                            ✅ 공간 환경음<br>
                            ✅ 거리 기반 이벤트
                        </div>
                    </div>
                    <div class="lesson-card border-2 border-neon-gold">
                        <div class="text-center mb-3">
                            <div class="text-3xl mb-1">📦</div>
                            <div class="font-bold text-neon-gold">Part 안</div>
                        </div>
                        <p class="text-sm text-ink-light mb-3">그 파트 위치에서 <strong>3D 입체</strong>로 들림</p>
                        <div class="bg-yellow-50 rounded-lg p-3 text-xs">
                            ✅ 코인 효과음<br>
                            ✅ 함정 경고음<br>
                            ✅ NPC 대화음
                        </div>
                    </div>
                </div>

                <div class="lesson-card">
                    <h4 class="font-bold mb-3">📋 Explorer 트리 예시</h4>
                    <div class="grid md:grid-cols-2 gap-4 font-mono text-sm">
                        <div class="bg-green-50 rounded-lg p-4">
                            <div class="font-bold text-green-700 mb-2">BGM (배경음)</div>
                            <div class="text-xs space-y-1">
                                <div>📁 SoundService</div>
                                <div class="ml-4">🔊 Sound (이름: "BGM")</div>
                                <div class="ml-8 text-ink-light">Looped: ✓</div>
                                <div class="ml-8 text-ink-light">Volume: 0.25</div>
                            </div>
                        </div>
                        <div class="bg-yellow-50 rounded-lg p-4">
                            <div class="font-bold text-yellow-700 mb-2">효과음 (파트 안)</div>
                            <div class="text-xs space-y-1">
