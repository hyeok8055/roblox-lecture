            <lua-code-block title="canAllocate() — 클라이언트 판단용" show-line-numbers>
-- 노드 라벨 가져오기
local NODE_LABELS = &#123;
    spd1="속도+2%", spd2="속도+4%", spd3="속도+6%",
    spd4="속도+8%", spd5="속도+10%",
    jmp1="점프+3",  jmp2="점프+7",  jmp3="점프+10",
    jmp4="점프+15", jmp5="점프+20",
    coin1="코인+5%",  coin2="코인+10%", coin3="코인+15%",
    coin4="코인+20%", coin5="코인+25%",
    time1="시간+10초", time2="시간+15초", time3="시간+20초",
    time4="시간+30초", time5="시간+40초",
&#125;

local function getNodeLabel(nodeId)
    return NODE_LABELS[nodeId] or nodeId
end

local function canAllocate(nodeId, allocated)
    -- 이미 찍었으면 불가
    if allocated[nodeId] then return false end

    -- Tier 1이면 무조건 가능
    local tier = tonumber(string.sub(nodeId, -1))
    if tier == 1 then return true end

    -- 하위 티어가 찍혀있어야 함
    local prevId = string.sub(nodeId, 1, -2) .. (tier - 1)
    return allocated[prevId] == true
end
            </lua-code-block>

            <HintBox type="warning" title="클라이언트에서도 체크하는 이유">
                서버에서 최종 검증하지만, 클라이언트에서도 미리 체크하면<br>
                잠긴 노드 클릭 시 불필요한 서버 요청을 보내지 않습니다.
            </HintBox>
