-- =============================================
-- 서버 → 클라이언트 스텟 동기화
-- =============================================
StatSync.OnClientEvent:Connect(function(data)
    currentStatData = data
    updateTreeUI()

    -- XP 바 채움 업데이트
    if data.xpProgress then
        TweenService:Create(xpBarFill,
            TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            &#123; Size = UDim2.new(data.xpProgress, 0, 1, 0) &#125;
        ):Play()
    end

    -- 현재 XP 텍스트 업데이트
    if data.currentXP and data.requiredXP then
        xpText.Text = data.currentXP .. " / " .. data.requiredXP .. " XP"
    end

    -- 포인트가 있으면 레벨 라벨 녹색 발광
    if data.statPoints > 0 then
        levelLabel.TextColor3 = Color3.fromRGB(61, 255, 162)
        local glow = Instance.new("UIStroke")
        glow.Name = "PointGlow"
        glow.Color = Color3.fromRGB(61, 255, 162)
        glow.Thickness = 2
        glow.Parent = levelLabel
    else
        levelLabel.TextColor3 = Color3.new(1, 1, 1)
        local glow = levelLabel:FindFirstChild("PointGlow")
        if glow then glow:Destroy() end
    end
end)

-- 레벨업 알림
RoundInfo.OnClientEvent:Connect(function(eventType, ...)
    if eventType == "LevelUp" then
