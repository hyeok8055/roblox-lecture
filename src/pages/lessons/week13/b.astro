local currentStatData = &#123; statPoints = 0, allocated = &#123;&#125; &#125;

local function updateTreeUI()
    treeTitle.Text = "스텟 트리 ★ " .. currentStatData.statPoints .. " 포인트"

    for i, branch in BRANCHES do
        for tier = 1, 5 do
            local nodeId = branch.prefix .. tier
            local btn = nodeButtons[nodeId]
            if not btn then continue end

            if currentStatData.allocated[nodeId] then
                -- ✓ 투자 완료: 초록 배경
                btn.BackgroundColor3 = Color3.fromRGB(34, 197, 94)
                btn.TextColor3 = Color3.fromRGB(20, 16, 30)
                btn.Text = "✓ " .. branch.tiers[tier]

            elseif currentStatData.statPoints > 0
                and (tier == 1 or currentStatData.allocated[branch.prefix .. (tier-1)]) then
                -- + 투자 가능: 금색 테두리
                btn.BackgroundColor3 = Color3.fromRGB(40, 34, 55)
                btn.TextColor3 = Color3.fromRGB(255, 217, 61)
                btn.Text = "+ " .. branch.tiers[tier]

            else
                -- 잠김: 회색
                btn.BackgroundColor3 = Color3.fromRGB(30, 26, 42)
                btn.TextColor3 = Color3.fromRGB(80, 80, 80)
                btn.Text = branch.tiers[tier]
            end
        end
    end
end
