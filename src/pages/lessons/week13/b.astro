---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';
---

<LessonLayout title="TOH 스텟 트리 UI + 음악 플레이어" lessonNumber={13} totalSlides={22}>

    <!-- ==================== 슬라이드 1: 인트로 ==================== -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">13주차 B</span>
                <h1 class="title-display mb-4">
                    스텟 트리 UI<br>
                    <span class="text-neon-mint">&amp; 음악 플레이어</span>
                </h1>
                <p class="text-ink-light text-lg max-w-2xl mx-auto mb-8">
                    A차시에서 만든 서버 로직을 <strong>눈에 보이는 UI</strong>로 연결합니다.<br>
                    경험치 바, 스텟 트리 애니메이션, 음악 플레이어까지 완성합니다.
                </p>
                <div class="flex flex-wrap justify-center gap-3 mb-8">
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">TweenService</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">UI Layout</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">플레이리스트</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">UDim2</span>
                </div>
                <HintBox type="info" title="이번 수업 목표">
                    레벨에 마우스를 올리면 경험치 바가 보이고, 클릭하면 스텟 트리가 열리는 UI를 만듭니다.<br>
                    또한 곡 제목이 표시되는 음악 플레이어를 구현합니다.
                </HintBox>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 2: UI 레이아웃 전체 구조 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-roblox mb-4">Part 1 — HUD 설계</span>
            <h2 class="title-section mb-6">UI 레이아웃 전체 구조</h2>
            <p class="text-ink-light mb-6">게임 화면에 표시될 모든 UI 요소의 위치를 설계합니다.</p>

            <div class="screen-layout">
                <div class="sl-screen">
                    <div class="sl-element sl-timer">
                        <strong>Timer</strong>
                        <span>상단 중앙</span>
                    </div>
                    <div class="sl-element sl-leaderboard">
                        <strong>Leaderboard</strong>
                        <span>상단 우측</span>
                    </div>
                    <div class="sl-element sl-heightbar">
                        <strong>Height</strong>
                        <span>우측</span>
                    </div>
                    <div class="sl-element sl-shop">
                        <strong>상점 + 코인</strong>
                        <span>좌하단</span>
                    </div>
                    <div class="sl-element sl-level">
                        <strong>Level 5</strong>
                        <span>하단 중앙</span>
                    </div>
                    <div class="sl-element sl-xpbar">
                        <strong>650 / 1000 XP</strong>
                        <span>호버 시 표시</span>
                    </div>
                    <div class="sl-element sl-stattree">
                        <strong>스텟 트리</strong>
                        <span>클릭 시 표시</span>
                    </div>
                    <div class="sl-element sl-music">
                        <strong>Music</strong>
                        <span>우하단</span>
                    </div>
                    <div class="sl-game-area">게임 화면</div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                <HintBox type="info" title="마우스 올리면">
                    레벨 표시에 마우스를 올리면 <strong>경험치 바</strong>가 나타납니다.<br>
                    현재 XP / 필요 XP를 시각적으로 확인할 수 있습니다.
                </HintBox>
                <HintBox type="tip" title="클릭하면">
                    레벨 표시를 <strong>클릭</strong>하면 <strong>스텟 트리</strong>가 위로 펼쳐집니다.<br>
                    보유 포인트를 원하는 스텟에 투자할 수 있습니다.
                </HintBox>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 3: ScreenGui 기본 설정 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 1 — 기본 셋업</span>
            <h2 class="title-section mb-6">ScreenGui 기본 설정</h2>
            <p class="text-ink-light mb-6">
                모든 UI의 부모가 될 ScreenGui를 먼저 만듭니다.
            </p>

            <lua-code-block title="GameUI (LocalScript) — ScreenGui 설정" show-line-numbers>
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- =============================================
-- ScreenGui: 모든 UI의 부모
-- =============================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GameHUD"
screenGui.ResetOnSpawn = false       -- 죽어도 UI 유지!
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = playerGui

-- Remote 연결
local remotes = ReplicatedStorage:WaitForChild("TOH_Remotes")
local AllocateStatRF = remotes:WaitForChild("AllocateStat")
local StatSync = remotes:WaitForChild("StatSync")
local RoundInfo = remotes:WaitForChild("RoundInfo")
            </lua-code-block>

            <div class="detail-grid mt-6">
                <div class="detail-item">
                    <div class="detail-label">ResetOnSpawn = false</div>
                    <div class="detail-desc">캐릭터가 죽고 리스폰해도 UI가 사라지지 않습니다. HUD에는 필수 설정입니다.</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">ZIndexBehavior = Sibling</div>
                    <div class="detail-desc">같은 레벨의 UI 요소끼리 ZIndex 값으로 앞뒤를 결정합니다. Global보다 관리하기 쉽습니다.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 4: 레벨 라벨 만들기 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 1 — 레벨 라벨</span>
            <h2 class="title-section mb-6">레벨 라벨 만들기</h2>
            <p class="text-ink-light mb-6">
                하단 중앙에 레벨을 표시하는 버튼입니다. 호버와 클릭 인터랙션이 필요하므로 <strong>TextButton</strong>을 사용합니다.
            </p>

            <lua-code-block title="레벨 라벨 (TextButton)" show-line-numbers>
-- =============================================
-- 레벨 라벨 — 하단 중앙
-- TextLabel이 아닌 TextButton! (클릭 필요)
-- =============================================
local levelLabel = Instance.new("TextButton")
levelLabel.Name = "LevelLabel"
levelLabel.Size = UDim2.new(0, 120, 0, 36)
levelLabel.Position = UDim2.new(0.5, -60, 1, -60)
levelLabel.BackgroundColor3 = Color3.fromRGB(20, 16, 30)
levelLabel.BackgroundTransparency = 0.3
levelLabel.Text = "Level 0"
levelLabel.TextColor3 = Color3.new(1, 1, 1)
levelLabel.TextSize = 16
levelLabel.Font = Enum.Font.GothamBold
levelLabel.Parent = screenGui

-- 모서리 둥글게
Instance.new("UICorner", levelLabel).CornerRadius = UDim.new(0, 10)

-- 테두리
local labelStroke = Instance.new("UIStroke")
labelStroke.Color = Color3.fromRGB(107, 207, 255)
labelStroke.Thickness = 1
labelStroke.Transparency = 0.5
labelStroke.Parent = levelLabel
            </lua-code-block>

            <HintBox type="tip" title="TextButton vs TextLabel">
                TextLabel은 <strong>표시만</strong> 합니다. 마우스 이벤트(MouseEnter, MouseButton1Click 등)를 쓰려면 <strong>TextButton</strong>이 필요합니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 5: 경험치 바 — 마우스 호버 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 1 — 경험치 바</span>
            <h2 class="title-section mb-6">경험치 바 — 마우스 호버</h2>
            <p class="text-ink-light mb-6">
                레벨 라벨에 마우스를 올리면 XP 바가 나타나고, 벗어나면 사라집니다.
            </p>

            <lua-code-block title="경험치 바 구조 + 호버 이벤트" show-line-numbers>
-- =============================================
-- 경험치 바 프레임 (평소엔 숨김)
-- =============================================
local xpBarFrame = Instance.new("Frame")
xpBarFrame.Name = "XPBar"
xpBarFrame.Size = UDim2.new(0, 200, 0, 40)
xpBarFrame.Position = UDim2.new(0.5, -100, 1, -100)
xpBarFrame.BackgroundTransparency = 1
xpBarFrame.Visible = false
xpBarFrame.Parent = screenGui

-- 배경 바
local xpBarBg = Instance.new("Frame")
xpBarBg.Size = UDim2.new(1, 0, 0, 8)
xpBarBg.Position = UDim2.new(0, 0, 0.5, -4)
xpBarBg.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
xpBarBg.Parent = xpBarFrame
Instance.new("UICorner", xpBarBg).CornerRadius = UDim.new(1, 0)

-- 채움 바 (그라데이션)
local xpBarFill = Instance.new("Frame")
xpBarFill.Size = UDim2.new(0, 0, 1, 0)   -- 시작은 0%
xpBarFill.BackgroundColor3 = Color3.fromRGB(107, 207, 255)
xpBarFill.Parent = xpBarBg
Instance.new("UICorner", xpBarFill).CornerRadius = UDim.new(1, 0)
Instance.new("UIGradient", xpBarFill).Color =
    ColorSequence.new(Color3.fromRGB(107,207,255), Color3.fromRGB(61,255,162))

-- XP 텍스트
local xpText = Instance.new("TextLabel")
xpText.Size = UDim2.new(1, 0, 0, 16)
xpText.Position = UDim2.new(0, 0, 0.5, 6)
xpText.Text = "0 / 100 XP"
xpText.TextColor3 = Color3.fromRGB(180, 180, 180)
xpText.TextSize = 11
xpText.Font = Enum.Font.GothamBold
xpText.BackgroundTransparency = 1
xpText.Parent = xpBarFrame

-- =============================================
-- 마우스 호버 → 페이드 인/아웃
-- =============================================
levelLabel.MouseEnter:Connect(function()
    xpBarFrame.Visible = true
    TweenService:Create(xpBarFrame,
        TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        &#123; BackgroundTransparency = 1 &#125;
    ):Play()
    TweenService:Create(xpBarBg,
        TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        &#123; BackgroundTransparency = 0 &#125;
    ):Play()
end)

levelLabel.MouseLeave:Connect(function()
    TweenService:Create(xpBarBg,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
        &#123; BackgroundTransparency = 1 &#125;
    ):Play()
    task.delay(0.2, function()
        xpBarFrame.Visible = false
    end)
end)
            </lua-code-block>
        </div>
    </section>

    <!-- ==================== 슬라이드 6: TweenService 심화 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">Part 2 — TweenService</span>
            <h2 class="title-section mb-6">TweenService 심화</h2>
            <p class="text-ink-light mb-6">
                TweenInfo의 EasingStyle에 따라 애니메이션 느낌이 완전히 달라집니다.
            </p>

            <lua-code-block title="TweenInfo 매개변수" show-line-numbers>
-- TweenInfo.new(시간, 이징스타일, 이징방향, 반복횟수, 역재생, 딜레이)
local info = TweenInfo.new(
    0.4,                         -- 0.4초 동안
    Enum.EasingStyle.Back,       -- Back = 살짝 넘쳤다 돌아오는 효과
    Enum.EasingDirection.Out,    -- Out = 끝에서 감속
    0,                           -- 반복 없음
    false,                       -- 역재생 없음
    0                            -- 딜레이 없음
)

local tween = TweenService:Create(frame, info, &#123; Position = targetPos &#125;)
tween:Play()
            </lua-code-block>

            <div class="easing-comparison">
                <div class="easing-card">
                    <div class="easing-name" style="color:#6BCFFF;">Quad</div>
                    <div class="easing-curve">
                        <div class="easing-bar" style="width:70%;background:linear-gradient(90deg,#6BCFFF,#6BCFFF);"></div>
                    </div>
                    <div class="easing-desc">부드러운 가감속. 일반적인 UI 이동에 적합</div>
                </div>
                <div class="easing-card">
                    <div class="easing-name" style="color:#3DFFA2;">Back</div>
                    <div class="easing-curve">
                        <div class="easing-bar" style="width:85%;background:linear-gradient(90deg,#3DFFA2,#6BCFFF);"></div>
                    </div>
                    <div class="easing-desc">살짝 넘쳤다 돌아오는 "바운스 오버슛" 효과</div>
                </div>
                <div class="easing-card">
                    <div class="easing-name" style="color:#FFD93D;">Elastic</div>
                    <div class="easing-curve">
                        <div class="easing-bar" style="width:100%;background:linear-gradient(90deg,#FFD93D,#FF6B6B);"></div>
                    </div>
                    <div class="easing-desc">고무줄처럼 출렁이는 효과. 강한 등장 연출에 사용</div>
                </div>
            </div>

            <HintBox type="tip" title="Back EasingStyle 추천!">
                Back 이징은 목표 지점을 살짝 넘었다가 돌아오는 "오버슛" 느낌을 줍니다.<br>
                UI 팝업이나 패널이 열릴 때 사용하면 생동감이 생깁니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 7: 스텟 트리 프레임 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 3 — 스텟 트리 UI</span>
            <h2 class="title-section mb-6">스텟 트리 프레임</h2>
            <p class="text-ink-light mb-6">
                스텟 트리의 메인 컨테이너를 만듭니다. 처음에는 화면 아래에 숨겨둡니다.
            </p>

            <lua-code-block title="스텟 트리 메인 프레임" show-line-numbers>
-- =============================================
-- 스텟 트리 메인 프레임 (처음엔 화면 밖)
-- =============================================
local treeFrame = Instance.new("Frame")
treeFrame.Name = "StatTree"
treeFrame.Size = UDim2.new(0, 380, 0, 420)
treeFrame.Position = UDim2.new(0.5, -190, 1, 50)  -- 화면 밖 (아래)
treeFrame.BackgroundColor3 = Color3.fromRGB(20, 16, 30)
treeFrame.BackgroundTransparency = 0.05
treeFrame.Visible = false
treeFrame.Parent = screenGui

-- 둥근 모서리
Instance.new("UICorner", treeFrame).CornerRadius = UDim.new(0, 16)

-- 테두리
local treeStroke = Instance.new("UIStroke")
treeStroke.Color = Color3.fromRGB(199, 146, 234)
treeStroke.Thickness = 2
treeStroke.Parent = treeFrame

-- 타이틀
local treeTitle = Instance.new("TextLabel")
treeTitle.Name = "TreeTitle"
treeTitle.Size = UDim2.new(1, 0, 0, 36)
treeTitle.Position = UDim2.new(0, 0, 0, 8)
treeTitle.Text = "스텟 트리 ★ 0 포인트"
treeTitle.TextColor3 = Color3.fromRGB(255, 217, 61)
treeTitle.TextSize = 16
treeTitle.Font = Enum.Font.GothamBold
treeTitle.BackgroundTransparency = 1
treeTitle.Parent = treeFrame
            </lua-code-block>

            <HintBox type="info" title="왜 화면 밖에?">
                <code>Position = UDim2.new(0.5, -190, 1, 50)</code><br>
                Y축이 <strong>1, 50</strong>이면 화면 하단(1 = 100%)에서 50px 더 아래 = 화면 밖입니다.<br>
                나중에 TweenService로 위로 슬라이드시킵니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 8: 4개 브랜치 배치 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 3 — 브랜치 생성</span>
            <h2 class="title-section mb-6">4개 브랜치 배치</h2>
            <p class="text-ink-light mb-6">
                속도/점프/코인/시간 4개 브랜치를 반복문으로 생성합니다.
            </p>

            <lua-code-block title="브랜치 반복 생성" show-line-numbers>
-- =============================================
-- 4개 브랜치 정의
-- =============================================
local BRANCHES = &#123;
    &#123; name = "Speed", label = "속도", color = Color3.fromRGB(107, 207, 255),
      prefix = "spd", tiers = &#123;"2%","4%","6%","8%","10%"&#125; &#125;,
    &#123; name = "Jump",  label = "점프", color = Color3.fromRGB(61, 255, 162),
      prefix = "jmp", tiers = &#123;"3","7","10","15","20"&#125; &#125;,
    &#123; name = "Coin",  label = "코인", color = Color3.fromRGB(255, 217, 61),
      prefix = "coin", tiers = &#123;"5%","10%","15%","20%","25%"&#125; &#125;,
    &#123; name = "Time",  label = "시간", color = Color3.fromRGB(199, 146, 234),
      prefix = "time", tiers = &#123;"10초","15초","20초","30초","40초"&#125; &#125;,
&#125;

local nodeButtons = &#123;&#125;   -- nodeId → TextButton 매핑

local columnWidth = 80
local startX = 30        -- 좌측 여백

for i, branch in BRANCHES do
    -- 브랜치 라벨 (하단)
    local colLabel = Instance.new("TextLabel")
    colLabel.Size = UDim2.new(0, columnWidth, 0, 20)
    colLabel.Position = UDim2.new(0, startX + (i-1) * (columnWidth + 10), 1, -30)
    colLabel.Text = branch.label
    colLabel.TextColor3 = branch.color
    colLabel.TextSize = 12
    colLabel.Font = Enum.Font.GothamBold
    colLabel.BackgroundTransparency = 1
    colLabel.Parent = treeFrame
end
            </lua-code-block>

            <HintBox type="info" title="UDim2 좌표 계산">
                <code>startX + (i-1) * (columnWidth + 10)</code><br>
                i=1이면 30px, i=2이면 120px, i=3이면 210px, i=4이면 300px.<br>
                4개 컬럼이 80px 너비 + 10px 간격으로 균등 배치됩니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 9: 노드 버튼 만들기 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 3 — 노드 생성</span>
            <h2 class="title-section mb-6">노드 버튼 만들기</h2>
            <p class="text-ink-light mb-6">
                각 브랜치에 5개 티어 버튼을 생성합니다. 아래(tier1)부터 위(tier5)까지 쌓습니다.
            </p>

            <lua-code-block title="티어 노드 + 연결선 생성" show-line-numbers>
for i, branch in BRANCHES do
    local colX = startX + (i-1) * (columnWidth + 10)

    for tier = 1, 5 do
        local nodeId = branch.prefix .. tier
        -- 아래(tier1)가 y큰값, 위(tier5)가 y작은값
        local nodeY = 340 - (tier - 1) * 65

        -- 노드 버튼
        local btn = Instance.new("TextButton")
        btn.Name = nodeId
        btn.Size = UDim2.new(0, columnWidth, 0, 44)
        btn.Position = UDim2.new(0, colX, 0, nodeY)
        btn.BackgroundColor3 = Color3.fromRGB(40, 34, 55)
        btn.Text = branch.tiers[tier]
        btn.TextColor3 = Color3.fromRGB(120, 120, 120)
        btn.TextSize = 13
        btn.Font = Enum.Font.GothamBold
        btn.Parent = treeFrame
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

        nodeButtons[nodeId] = btn

        -- 연결선 (tier 2~5에만)
        if tier > 1 then
            local line = Instance.new("Frame")
            line.Size = UDim2.new(0, 2, 0, 21)
            line.Position = UDim2.new(0, colX + columnWidth/2 - 1, 0, nodeY + 44)
