local bgm = Instance.new("Sound")
bgm.SoundId = PLAYLIST[1].id
bgm.Volume = 0.3
bgm.Looped = false  -- 곡 끝나면 다음 곡으로
bgm.Parent = SoundService
bgm:Play()

local isPlaying = true

-- 재생/정지 토글
playBtn.MouseButton1Click:Connect(function()
    isPlaying = not isPlaying
    if isPlaying then
        bgm:Resume()
        playBtn.Text = "▶"
        playBtn.BackgroundColor3 = Color3.fromRGB(61, 255, 162)
    else
        bgm:Pause()
        playBtn.Text = "■"
        playBtn.BackgroundColor3 = Color3.fromRGB(255, 107, 107)
    end
end)

-- 곡 끝나면 다음 곡 자동 재생
bgm.Ended:Connect(function()
    currentTrack = currentTrack % #PLAYLIST + 1
    bgm.SoundId = PLAYLIST[currentTrack].id
    songLabel.Text = PLAYLIST[currentTrack].name
    if isPlaying then
        bgm:Play()
    end
end)
