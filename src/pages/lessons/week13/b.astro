        line.BackgroundColor3 = Color3.fromRGB(100, 90, 130)
        line.BorderSizePixel = 0
        line.LayoutOrder = (6 - i) * 10 + 5  -- 노드 사이에 배치
        line.AnchorPoint = Vector2.new(0.5, 0)
        line.Position = UDim2.new(0.5, 0, 0, 0)
        line.Parent = col
    end
end

-- 레벨 → Tier 1 연결선 (대각선 효과)
-- 실제로는 4개의 짧은 프레임으로 표현
for i, branch in BRANCHES do
    local line = Instance.new("Frame")
    line.Size = UDim2.new(0, 2, 0, 20)
