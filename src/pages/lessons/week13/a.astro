---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import HintBox from '../../../components/astro/HintBox.astro';
---

<LessonLayout title="TOH 스텟 트리 - 레벨 & 상점 설계" lessonNumber={13} totalSlides={18}>

    <!-- ==================== 슬라이드 1: 인트로 ==================== -->
    <section class="slide active">
        <div class="max-w-4xl mx-auto px-6 py-12 flex flex-col items-center justify-center min-h-[80vh]">
            <div class="text-center animate-in">
                <span class="badge badge-roblox mb-6">13주차 A</span>
                <h1 class="title-display mb-4">
                    TOH 스텟 트리<br>
                    <span class="text-neon-mint">레벨 &amp; 상점 설계</span>
                </h1>
                <p class="text-ink-light text-lg max-w-2xl mx-auto mb-8">
                    레벨업 시스템을 확장하고, 스텟 포인트로<br>
                    속도·점프·코인·시간을 영구 강화하는 시스템을 만듭니다.
                </p>
                <div class="flex flex-wrap justify-center gap-3 mb-8">
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">레벨 시스템</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">스텟 포인트</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">스텟 트리</span>
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-ink-deep text-white">서버 보안</span>
                </div>
                <HintBox type="info" title="이번 수업 목표">
                    기존 TOH의 레벨 시스템을 확장합니다.<br>
                    레벨업 시 <strong>스텟 포인트</strong>를 얻고, 4개 브랜치(속도/점프/코인/시간)에 투자하는 <strong>스텟 트리</strong>를 설계합니다.
                </HintBox>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 2: 현재 시스템 복습 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">Part 1 — 현재 시스템 분석</span>
            <h2 class="title-section mb-6">현재 레벨 시스템 복습</h2>

            <lua-code-block title="기존 GameManager — giveXP()" show-line-numbers>
local function giveXP(player, amount)
    playerXP[player.UserId] += amount
    local level = player.leaderstats.Level
    local requiredXP = (level.Value + 1) * CONFIG.LEVEL_XP_BASE
    while playerXP[player.UserId] >= requiredXP do
        playerXP[player.UserId] -= requiredXP
        level.Value += 1
        requiredXP = (level.Value + 1) * CONFIG.LEVEL_XP_BASE
    end
end
            </lua-code-block>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                <div class="bg-ink-deep rounded-xl p-4">
                    <h4 class="text-neon-mint font-bold mb-2">현재 동작</h4>
                    <ul class="text-white text-sm space-y-1">
                        <li>• 코인 획득 = XP 획득</li>
                        <li>• 필요 XP = (레벨+1) × 100</li>
                        <li>• 레벨업 시 아무 보상 없음</li>
                    </ul>
                </div>
                <div class="bg-ink-deep rounded-xl p-4">
                    <h4 class="text-neon-coral font-bold mb-2">문제점</h4>
                    <ul class="text-white text-sm space-y-1">
                        <li>• 레벨이 올라도 <strong>달라지는 게 없다</strong></li>
                        <li>• 플레이어가 레벨에 관심을 안 가짐</li>
                        <li>• 경험치 바도 안 보임 — 진행도 모름</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 3: 새 시스템 개요 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lesson mb-4">Part 1 — 설계</span>
            <h2 class="title-section mb-6">새 레벨 시스템 설계</h2>

            <div class="bg-ink-deep rounded-xl p-6 mb-6">
                <div class="flow-horizontal">
                    <span class="flow-step" style="background:#6BCFFF;color:#1a1625;">코인 획득<br><small>= XP 획득</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#FFD93D;color:#1a1625;">XP 바 채움<br><small>호버 시 표시</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#3DFFA2;color:#1a1625;">레벨업!<br><small>+1 스텟 포인트</small></span>
                    <span class="flow-arrow">→</span>
                    <span class="flow-step" style="background:#C792EA;color:#1a1625;">트리에 투자<br><small>영구 강화</small></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <HintBox type="info" title="마우스 올리면">
                    레벨 표시에 마우스를 올리면 <strong>경험치 바</strong>가 나타납니다.<br>
                    현재 XP / 필요 XP를 시각적으로 확인할 수 있습니다.
                </HintBox>
                <HintBox type="tip" title="클릭하면">
                    레벨 표시를 <strong>클릭</strong>하면 <strong>스텟 트리</strong>가 위로 펼쳐집니다.<br>
                    보유 포인트를 원하는 스텟에 투자할 수 있습니다.
                </HintBox>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 4: 스텟 트리 전체 구조 ==================== -->
