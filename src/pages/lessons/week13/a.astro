            <lua-code-block title="playerStats 구조" show-line-numbers>
-- 플레이어별 스텟 데이터
local playerStats = &#123;&#125;

local function initPlayerStats(player)
    playerStats[player.UserId] = &#123;
        statPoints = 0,        -- 미사용 포인트
        allocated = &#123;&#125;,       -- &#123; spd1 = true, spd2 = true, ... &#125;
    &#125;
end

-- 기존 setupLeaderstats에 추가
local function setupLeaderstats(player)
    -- ... 기존 Wins, Coins, Level ...
    initPlayerStats(player)
end
            </lua-code-block>

            <div class="bg-ink-deep rounded-xl p-4 mt-4">
                <h4 class="text-neon-gold font-bold mb-2">allocated 테이블 예시</h4>
                <lua-code-block title="레벨 8 플레이어 예시">
allocated = &#123;
    spd1 = true,  -- 속도+2% ✓
    spd2 = true,  -- 속도+4% ✓
    spd3 = true,  -- 속도+6% ✓
    jmp1 = true,  -- 점프+3 ✓
    jmp2 = true,  -- 점프+7 ✓
    coin1 = true, -- 코인+5% ✓
    coin2 = true, -- 코인+10% ✓
    time1 = true, -- 시간+10초 ✓
&#125;
-- statPoints = 0 (8포인트 전부 사용)
                </lua-code-block>
            </div>
        </div>
    </section>

    <!-- ==================== 슬라이드 7: 레벨업 시 포인트 지급 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 구현</span>
            <h2 class="title-section mb-6">레벨업 시 포인트 지급</h2>

            <lua-code-block title="giveXP() 수정" show-line-numbers>
local function giveXP(player, amount)
    playerXP[player.UserId] += amount
    local level = player.leaderstats.Level
    local requiredXP = (level.Value + 1) * CONFIG.LEVEL_XP_BASE

    while playerXP[player.UserId] >= requiredXP do
        playerXP[player.UserId] -= requiredXP
        level.Value += 1

        -- ★ 새로 추가: 레벨업 보상
        local stats = playerStats[player.UserId]
        if stats then
            stats.statPoints += 1
        end

        -- 클라이언트에 레벨업 알림
        RoundInfo:FireClient(player, "LevelUp", level.Value, stats.statPoints)

        requiredXP = (level.Value + 1) * CONFIG.LEVEL_XP_BASE
    end

    -- XP 진행도를 클라이언트에 전송
    local progress = playerXP[player.UserId] / requiredXP
    RoundInfo:FireClient(player, "XPUpdate", progress, playerXP[player.UserId], requiredXP)
end
            </lua-code-block>

            <HintBox type="warning" title="핵심 변경">
                <strong>2가지</strong>가 추가됩니다:<br>
                1. 레벨업 시 <code>statPoints += 1</code><br>
                2. XP 변경 시 클라이언트에 <code>진행도(0~1)</code> 전송 → 경험치 바 표시용
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 8: 스텟 할당 서버 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 구현</span>
            <h2 class="title-section mb-6">스텟 할당 — 서버 검증</h2>

            <lua-code-block title="AllocateStat RemoteFunction" show-line-numbers>
AllocateStatRF.OnServerInvoke = function(player, nodeId)
    -- [1] 타입 검증
    if typeof(nodeId) ~= "string" then
        return false, "잘못된 요청"
    end

    local stats = playerStats[player.UserId]
    if not stats then return false, "데이터 없음" end

    -- [2] 포인트 확인
    if stats.statPoints &lt;= 0 then
        return false, "포인트 부족"
    end

    -- [3] 노드 유효성
    local node = nil
    for _, n in STAT_TREE do
        if n.id == nodeId then node = n; break end
    end
    if not node then return false, "존재하지 않는 노드" end

    -- [4] 이미 찍었는지
    if stats.allocated[nodeId] then
        return false, "이미 투자함"
    end

    -- [5] 전제조건: 하위 티어를 먼저 찍었는지
    if node.tier > 1 then
        local prevId = string.sub(nodeId, 1, -2) .. (node.tier - 1)
        if not stats.allocated[prevId] then
            return false, "하위 노드를 먼저 투자하세요"
        end
    end

    -- [6] 투자 실행
    stats.statPoints -= 1
    stats.allocated[nodeId] = true
    applyStats(player)
    return true, node.label .. " 적용!"
end
            </lua-code-block>
        </div>
    </section>

    <!-- ==================== 슬라이드 9: 서버 검증 해설 ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 구현</span>
            <h2 class="title-section mb-6">6단계 검증 — 왜 필요한가?</h2>

            <div class="space-y-3">
                <div class="bg-ink-deep rounded-xl p-4 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-neon-coral flex items-center justify-center text-ink-deep font-bold">1</div>
                    <div class="text-white">
                        <strong>타입 검증</strong> — 해커가 숫자나 테이블을 보낼 수 있음. 문자열만 허용
                    </div>
                </div>
                <div class="bg-ink-deep rounded-xl p-4 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-neon-coral flex items-center justify-center text-ink-deep font-bold">2</div>
                    <div class="text-white">
                        <strong>포인트 확인</strong> — 0포인트인데 찍는 걸 막음
                    </div>
                </div>
                <div class="bg-ink-deep rounded-xl p-4 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-neon-coral flex items-center justify-center text-ink-deep font-bold">3</div>
                    <div class="text-white">
                        <strong>노드 유효성</strong> — 존재하지 않는 노드 id를 보내는 걸 막음
                    </div>
                </div>
                <div class="bg-ink-deep rounded-xl p-4 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-neon-coral flex items-center justify-center text-ink-deep font-bold">4</div>
                    <div class="text-white">
                        <strong>중복 방지</strong> — 같은 노드를 두 번 찍는 걸 막음
                    </div>
                </div>
                <div class="bg-ink-deep rounded-xl p-4 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-neon-coral flex items-center justify-center text-ink-deep font-bold">5</div>
                    <div class="text-white">
                        <strong>전제조건</strong> — spd3을 찍으려면 spd2가 먼저 있어야 함
                    </div>
                </div>
                <div class="bg-ink-deep rounded-xl p-4 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-neon-mint flex items-center justify-center text-ink-deep font-bold">6</div>
                    <div class="text-white">
                        <strong>투자 실행</strong> — 모든 검증 통과 후 포인트 차감 + 효과 적용
                    </div>
                </div>
            </div>

            <HintBox type="warning" title="절대 규칙">
                클라이언트가 "spd1 찍었다"고 보내는 걸 <strong>절대 믿으면 안 됩니다</strong>.
                서버가 직접 확인하고 적용해야 합니다.
            </HintBox>
        </div>
    </section>

    <!-- ==================== 슬라이드 10: applyStats ==================== -->
    <section class="slide">
        <div class="max-w-5xl mx-auto px-6 py-12">
            <span class="badge badge-lua mb-4">Part 2 — 서버 구현</span>
            <h2 class="title-section mb-6">스텟 적용 함수</h2>

            <lua-code-block title="applyStats()" show-line-numbers>
local BASE_WALK_SPEED = 16
local BASE_JUMP_POWER = 50

local function applyStats(player)
    local stats = playerStats[player.UserId]
    if not stats then return end

    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end

    -- 속도 계산: 기본값 × (1 + 모든 속도 효과 합산)
    local speedBonus = 0
    local jumpBonus = 0
    for _, node in STAT_TREE do
        if stats.allocated[node.id] then
            if node.branch == "Speed" then
                speedBonus += node.effect
            elseif node.branch == "Jump" then
                jumpBonus += node.effect
            end
        end
    end

    humanoid.WalkSpeed = BASE_WALK_SPEED * (1 + speedBonus)
    humanoid.JumpPower = BASE_JUMP_POWER + jumpBonus
    humanoid.UseJumpPower = true
end

-- 캐릭터 스폰될 때마다 적용
player.CharacterAdded:Connect(function()
    task.wait(0.1) -- Humanoid 로드 대기
    applyStats(player)
end)
