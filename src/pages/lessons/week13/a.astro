local function syncStats(player)
    local stats = playerStats[player.UserId]
    if not stats then return end

    -- 클라이언트에 전체 스텟 데이터 전송
    StatSync:FireClient(player, &#123;
        statPoints = stats.statPoints,
        allocated = stats.allocated,
        xpProgress = playerXP[player.UserId]
            / ((player.leaderstats.Level.Value + 1) * CONFIG.LEVEL_XP_BASE),
    &#125;)
end

-- 동기화 시점:
-- 1. 플레이어 접속 시 (PlayerAdded)
-- 2. 레벨업 시 (giveXP 안에서)
-- 3. 스텟 할당 후 (AllocateStat 안에서)
-- 4. 코인 변경 시 (giveCoins 안에서)
            </lua-code-block>

