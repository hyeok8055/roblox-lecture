local function getCoinMultiplier(player)
    local stats = playerStats[player.UserId]
    if not stats then return 1 end
    local bonus = 0
    for _, node in STAT_TREE do
        if stats.allocated[node.id]
            and node.branch == "Coin" then
            bonus += node.effect
        end
    end
    return 1 + bonus -- 1.0 ~ 1.75
end

-- giveCoins 수정
local function giveCoins(player, amount)
    local multiplier = getCoinMultiplier(player)
    local final = math.floor(amount * multiplier)
    coins.Value += final
    giveXP(player, final)
end
                    </lua-code-block>
                </div>
                <div>
                    <lua-code-block title="시간 보너스 적용" show-line-numbers>
local function getTimeBonus(player)
    local stats = playerStats[player.UserId]
    if not stats then return 0 end
    local bonus = 0
    for _, node in STAT_TREE do
        if stats.allocated[node.id]
            and node.branch == "Time" then
            bonus += node.effect
        end
    end
    return bonus -- 0 ~ 115초
end

-- startTimer 수정
local function startTimer()
    -- 접속 중인 플레이어의 최대 시간 보너스
    local maxBonus = 0
    for _, plr in Players:GetPlayers() do
        local b = getTimeBonus(plr)
        if b > maxBonus then maxBonus = b end
    end
    currentRemainingTime = CONFIG.ROUND_TIME + maxBonus
end
