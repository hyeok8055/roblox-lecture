local template = ServerStorage:FindFirstChild("Coin")

-- 💡 원본을 복제해서 월드에 배치!
local coin = template[b1]
coin.Parent = workspace

-- 💡 수집 시 완전히 삭제
coin.Touched:Connect(function(hit)
    if hit.Parent:FindFirstChild("Humanoid") then
        [b2]
