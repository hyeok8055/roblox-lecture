        [b2](0.03)  -- 💡 0.03초마다 회전
    end
end)

-- 💡 색상 변경 루프도 동시에!
[b1](function()
    while true do
        part.Color = Color3.fromRGB(
            math.random(0, 255),
            math.random(0, 255),
            math.random(0, 255)
        )
        [b2](1)  -- 💡 1초마다 색 변경
    end
end)

-- 💡 5초 뒤에 파트 자동 삭제 예약
[b3](5, function()
    part:Destroy()
    print("5초 후 삭제됨!")
end)`;
const taskFullCode = `-- 🚀 task 라이브러리 활용
-- 회전 루프 (별도 스레드)
task.spawn(function()
    while true do
        part.CFrame = part.CFrame * CFrame.Angles(0, math.rad(2), 0)
        task.wait(0.03)
    end
end)

-- 색상 변경 루프 (별도 스레드)
task.spawn(function()
    while true do
        part.Color = Color3.fromRGB(
            math.random(0, 255),
            math.random(0, 255),
