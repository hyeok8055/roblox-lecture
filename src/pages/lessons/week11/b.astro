const tweenChainFullCode = `-- 🔗 Tween 체인 — 문 자동 닫기
local TweenService = game:GetService("TweenService")
local door = script.Parent

local openGoal = { Position = door.Position + Vector3.new(0, 8, 0) }
local closeGoal = { Position = door.Position }
local info = TweenInfo.new(1, Enum.EasingStyle.Quad)

local openTween = TweenService:Create(door, info, openGoal)
local closeTween = TweenService:Create(door, info, closeGoal)

