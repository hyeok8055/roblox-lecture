const sunsetTemplate = `-- ========================================
-- Sunset Paradise (석양 낙원)
-- ========================================
-- 📦 준비: ServerScriptService > Script
-- 💡 Lighting = 게임 전체 조명을 관리하는 서비스
-- 💡 ClockTime = 시간 (0~24)
-- 💡 Atmosphere = 대기 효과 (안개, 색감)
-- ========================================

local Lighting = game:GetService("Lighting")

-- 💡 시간 설정 (18.2 = 오후 6시 12분, 석양)
Lighting.ClockTime = [b1]
-- 💡 밝기 (높을수록 빛/그림자 대비 강화)
Lighting.Brightness = [b2]
Lighting.Ambient = Color3.fromRGB(80, 60, 40)
Lighting.OutdoorAmbient = Color3.fromRGB(100, 70, 50)

-- 💡 Atmosphere (대기 효과)
local atmo = Instance.new("Atmosphere")
atmo.Density = [b3]          -- 💡 0.35 = 약간 뿌연 공기
atmo.Haze = 2                 -- 💡 전체적 흐릿함 (0~10)
atmo.Glare = 0.5              -- 💡 태양 주변 눈부심
atmo.Color = [b4]             -- 💡 대기 색 (따뜻한 주황)
atmo.Decay = Color3.fromRGB(200, 120, 60)
atmo.Offset = 0.2
atmo.Parent = Lighting

-- 💡 ColorCorrection (색 보정)
local cc = Instance.new("ColorCorrectionEffect")
cc.Brightness = 0.05
cc.Contrast = 0.1
cc.Saturation = 0.2           -- 💡 양수 = 색이 더 선명
cc.TintColor = Color3.fromRGB(255, 230, 200)
cc.Parent = Lighting

-- 💡 Bloom (밝은 부분이 빛나는 효과)
local bloom = Instance.new("BloomEffect")
bloom.Intensity = 0.8
bloom.Size = 40
bloom.Threshold = 1.2          -- 💡 낮을수록 더 많은 부분이 빛남
bloom.Parent = Lighting

-- 💡 SunRays (태양 광선)
local rays = Instance.new("SunRaysEffect")
rays.Intensity = 0.15
rays.Spread = 0.6
rays.Parent = Lighting`;
