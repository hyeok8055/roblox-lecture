            <lua-code-block title="Day/Night Cycle" show-line-numbers>
local Lighting = game:GetService("Lighting")

while true do
    -- ClockTime을 0.1씩 올려서 시간 흐르게
    Lighting.ClockTime = Lighting.ClockTime + 0.1

    -- 24시가 넘으면 0으로 리셋 (하루 반복)
    if Lighting.ClockTime >= 24 then
        Lighting.ClockTime = 0
    end

    -- 0.5초마다 업데이트
    task.wait(0.5)
end
            </lua-code-block>

            <HintBox type="tip" title="속도 조절">
                <code>+ 0.1</code> 을 크게 하면 빨리, 작게 하면 천천히 변해요. <code>task.wait()</code> 값도 조절해보세요!
            </HintBox>

            <div class="mt-4">
                <lua-code-block title="TweenService로 부드러운 전환">
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

-- 10초에 걸쳐 석양으로 부드럽게 전환!
local tween = TweenService:Create(
    Lighting,
    TweenInfo.new(10),
    {"{ ClockTime = 18.2, Brightness = 2 }"}
)
tween:Play()
                </lua-code-block>
            </div>
