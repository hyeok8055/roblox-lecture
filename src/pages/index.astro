---
import BaseLayout from '../layouts/BaseLayout.astro';

// 24차시 커리큘럼 데이터 (주 2회, 12주)
const curriculum = [
    // 1개월차: 기초 문법
    { week: 1, part: 'A', title: '스튜디오 적응', desc: 'Explorer, Properties, Anchored', active: true, path: '/lessons/week01/a' },
    { week: 1, part: 'B', title: '첫 스크립트', desc: 'print, Output 창', active: true, path: '/lessons/week01/b' },
    { week: 2, part: 'A', title: '변수 기초', desc: 'local 변수, 자료형', active: true, path: '/lessons/week02/a' },
    { week: 2, part: 'B', title: '파트 속성 변경', desc: 'BrickColor, Transparency', active: true, path: '/lessons/week02/b' },
    { week: 3, part: 'A', title: '함수 기초', desc: 'function, 매개변수, return', active: true, path: '/lessons/week03/a' },
    { week: 3, part: 'B', title: '이벤트 (Touched)', desc: 'Connect, Humanoid 감지', active: true, path: '/lessons/week03/b' },
    { week: 4, part: 'A', title: '조건문 기초', desc: 'if-then-end, 비교연산자', active: true, path: '/lessons/week04/a' },
    { week: 4, part: 'B', title: '조건문 활용', desc: 'Kill Part, 체력 감소', active: true, path: '/lessons/week04/b' },

    // 2개월차: 게임 로직
    { week: 5, part: 'A', title: '반복문 (for)', desc: 'for i = 1, 10 do', active: true, path: '/lessons/week05/a' },
    { week: 5, part: 'B', title: '반복문 (while)', desc: 'while true do, 회전 장애물', active: true, path: '/lessons/week05/b' },
    { week: 6, part: 'A', title: 'Humanoid', desc: 'WalkSpeed, JumpPower', active: true, path: '/lessons/week06/a' },
    { week: 6, part: 'B', title: '미니 오비 만들기', desc: '텔레포트, 코인, 체크포인트', active: true, path: '/lessons/week06/b' },
    { week: 7, part: 'A', title: 'GUI 기초', desc: 'ScreenGui, TextButton, 클릭 이벤트', active: true, path: '/lessons/week07/a' },
    { week: 7, part: 'B', title: 'GUI 활용', desc: 'UICorner, TweenService, BillboardGui', active: true, path: '/lessons/week07/b' },
    { week: 8, part: 'A', title: 'Leaderstats', desc: 'PlayerAdded, Folder, IntValue', active: true, path: '/lessons/week08/a' },
    { week: 8, part: 'B', title: '코인 수집 게임', desc: '코인 줍기, Destroy, 재생성', active: true, path: '/lessons/week08/b' },

    // 3개월차: 프로젝트
    { week: 9, part: 'A', title: 'Tool 기초', desc: 'Handle, Equipped, 검 만들기', active: true, path: '/lessons/week09/a' },
    { week: 9, part: 'B', title: 'Tool 활용', desc: '마법 지팡이, 구체 발사', active: true, path: '/lessons/week09/b' },
    { week: 10, part: 'A', title: '사운드 시스템', desc: 'Sound, BGM, 효과음', active: false, path: '/lessons/week10/a' },
    { week: 10, part: 'B', title: '파티클 & 이펙트', desc: 'ParticleEmitter, PointLight', active: false, path: '/lessons/week10/b' },
    { week: 11, part: 'A', title: '오비 맵 설계', desc: '이동파트, 페이드파트, 바운스', active: false, path: '/lessons/week11/a' },
    { week: 11, part: 'B', title: '게임 시스템 완성', desc: '체크포인트, 스테이지, UI', active: false, path: '/lessons/week11/b' },
    { week: 12, part: 'A', title: '게임 꾸미기', desc: 'Lighting, Atmosphere, Skybox', active: false, path: '/lessons/week12/a' },
    { week: 12, part: 'B', title: '게임 출시', desc: '썸네일, 아이콘, Public 설정', active: false, path: '/lessons/week12/b' },
];

// 월별로 그룹화
const month1 = curriculum.slice(0, 8);   // 1~4주
const month2 = curriculum.slice(8, 16);  // 5~8주
const month3 = curriculum.slice(16, 24); // 9~12주
---

<BaseLayout title="로블록스 과외">
    <div class="min-h-screen bg-ink-cream">
        <!-- 헤더 -->
        <header class="pt-16 pb-12 px-6 text-center">
            <div class="inline-flex items-center gap-3 bg-roblox-red text-white px-4 py-2 rounded-full text-sm font-bold mb-6">
                <span>🎮</span> 로블록스 스튜디오 & Lua
            </div>
            <h1 class="title-display text-ink-deep mb-4">
                로블록스 <span class="text-neon-mint">게임 개발</span> 과외
            </h1>
            <p class="text-lg text-ink-light max-w-xl mx-auto mb-4">
                12주 24차시 커리큘럼으로 나만의 로블록스 게임을 만들어보세요
            </p>
            <p class="text-sm text-ink-light">
                주 2회 × 1.5시간 | 기초 문법 → 게임 로직 → 프로젝트
            </p>
        </header>

        <!-- 커리큘럼 그리드 -->
        <main class="max-w-6xl mx-auto px-6 pb-20">
            <!-- 1개월차 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-6">
                    <span class="badge badge-lesson">1개월차</span>
                    <h2 class="title-section">기초 문법</h2>
                    <span class="text-sm text-ink-light">(1~4주)</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    {month1.map(lesson => (
                        lesson.active ? (
                            <a
                                href={lesson.path}
                                class="lesson-card group"
                            >
                                <div class="flex items-start justify-between mb-3">
                                    <div class="w-12 h-10 rounded-xl flex items-center justify-center text-white font-bold bg-gradient-to-br from-ink-deep to-ink-medium text-sm">
                                        {lesson.week}{lesson.part}
                                    </div>
                                    <span class="badge badge-success text-xs">수강 가능</span>
                                </div>
                                <h3 class="font-bold text-ink-deep mb-1 group-hover:text-neon-sky transition-colors">
                                    {lesson.title}
                                </h3>
                                <p class="text-sm text-ink-light">{lesson.desc}</p>
                            </a>
                        ) : (
                            <div class="lesson-card opacity-50">
                                <div class="flex items-start justify-between mb-3">
                                    <div class="w-12 h-10 rounded-xl flex items-center justify-center bg-gray-300 text-white font-bold text-sm">
                                        {lesson.week}{lesson.part}
                                    </div>
                                    <span class="material-symbols-outlined text-gray-300">lock</span>
                                </div>
                                <h3 class="font-bold text-ink-deep mb-1">{lesson.title}</h3>
                                <p class="text-sm text-ink-light">{lesson.desc}</p>
                            </div>
                        )
                    ))}
                </div>

                <!-- 1개월차 복습 카드 -->
                <div class="mt-6">
                    <a
                        href="/lessons/review-month1"
                        class="block w-full lesson-card group bg-gradient-to-r from-neon-mint/10 via-neon-sky/10 to-neon-gold/10 border-2 border-neon-mint/30 hover:border-neon-mint/60 transition-all"
                    >
                        <div class="flex items-center gap-4">
                            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-neon-mint to-neon-sky flex items-center justify-center text-white text-2xl font-bold shrink-0">
                                🔄
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="font-bold text-lg text-ink-deep group-hover:text-neon-mint transition-colors">
                                        1개월차 종합 복습
                                    </h3>
                                    <span class="badge badge-success text-xs">32 슬라이드</span>
                                </div>
                                <p class="text-sm text-ink-light">
                                    스튜디오 적응 • 변수 • 함수 • 이벤트 • 조건문 | 배운 모든 것을 복습하고 종합 실습까지!
                                </p>
                            </div>
                            <div class="text-neon-mint text-2xl group-hover:translate-x-1 transition-transform">
                                →
                            </div>
                        </div>
                    </a>
                </div>
            </section>

            <!-- 2개월차 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-6">
                    <span class="badge badge-lesson">2개월차</span>
                    <h2 class="title-section">게임 로직 심화</h2>
                    <span class="text-sm text-ink-light">(5~8주)</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    {month2.map(lesson => (
                        lesson.active ? (
                            <a
                                href={lesson.path}
                                class="lesson-card group"
                            >
                                <div class="flex items-start justify-between mb-3">
                                    <div class="w-12 h-10 rounded-xl flex items-center justify-center text-white font-bold bg-gradient-to-br from-ink-deep to-ink-medium text-sm">
                                        {lesson.week}{lesson.part}
                                    </div>
                                    <span class="badge badge-success text-xs">수강 가능</span>
                                </div>
                                <h3 class="font-bold text-ink-deep mb-1 group-hover:text-neon-sky transition-colors">
                                    {lesson.title}
                                </h3>
                                <p class="text-sm text-ink-light">{lesson.desc}</p>
                            </a>
                        ) : (
                            <div class="lesson-card opacity-50">
                                <div class="flex items-start justify-between mb-3">
                                    <div class="w-12 h-10 rounded-xl flex items-center justify-center bg-gray-300 text-white font-bold text-sm">
                                        {lesson.week}{lesson.part}
                                    </div>
                                    <span class="material-symbols-outlined text-gray-300">lock</span>
                                </div>
                                <h3 class="font-bold text-ink-deep mb-1">{lesson.title}</h3>
                                <p class="text-sm text-ink-light">{lesson.desc}</p>
                            </div>
                        )
                    ))}
                </div>

                <!-- 보너스 차시 카드 -->
                <div class="mt-6">
                    <a
                        href="/lessons/bonus/gui-visual-effects"
                        class="block w-full lesson-card group bg-gradient-to-r from-neon-gold/10 via-neon-coral/10 to-neon-mint/10 border-2 border-neon-gold/30 hover:border-neon-gold/60 transition-all"
                    >
                        <div class="flex items-center gap-4">
                            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-neon-gold to-neon-coral flex items-center justify-center text-white text-2xl font-bold shrink-0">
                                🎨
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="font-bold text-lg text-ink-deep group-hover:text-neon-gold transition-colors">
                                        GUI와 시각 효과
                                    </h3>
                                    <span class="badge badge-lesson text-xs">보너스</span>
                                </div>
                                <p class="text-sm text-ink-light">
                                    SurfaceGui로 파트에 텍스트 표시 • 용암 효과 • 힐링 효과 | 5B 학습 후 추천!
                                </p>
                            </div>
                            <div class="text-neon-gold text-2xl group-hover:translate-x-1 transition-transform">
                                →
                            </div>
                        </div>
                    </a>
                </div>

                <!-- 지형 생성 보너스 카드 -->
                <div class="mt-4">
                    <a
                        href="/lessons/bonus/terrain-editor"
                        class="block w-full lesson-card group bg-gradient-to-r from-neon-mint/10 via-neon-sky/10 to-neon-gold/10 border-2 border-neon-mint/30 hover:border-neon-mint/60 transition-all"
                    >
                        <div class="flex items-center gap-4">
                            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-neon-mint to-neon-sky flex items-center justify-center text-white text-2xl font-bold shrink-0">
                                🏔️
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="font-bold text-lg text-ink-deep group-hover:text-neon-mint transition-colors">
                                        지형 생성과 편집
                                    </h3>
                                    <span class="badge badge-lesson text-xs">보너스</span>
                                </div>
                                <p class="text-sm text-ink-light">
                                    Terrain Editor로 산, 호수, 섬 만들기 • Generate, Sculpt, Paint | 코딩 없이 스튜디오만!
                                </p>
                            </div>
                            <div class="text-neon-mint text-2xl group-hover:translate-x-1 transition-transform">
                                →
                            </div>
                        </div>
                    </a>
                </div>
            </section>

            <!-- 3개월차 -->
            <section>
                <div class="flex items-center gap-3 mb-6">
                    <span class="badge badge-lesson">3개월차</span>
                    <h2 class="title-section">프로젝트 완성</h2>
                    <span class="text-sm text-ink-light">(9~12주)</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    {month3.map(lesson => (
                        lesson.active ? (
                            <a
                                href={lesson.path}
                                class="lesson-card group"
                            >
                                <div class="flex items-start justify-between mb-3">
                                    <div class="w-12 h-10 rounded-xl flex items-center justify-center text-white font-bold bg-gradient-to-br from-ink-deep to-ink-medium text-sm">
                                        {lesson.week}{lesson.part}
                                    </div>
                                    <span class="badge badge-success text-xs">수강 가능</span>
                                </div>
                                <h3 class="font-bold text-ink-deep mb-1 group-hover:text-neon-sky transition-colors">
                                    {lesson.title}
                                </h3>
                                <p class="text-sm text-ink-light">{lesson.desc}</p>
                            </a>
                        ) : (
                            <div class="lesson-card opacity-50">
                                <div class="flex items-start justify-between mb-3">
                                    <div class="w-12 h-10 rounded-xl flex items-center justify-center bg-gray-300 text-white font-bold text-sm">
                                        {lesson.week}{lesson.part}
                                    </div>
                                    <span class="material-symbols-outlined text-gray-300">lock</span>
                                </div>
                                <h3 class="font-bold text-ink-deep mb-1">{lesson.title}</h3>
                                <p class="text-sm text-ink-light">{lesson.desc}</p>
                            </div>
                        )
                    ))}
                </div>
            </section>
        </main>

        <!-- 푸터 -->
        <footer class="border-t border-ink-pale py-8 text-center text-ink-light text-sm">
            <p>🎮 로블록스 과외 커리큘럼 | Astro + Lit + Wasmoon</p>
        </footer>
    </div>

    <style>
        .bg-ink-cream { background: var(--ink-cream); }
        .bg-roblox-red { background: var(--roblox-red); }
        .text-ink-deep { color: var(--ink-deep); }
        .text-ink-light { color: var(--ink-light); }
        .border-ink-pale { border-color: var(--ink-pale); }
    </style>

    <!-- index 페이지 스크롤 활성화 -->
    <style is:global>
        body {
            overflow-y: auto !important;
            overflow-x: hidden;
        }
    </style>
</BaseLayout>
